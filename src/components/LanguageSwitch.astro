---
import { hasEnglishPost, localizedPath } from '../i18n';

const currentPath = Astro.url.pathname;
const zhPath = localizedPath(currentPath, 'zh');
const enPath = localizedPath(currentPath, 'en');
const isEnglish = currentPath === '/en' || currentPath.startsWith('/en/');
const chinesePostMatch = currentPath.match(/^\/blog\/([^/]+)\/?$/);
const hasEnglishVersion = !chinesePostMatch || hasEnglishPost(chinesePostMatch[1]);
---

<div class="language-switch" aria-label="Language switcher">
	{
		isEnglish ? (
			<a href={zhPath} aria-label="切换到中文"><span>中 / </span><b>EN</b></a>
		) : hasEnglishVersion ? (
			<a href={enPath} aria-label="Switch to English"><b>中</b><span> / EN</span></a>
		) : (
			<span class="language-disabled" aria-disabled="true" title="English translation coming soon">
				<b>中</b><span> / EN</span>
			</span>
		)
	}
</div>

<style>
	.language-switch {
		display: inline-flex;
		align-items: center;
	}

	.language-switch a,
	.language-disabled {
		color: var(--muted);
		font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12.5px;
		letter-spacing: 0.08em;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.language-switch b {
		color: var(--text);
		font-weight: 500;
	}

	.language-switch a span {
		transition: color 0.18s ease;
	}

	.language-switch a:hover span {
		color: var(--accent-dark);
	}

	.language-disabled {
		cursor: not-allowed;
		opacity: 0.52;
	}

	@media (prefers-reduced-motion: reduce) {
		.language-switch a span {
			transition: none;
		}
	}
</style>
