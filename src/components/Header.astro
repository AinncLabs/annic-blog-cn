---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import { isEnglishPath, SITE_COPY } from '../i18n';

const isEnglish = isEnglishPath(Astro.url.pathname);
const copy = isEnglish ? SITE_COPY.en : SITE_COPY.zh;
const rootPath = isEnglish ? '/en/' : '/';
const blogPath = isEnglish ? '/en/blog/' : '/blog/';
const aboutPath = isEnglish ? '/en/about/' : '/about/';
---

<header>
	<nav>
		<a class="brand" href={rootPath}>
			<span class="brand-mark">
				<img src="/ainnc-logo-icon.webp" width="36" height="36" alt="Ainnc" />
			</span>
			<span>{copy.title}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href={rootPath}>{copy.home}</HeaderLink>
			<HeaderLink href={blogPath}>{copy.blog}</HeaderLink>
			<HeaderLink href={aboutPath}>{copy.about}</HeaderLink>
			<a class="site-link" href="https://www.ainnc.com/#hero" target="_blank" rel="noopener noreferrer">
				{copy.officialSite}
			</a>
			<a
				class="telegram-link"
				href="https://t.me/qccbot2026"
				target="_blank"
				rel="noopener noreferrer"
				aria-label={copy.telegram}
				title={copy.telegram}
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M21.7 4.2c.3-1.2-.8-2.1-1.9-1.6L2.9 9.1c-1.2.5-1.2 2.1.1 2.5l4.3 1.3 1.6 5.1c.4 1.2 1.9 1.5 2.6.5l2.3-3.1 4.4 3.2c1 .7 2.4.2 2.7-1L21.7 4.2ZM8.1 11.8l8.4-5.2c.4-.2.8.3.5.6l-6.9 6.4-.3 2.8-1.1-3.5a1.5 1.5 0 0 0-.6-1.1Z"
						fill="currentColor"
					/>
				</svg>
			</a>
			<LanguageSwitch />
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--line);
		background: white;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 6%);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		gap: 0.65rem;
		color: var(--text);
		font-weight: 800;
		text-decoration: none;
	}
	.brand > span:last-child {
		white-space: nowrap;
	}
	.brand-mark {
		display: grid;
		width: 2.25rem;
		height: 2.25rem;
		place-items: center;
		overflow: hidden;
		border-radius: 10px;
		background: #081817;
		box-shadow: 0 8px 22px rgba(0, 201, 170, 28%);
	}
	.brand-mark :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(1120px, calc(100% - 2rem));
		min-height: 68px;
		margin: 0 auto;
	}
	nav a {
		color: var(--muted);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}
	.internal-links :global(a.active) {
		background: var(--surface-blue);
		color: var(--accent-dark);
		box-shadow: inset 0 0 0 1px rgba(0, 201, 170, 18%);
	}
	.site-link {
		display: inline-flex;
		align-items: center;
		border-radius: 8px;
		background: var(--accent);
		padding: 0.45rem 0.8rem;
		color: white;
		font-size: 0.95rem;
		font-weight: 800;
		white-space: nowrap;
		transition:
			background 0.18s ease,
			transform 0.18s ease;
	}
	.site-link:hover {
		background: var(--accent-dark);
		color: white;
		transform: translateY(-1px);
	}
	.telegram-link {
		display: inline-grid;
		width: 2.15rem;
		height: 2.15rem;
		place-items: center;
		border: 1px solid #99f6e4;
		border-radius: 999px;
		background: var(--surface-blue);
		color: var(--accent-dark);
		transition:
			background 0.18s ease,
			color 0.18s ease,
			transform 0.18s ease;
	}
	.telegram-link:hover {
		border-color: var(--accent);
		background: var(--accent);
		color: white;
		transform: translateY(-1px);
	}
	.telegram-link svg {
		width: 1.1rem;
		height: 1.1rem;
	}
	@media (max-width: 720px) {
		nav {
			gap: 1rem;
			overflow-x: auto;
		}
	}
</style>
