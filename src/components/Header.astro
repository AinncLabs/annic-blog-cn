---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import { isEnglishPath, SITE_COPY } from '../i18n';

const isEnglish = isEnglishPath(Astro.url.pathname);
const copy = isEnglish ? SITE_COPY.en : SITE_COPY.zh;
const rootPath = isEnglish ? '/en/' : '/';
const blogPath = isEnglish ? '/en/blog/' : '/blog/';
const aboutPath = isEnglish ? '/en/about/' : '/about/';
---

<header class="site-header" data-site-header>
	<nav class="nav-inner" aria-label={isEnglish ? 'Primary navigation' : '主导航'}>
		<a class="brand" href={rootPath} aria-label={isEnglish ? 'Ainnc home' : 'Ainnc 麦芽营销首页'}>
			<img src="/ainnc-logo-icon.webp" width="30" height="30" alt="" aria-hidden="true" />
			<span class="brand-name">Ainnc{!isEnglish && <span class="brand-local">麦芽营销</span>}</span>
		</a>

		<div class="nav-links">
			<HeaderLink href={rootPath}>{copy.home}</HeaderLink>
			<HeaderLink href={blogPath}>{copy.blog}</HeaderLink>
			<HeaderLink href={aboutPath}>{copy.about}</HeaderLink>
		</div>

		<div class="nav-actions">
			<LanguageSwitch />
			<a
				class="telegram-link"
				href="https://t.me/qccbot2026"
				target="_blank"
				rel="noopener noreferrer"
				aria-label={copy.telegram}
				title={copy.telegram}
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M21.9 4.6c.3-1.2-.9-2.2-2-1.7L2.7 10.1c-1.2.5-1.1 2.2.1 2.6l4.6 1.5 1.8 5.6c.3 1 1.6 1.3 2.3.5l2.6-2.7 4.8 3.5c.9.7 2.2.2 2.4-.9l2.6-15.6zM9.4 13.9l8.7-6.4c.3-.2.6.2.4.4l-7.2 7-.3 3.1-1.6-4.1z" fill="currentColor" />
				</svg>
			</a>
			<span class="nav-divider" aria-hidden="true"></span>
			<a class="site-link" href="https://www.ainnc.com/#hero" target="_blank" rel="noopener noreferrer">
				<span class="cta-dot" aria-hidden="true"></span>
				<span>{copy.officialSite}</span>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M5 12h14M13 6l6 6-6 6" />
				</svg>
			</a>
		</div>
	</nav>
</header>

<script>
	const header = document.querySelector<HTMLElement>('[data-site-header]');
	const syncHeaderState = () => header?.classList.toggle('is-scrolled', window.scrollY > 8);

	syncHeaderState();
	window.addEventListener('scroll', syncHeaderState, { passive: true });
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		border-bottom: 1px solid var(--line);
		background: rgba(255, 255, 255, 72%);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		transition:
			background 0.3s ease,
			box-shadow 0.3s ease;
	}

	.site-header.is-scrolled {
		background: rgba(255, 255, 255, 86%);
		box-shadow: 0 12px 32px -20px color-mix(in srgb, var(--text) 25%, transparent);
	}

	.nav-inner {
		display: flex;
		align-items: center;
		width: min(1240px, calc(100% - 5.5rem));
		height: 68px;
		margin: 0 auto;
		gap: 44px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		gap: 11px;
		margin-right: 8px;
		color: var(--text);
		text-decoration: none;
	}

	.brand img {
		width: 30px;
		height: 30px;
		border-radius: 0;
		object-fit: contain;
	}

	.brand-name {
		font-family: 'Space Grotesk', var(--font-atkinson), sans-serif;
		font-size: 17px;
		font-weight: 700;
		letter-spacing: 0.02em;
		line-height: 1;
		white-space: nowrap;
	}

	.brand-local {
		margin-left: 7px;
		color: var(--muted);
		font-family: var(--font-atkinson), system-ui, sans-serif;
		font-size: 15px;
		font-weight: 500;
		letter-spacing: 0;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		margin-left: auto;
		gap: 22px;
	}

	.telegram-link {
		display: grid;
		width: 34px;
		height: 34px;
		place-items: center;
		border-radius: 8px;
		color: var(--muted);
		text-decoration: none;
		transition:
			background 0.18s ease,
			color 0.18s ease;
	}

	.telegram-link:hover {
		background: color-mix(in srgb, var(--text) 5%, transparent);
		color: var(--accent-dark);
	}

	.telegram-link svg {
		width: 17px;
		height: 17px;
	}

	.nav-divider {
		width: 1px;
		height: 20px;
		background: var(--line);
	}

	.site-link {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		border-radius: 999px;
		background: var(--text);
		padding: 11px 22px;
		color: var(--surface);
		font-size: 14px;
		font-weight: 500;
		letter-spacing: 0.02em;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
		transition:
			background 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.site-link:hover {
		background: color-mix(in srgb, var(--text) 92%, var(--accent-dark));
		box-shadow: 0 10px 24px -10px color-mix(in srgb, var(--text) 50%, transparent);
		color: var(--surface);
		transform: translateY(-1px);
	}

	.cta-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 8px var(--accent);
	}

	.site-link svg {
		width: 14px;
		height: 14px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2.4;
		transition: transform 0.2s ease;
	}

	.site-link:hover svg {
		transform: translateX(3px);
	}

	@media (max-width: 860px) {
		.nav-inner {
			width: calc(100% - 2.5rem);
			gap: 20px;
		}

		.nav-links,
		.brand-local {
			display: none;
		}
	}

	@media (max-width: 520px) {
		.nav-inner {
			width: calc(100% - 1.75rem);
			gap: 12px;
		}

		.nav-actions {
			gap: 10px;
		}

		.nav-divider {
			display: none;
		}

		.site-link {
			gap: 7px;
			padding: 10px 13px;
		}

		.site-link svg {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-header,
		.telegram-link,
		.site-link,
		.site-link svg {
			transition: none;
		}
	}
</style>
