---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">
			<span class="brand-mark">
				<img src="/ainnc-logo-icon.png" width="36" height="36" alt="Ainnc" />
			</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<a class="site-link" href="https://www.ainnc.com/#hero" target="_blank" rel="noopener noreferrer">
				进入官网
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--line);
		background: white;
		box-shadow: 0 8px 30px rgba(15, 23, 42, 6%);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		color: var(--text);
		font-weight: 800;
		text-decoration: none;
	}
	.brand-mark {
		display: grid;
		width: 2.25rem;
		height: 2.25rem;
		place-items: center;
		overflow: hidden;
		border-radius: 10px;
		background: #081817;
		box-shadow: 0 8px 22px rgba(0, 201, 170, 28%);
	}
	.brand-mark :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(1120px, calc(100% - 2rem));
		min-height: 68px;
		margin: 0 auto;
	}
	nav a {
		color: var(--muted);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}
	.site-link {
		display: inline-flex;
		align-items: center;
		border-radius: 8px;
		background: var(--accent);
		padding: 0.45rem 0.8rem;
		color: white;
		font-size: 0.95rem;
		font-weight: 800;
		white-space: nowrap;
	}
	.site-link:hover {
		background: var(--accent-dark);
		color: white;
	}
	@media (max-width: 720px) {
		nav {
			gap: 1rem;
			overflow-x: auto;
		}
	}
</style>
