---
import HeaderLink from './HeaderLink.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import { isEnglishPath, SITE_COPY } from '../i18n';

const isEnglish = isEnglishPath(Astro.url.pathname);
const copy = isEnglish ? SITE_COPY.en : SITE_COPY.zh;
const rootPath = isEnglish ? '/en/' : '/';
const blogPath = isEnglish ? '/en/blog/' : '/blog/';
const aboutPath = isEnglish ? '/en/about/' : '/about/';
---

<header>
	<nav>
		<a class="brand" href={rootPath}>
			<span class="brand-mark">
				<img src="/ainnc-logo-icon.webp" width="36" height="36" alt="Ainnc" />
			</span>
			<span>{copy.title}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href={rootPath}>{copy.home}</HeaderLink>
			<HeaderLink href={blogPath}>{copy.blog}</HeaderLink>
			<HeaderLink href={aboutPath}>{copy.about}</HeaderLink>
			<a class="site-link" href="https://www.ainnc.com/#hero" target="_blank" rel="noopener noreferrer">
				{copy.officialSite}
			</a>
			<a
				class="telegram-link"
				href="https://t.me/qccbot2026"
				target="_blank"
				rel="noopener noreferrer"
				aria-label={copy.telegram}
				title={copy.telegram}
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M21.7 4.2c.3-1.2-.8-2.1-1.9-1.6L2.9 9.1c-1.2.5-1.2 2.1.1 2.5l4.3 1.3 1.6 5.1c.4 1.2 1.9 1.5 2.6.5l2.3-3.1 4.4 3.2c1 .7 2.4.2 2.7-1L21.7 4.2ZM8.1 11.8l8.4-5.2c.4-.2.8.3.5.6l-6.9 6.4-.3 2.8-1.1-3.5a1.5 1.5 0 0 0-.6-1.1Z"
						fill="currentColor"
					/>
				</svg>
			</a>
			<LanguageSwitch />
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--line);
		background: rgba(255, 255, 255, 92%);
		backdrop-filter: blur(22px);
		box-shadow: 0 12px 34px rgba(15, 23, 42, 4%);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		gap: 0.85rem;
		color: var(--text);
		font-size: 1.18rem;
		font-weight: 900;
		letter-spacing: 0;
		text-decoration: none;
	}
	.brand > span:last-child {
		white-space: nowrap;
	}
	.brand-mark {
		display: grid;
		width: 2.15rem;
		height: 2.15rem;
		place-items: center;
		overflow: hidden;
		border-radius: 8px;
		background: transparent;
		box-shadow: 0 12px 26px rgba(0, 201, 170, 10%);
	}
	.brand-mark :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(var(--page-max), calc(100% - 2.5rem));
		min-height: 76px;
		margin: 0 auto;
	}
	nav a {
		color: var(--muted);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		gap: 1.15rem;
		align-items: center;
	}
	.internal-links :global(a.active) {
		color: var(--text);
	}
	.internal-links .site-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.85rem;
		border: 1px solid rgba(0, 174, 176, 34%);
		border-radius: 7px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 20%), transparent 46%),
			linear-gradient(135deg, #2fe0d0 0%, #00c9aa 58%, #00a8af 100%);
		padding: 0.45rem 1.28rem;
		color: var(--text);
		font-size: 0.98rem;
		font-weight: 900;
		white-space: nowrap;
		box-shadow:
			0 12px 22px rgba(0, 174, 176, 18%),
			inset 0 1px 0 rgba(255, 255, 255, 42%),
			inset 0 -8px 14px rgba(0, 91, 92, 12%);
		transition:
			box-shadow 0.18s ease,
			transform 0.18s ease;
	}
	.internal-links .site-link:hover {
		color: var(--text);
		transform: translateY(-2px);
		box-shadow:
			0 16px 28px rgba(0, 174, 176, 24%),
			inset 0 1px 0 rgba(255, 255, 255, 50%),
			inset 0 -8px 14px rgba(0, 91, 92, 10%);
	}
	.internal-links .telegram-link {
		display: inline-grid;
		width: 2.65rem;
		height: 2.65rem;
		place-items: center;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(255, 255, 255, 68%);
		color: var(--accent);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 86%);
		transition:
			border-color 0.18s ease,
			background 0.18s ease,
			box-shadow 0.18s ease,
			color 0.18s ease,
			transform 0.18s ease;
	}
	.internal-links .telegram-link:hover {
		border-color: var(--accent);
		background: var(--surface-blue);
		color: var(--accent-dark);
		box-shadow:
			0 12px 24px rgba(0, 201, 170, 14%),
			inset 0 1px 0 rgba(255, 255, 255, 90%);
		transform: translateY(-1px);
	}
	.internal-links .telegram-link svg {
		width: 1.08rem;
		height: 1.08rem;
	}
	@media (max-width: 720px) {
		nav {
			gap: 1rem;
			overflow-x: auto;
		}
	}
</style>
