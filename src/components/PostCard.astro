---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { getCategoryTone, getPostCode } from '../blogVisuals';
import { getPostMeta, type Locale } from '../i18n';

interface Props {
	post: CollectionEntry<'blog'>;
	featured?: boolean;
	index?: number;
	locale?: Locale;
	variant?: 'media' | 'bento';
	span?: 'wide' | 'tall' | 'none';
}

const { post, featured = false, index = 0, locale = 'zh', variant = 'media', span = 'none' } = Astro.props;
const meta = getPostMeta(post, locale);
const postHref = locale === 'en' ? `/en/blog/${post.id}/` : `/blog/${post.id}/`;
const tagLabel = locale === 'en' ? 'Post tags' : '文章标签';
const readLabel = locale === 'en' ? 'Read article' : '阅读全文';
const tone = getCategoryTone(meta.category);
const postCode = getPostCode(meta.category, index);
---

<article class:list={['post-card', variant, span, { featured }]} data-category={meta.category} data-tone={tone}>
	<span class="accent-bar" aria-hidden="true"></span>
	<span class="card-glare" aria-hidden="true"></span>
	<div class="post-body">
		<div class="card-code">
			<span class="code-dot" aria-hidden="true"></span>
			<span>{postCode}</span>
		</div>
		<div class="post-meta">
			<span>{meta.category}</span>
			<span><FormattedDate date={post.data.pubDate} locale={locale} /></span>
		</div>
		<h2><a href={postHref}>{meta.title}</a></h2>
		<p>{meta.description}</p>
		<a class="read-link" href={postHref}>{readLabel}<span aria-hidden="true">-&gt;</span></a>
		{
			meta.tags.length > 0 && (
				<ul class="content-tags card-tags" aria-label={tagLabel}>
					{meta.tags.slice(0, 6).map((tag) => (
						<li>#{tag}</li>
					))}
				</ul>
			)
		}
	</div>
</article>
