---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { getCategoryTone, getPostCode } from '../blogVisuals';
import { getPostMeta, type Locale } from '../i18n';

interface Props {
	post: CollectionEntry<'blog'>;
	featured?: boolean;
	index?: number;
	locale?: Locale;
}

const { post, featured = false, index = 0, locale = 'zh' } = Astro.props;
const meta = getPostMeta(post, locale);
const postHref = locale === 'en' ? `/en/blog/${post.id}/` : `/blog/${post.id}/`;
const tagLabel = locale === 'en' ? 'Post tags' : '文章标签';
const readLabel = locale === 'en' ? 'Read article' : '阅读全文';
const tone = getCategoryTone(meta.category);
const postCode = getPostCode(meta.category, index);
---

<article class:list={['post-card', { featured }]} data-category={meta.category} data-tone={tone}>
	<a href={postHref} class="media-link" aria-label={meta.title}>
		{
			post.data.heroImage && (
				<Image
					width={featured ? 960 : 640}
					height={featured ? 480 : 360}
					src={post.data.heroImage}
					alt=""
					loading={featured ? 'eager' : 'lazy'}
				/>
			)
		}
	</a>
	<div class="post-body">
		<div class="card-code">
			<span class="code-dot" aria-hidden="true"></span>
			<span>{postCode}</span>
		</div>
		<div class="post-meta">
			<span>{meta.category}</span>
			<span><FormattedDate date={post.data.pubDate} locale={locale} /></span>
		</div>
		<h2><a href={postHref}>{meta.title}</a></h2>
		<p>{meta.description}</p>
		{
			meta.tags.length > 0 && (
				<ul class="tag-list" aria-label={tagLabel}>
					{meta.tags.map((tag) => (
						<li>{tag}</li>
					))}
				</ul>
			)
		}
		<a class="read-link" href={postHref}>{readLabel}<span aria-hidden="true">-&gt;</span></a>
	</div>
</article>
