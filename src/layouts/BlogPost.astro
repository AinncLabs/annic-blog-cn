---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCategoryTone, getPostCode } from '../blogVisuals';
import { getPostMeta, hasEnglishPost, type Locale } from '../i18n';

type Props = CollectionEntry<'blog'>['data'] & {
	locale?: Locale;
	postIndex?: number;
	postId?: string;
	schemaFaq?: Array<{ question: string; answer: string }>;
};

const {
	title,
	description,
	author,
	pubDate,
	updatedDate,
	category = 'Ainnc',
	tags = [],
	tldr = [],
	faq = [],
	locale = 'zh',
	postIndex = 0,
	postId = '',
	schemaFaq = [],
} = Astro.props;
const isEnglish = locale === 'en';
const tagLabel = isEnglish ? 'Post tags' : '文章标签';
const authorName = author ?? (isEnglish ? 'Ainnc Team' : 'Ainnc 麦芽营销团队');
const authorLabel = isEnglish ? 'By' : '作者';
const blogPath = isEnglish ? '/en/blog/' : '/blog/';
const backLabel = isEnglish ? 'Back to Blog' : '返回博客列表';
const ctaByTone = {
	ops: {
		zh: ['让账号、任务和交接记录回到同一个工作现场', '看看 Ainnc 如何帮助代运营团队减少重复确认，在账号规模增长后仍然保留清楚的状态与责任记录。'],
		en: ['Keep accounts, tasks, and handoffs in one operating context', 'See how Ainnc helps agency teams reduce repeated confirmation and preserve clear ownership as account volume grows.'],
	},
	product: {
		zh: ['把账号、环境、素材和任务放进同一条可追溯记录', '了解 Ainnc 如何连接账号环境、代理、素材与执行结果，让故障排查和下一次决策不再依赖个人记忆。'],
		en: ['Connect accounts, environments, assets, and tasks in one traceable record', 'See how Ainnc connects operating context with execution results so troubleshooting does not depend on individual memory.'],
	},
	platform: {
		zh: ['用可解释的环境和任务记录运营多个平台', '查看 Ainnc 如何让 TikTok、Instagram、Reddit 和 X 的账号环境、素材与任务分别管理，同时保留统一复盘入口。'],
		en: ['Run multiple platforms with explainable environments and task records', 'See how Ainnc separates platform-specific execution while keeping account, asset, and review records connected.'],
	},
	insights: {
		zh: ['让内容判断最终回到账号状态和业务结果', '了解 Ainnc 如何把内容素材、账号分组与任务结果连接起来，让团队能够验证一个判断，而不只是继续增加发布数量。'],
		en: ['Connect content judgment with account state and business outcomes', 'See how Ainnc connects assets, account groups, and task results so teams can validate decisions instead of only increasing output.'],
	},
	default: {
		zh: ['用一个平台运营你的整个社媒矩阵', '看看 Ainnc 如何在规模化场景下处理账号隔离、代理 IP、素材管理和批量发布。'],
		en: ['Run Your Social Account Matrix From One Platform', 'See how Ainnc handles account isolation, proxy IPs, content assets, and bulk publishing for scaled operations.'],
	},
} as const;
const telegramLabel = isEnglish ? 'Contact on Telegram' : 'Telegram 咨询';
const tocLabel = isEnglish ? 'In This Article' : '文章目录';
const tocHint = isEnglish ? 'Timeline' : '时间轴';
const tldrLabel = isEnglish ? 'TL;DR' : 'TL;DR';
const faqLabel = isEnglish ? 'FAQ' : '常见问题';
const categoryTone = getCategoryTone(category);
const ctaCopy = ctaByTone[categoryTone as keyof typeof ctaByTone] ?? ctaByTone.default;
const [ctaTitle, ctaDescription] = isEnglish ? ctaCopy.en : ctaCopy.zh;
const officialLabel = isEnglish ? 'See the Ainnc Operations Platform' : '查看 Ainnc 运营底座';
const postCode = getPostCode(category, postIndex);
const tldrItems = tldr;
const faqItems = faq;
const faqSchemaItems = schemaFaq.length > 0 ? schemaFaq : faqItems;
const displayUpdatedDate = updatedDate ?? pubDate;
const publishedPosts = await getCollection('blog', (post) => !post.data.draft && post.id !== postId && (!isEnglish || hasEnglishPost(post.id)));
const scoredRelatedPosts = publishedPosts
	.map((post) => {
		const meta = getPostMeta(post, locale);
		const sharedTags = meta.tags.filter((tag) => tags.includes(tag)).length;
		const score = (meta.category === category ? 5 : 0) + sharedTags * 2;
		return { post, meta, score };
	})
	.filter((item) => item.score > 0)
	.sort((first, second) => second.score - first.score || second.post.data.pubDate.valueOf() - first.post.data.pubDate.valueOf())
	.slice(0, 3);
const relatedLabel = isEnglish ? 'Continue the Decision' : '沿着这个问题继续判断';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const logoURL = new URL('/ainnc-logo-icon.webp', Astro.site);
const schemaGraph: Record<string, unknown>[] = [
	{
		'@type': 'BlogPosting',
		'@id': `${canonicalURL.href}#article`,
		headline: title,
		description,
		datePublished: pubDate.toISOString(),
		dateModified: displayUpdatedDate.toISOString(),
		inLanguage: isEnglish ? 'en' : 'zh-CN',
		articleSection: category,
		keywords: tags.join(', '),
		mainEntityOfPage: canonicalURL.href,
		author: { '@type': 'Organization', name: authorName },
		publisher: {
			'@type': 'Organization',
			name: 'Ainnc',
			url: 'https://www.ainnc.com/',
			logo: { '@type': 'ImageObject', url: logoURL.href },
		},
		image: logoURL.href,
	},
	{
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: isEnglish ? 'Home' : '首页', item: new URL(isEnglish ? '/en/' : '/', Astro.site).href },
			{ '@type': 'ListItem', position: 2, name: isEnglish ? 'Blog' : '博客', item: new URL(blogPath, Astro.site).href },
			{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.href },
		],
	},
];
if (faqSchemaItems.length > 0) {
	schemaGraph.push({
		'@type': 'FAQPage',
		mainEntity: faqSchemaItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: { '@type': 'Answer', text: item.answer },
		})),
	});
}
const structuredData = { '@context': 'https://schema.org', '@graph': schemaGraph };
---

<html lang={isEnglish ? 'en' : 'zh-CN'}>
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</head>

	<body>
		<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
		<Header />
		<main>
			<a class="back-link" href={blogPath}><span aria-hidden="true">&larr;</span>{backLabel}</a>
			<article class="article-shell" data-tone={categoryTone}>
				<header class="article-header">
					<div class="article-code">
						<span>ARTICLE</span>
						<span aria-hidden="true">/</span>
						<span>{postCode}</span>
					</div>
					<div class="post-meta">
						<span>{category}</span>
						<span>
							<FormattedDate date={pubDate} locale={locale} />
							<span class="updated-date">
								{isEnglish ? ' (updated ' : '（更新于'}
								<FormattedDate date={displayUpdatedDate} locale={locale} />
								{isEnglish ? ')' : '）'}
							</span>
						</span>
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					<div class="article-byline">
						<span>{authorLabel} {authorName}</span>
						{
							tags.length > 0 && (
								<ul class="content-tags article-header-tags" aria-label={tagLabel}>
									{tags.slice(0, 6).map((tag) => (
										<li>#{tag}</li>
									))}
								</ul>
							)
						}
					</div>
				</header>

				<div class="article-body-grid">
					<aside class="article-toc" id="article-toc" aria-label={tocLabel}>
						<div class="toc-card">
							<div class="toc-kicker">{tocHint}</div>
							<h2>{tocLabel}</h2>
							<nav class="toc-list" id="article-toc-list"></nav>
						</div>
					</aside>

					<div class="prose panel">
						{
							tldrItems.length > 0 && (
								<aside class="tldr-block" aria-label={tldrLabel}>
									<strong>{tldrLabel}</strong>
									{tldrItems.map((item) => (
										<p>{item}</p>
									))}
								</aside>
							)
						}
						<slot />
						{
							faqItems.length > 0 && (
								<section class="faq-section" aria-label={faqLabel}>
									<h2>{faqLabel}</h2>
									{faqItems.map((item) => (
										<details>
											<summary>{item.question}</summary>
											<p>{item.answer}</p>
										</details>
									))}
								</section>
							)
						}
					</div>
				</div>

				{
					scoredRelatedPosts.length > 0 && (
						<nav class="related-reading" aria-label={relatedLabel}>
							<div class="related-reading-head">
								<span>{relatedLabel}</span>
								<small>{isEnglish ? 'Related evidence and next questions' : '相关证据与下一步问题'}</small>
							</div>
							<div class="related-reading-grid">
								{scoredRelatedPosts.map(({ post, meta }) => (
									<a href={`${isEnglish ? '/en' : ''}/blog/${post.id}/`}>
										<span>{meta.category}</span>
										<strong>{meta.title}</strong>
										<em>{isEnglish ? 'Read next →' : '继续阅读 →'}</em>
									</a>
								))}
							</div>
						</nav>
					)
				}

				<div class="article-cta-row">
					<section class="article-cta">
						<h2>{ctaTitle}</h2>
						<p>{ctaDescription}</p>
						<div class="cta-actions">
							<a href="https://www.ainnc.com/#hero" target="_blank" rel="noopener noreferrer">
								{officialLabel}
							</a>
							<a class="secondary-cta" href="https://t.me/qccbot2026" target="_blank" rel="noopener noreferrer">
								{telegramLabel}
							</a>
						</div>
					</section>
				</div>
			</article>
		</main>
		<button class="back-to-top" type="button" id="back-to-top" aria-label={isEnglish ? 'Back to top' : '返回顶部'}>
			&uarr;
		</button>
		<Footer />
		<script>
			const progress = document.getElementById('reading-progress');
			const backToTop = document.getElementById('back-to-top');
			const toc = document.getElementById('article-toc');
			const tocList = document.getElementById('article-toc-list');
			const articleHeadings = Array.from(document.querySelectorAll<HTMLElement>('.prose h2, .prose h3')).filter(
				(heading) => !heading.closest('.tldr-block, .faq-section')
			);

			function slugifyHeading(text: string, index: number) {
				const slug = text
					.trim()
					.toLowerCase()
					.replace(/[^\p{Letter}\p{Number}]+/gu, '-')
					.replace(/^-+|-+$/g, '');
				return slug || `section-${index + 1}`;
			}

			if (toc && tocList) {
				if (articleHeadings.length < 2) {
					toc.hidden = true;
					toc.closest('.article-body-grid')?.classList.add('toc-hidden');
				} else {
					const usedHeadingIds = new Set<string>();
					articleHeadings.forEach((heading, index) => {
						if (!heading.id) {
							heading.id = slugifyHeading(heading.textContent || '', index);
						}
						let uniqueId = heading.id;
						let suffix = 2;
						while (usedHeadingIds.has(uniqueId)) {
							uniqueId = `${heading.id}-${suffix}`;
							suffix += 1;
						}
						heading.id = uniqueId;
						usedHeadingIds.add(uniqueId);

						const link = document.createElement('a');
						link.href = `#${heading.id}`;
						link.className = `toc-link depth-${heading.tagName.toLowerCase()}`;
						link.dataset.target = heading.id;
						const dot = document.createElement('span');
						dot.className = 'toc-dot';
						dot.setAttribute('aria-hidden', 'true');
						const label = document.createElement('span');
						label.textContent = heading.textContent || '';
						link.append(dot, label);
						tocList.appendChild(link);
					});
				}
			}

			function updateReadingState() {
				const scrollable = document.documentElement.scrollHeight - window.innerHeight;
				const percent = scrollable > 0 ? Math.min(100, (window.scrollY / scrollable) * 100) : 0;
				if (progress) {
					progress.style.width = `${percent}%`;
				}
				if (backToTop) {
					backToTop.classList.toggle('show', window.scrollY > 520);
				}
			}

			window.addEventListener('scroll', updateReadingState, { passive: true });
			updateReadingState();
			backToTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

			const revealItems = document.querySelectorAll('.prose > *, .prose section > *');
			if ('IntersectionObserver' in window) {
				const revealObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							entry.target.classList.add('is-visible');
							revealObserver.unobserve(entry.target);
						});
					},
					{ rootMargin: '0px 0px -10% 0px', threshold: 0.12 },
				);

				revealItems.forEach((item) => {
					item.classList.add('reveal-item');
					revealObserver.observe(item);
				});
			} else {
				revealItems.forEach((item) => item.classList.add('is-visible'));
			}

			const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-link'));
			if (tocLinks.length > 0 && 'IntersectionObserver' in window) {
				const setActiveTocLink = (id: string) => {
					tocLinks.forEach((link) => link.classList.toggle('is-active', link.dataset.target === id));
				};

				const headingObserver = new IntersectionObserver(
					(entries) => {
						const visible = entries
							.filter((entry) => entry.isIntersecting)
							.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
						if (visible?.target.id) {
							setActiveTocLink(visible.target.id);
						}
					},
					{ rootMargin: '-18% 0px -68% 0px', threshold: 0.01 },
				);

				articleHeadings.forEach((heading) => headingObserver.observe(heading));
				setActiveTocLink(articleHeadings[0]?.id || '');
			}
		</script>
	</body>
</html>

<style>
	.reading-progress {
		position: fixed;
		z-index: 30;
		top: 0;
		left: 0;
		width: 0;
		height: 3px;
		background: linear-gradient(90deg, var(--accent-dark), var(--accent));
	}

	.back-link {
		display: inline-flex;
		gap: 0.35rem;
		align-items: center;
		margin-bottom: 1rem;
		color: var(--muted);
		font-weight: 800;
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--accent-dark);
	}

	.article-shell {
		--article-accent: var(--accent-dark);
		--article-accent-soft: var(--surface-blue);
		display: grid;
		gap: 1rem;
		justify-items: center;
	}

	.article-shell[data-tone='ops'] {
		--article-accent: var(--tone-ops);
		--article-accent-soft: #e3fbf7;
	}

	.article-shell[data-tone='product'] {
		--article-accent: var(--tone-product);
		--article-accent-soft: #e1f5fb;
	}

	.article-shell[data-tone='platform'] {
		--article-accent: var(--tone-platform);
		--article-accent-soft: #e7eef6;
	}

	.article-shell[data-tone='insights'] {
		--article-accent: var(--tone-insights);
		--article-accent-soft: #e2f7ee;
	}

	.article-header {
		display: grid;
		width: min(1040px, 100%);
		gap: 1rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: white;
		padding: 2.25rem 2.65rem;
		box-shadow: var(--shadow);
	}

	.article-code {
		display: inline-flex;
		gap: 0.5rem;
		align-items: center;
		width: fit-content;
		border: 1px solid color-mix(in srgb, var(--article-accent) 26%, white);
		border-radius: 999px;
		background: var(--article-accent-soft);
		padding: 0.28rem 0.7rem;
		color: var(--article-accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.8rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.article-header p {
		max-width: 760px;
		font-size: 1.05rem;
	}

	.article-header h1 {
		max-width: 820px;
	}

	.article-byline {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		align-items: center;
		margin-top: 0.15rem;
		color: #64748b;
		font-size: 0.92rem;
		font-weight: 800;
	}

	.article-header-tags {
		align-items: center;
	}

	.updated-date {
		color: #80939a;
		font-weight: 700;
	}

	.article-body-grid {
		display: grid;
		grid-template-columns: minmax(170px, 220px) minmax(0, 780px);
		gap: 1.25rem;
		align-items: start;
		width: min(1040px, 100%);
	}

	.article-body-grid.toc-hidden {
		grid-template-columns: minmax(0, 780px);
		justify-content: center;
	}

	.article-body-grid.toc-hidden .prose {
		grid-column: 1;
	}

	.article-toc {
		position: sticky;
		top: 6rem;
		align-self: start;
	}

	.article-toc[hidden] {
		display: none;
	}

	.toc-card {
		position: relative;
		border: 1px solid color-mix(in srgb, var(--article-accent) 18%, white);
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 82%), rgba(239, 255, 252, 74%)),
			white;
		padding: 1rem;
		box-shadow: 0 18px 50px rgba(3, 47, 44, 8%);
	}

	.toc-kicker {
		display: inline-flex;
		width: fit-content;
		border: 1px solid color-mix(in srgb, var(--article-accent) 24%, white);
		border-radius: 999px;
		background: var(--article-accent-soft);
		padding: 0.2rem 0.55rem;
		color: var(--article-accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.toc-card h2 {
		margin: 0.55rem 0 0.8rem;
		font-size: 1rem;
	}

	.toc-list {
		position: relative;
		display: grid;
		gap: 0.15rem;
	}

	.toc-list::before {
		content: '';
		position: absolute;
		top: 0.45rem;
		bottom: 0.45rem;
		left: 0.34rem;
		width: 1px;
		background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--article-accent) 42%, white), transparent);
	}

	.toc-list :global(.toc-link) {
		position: relative;
		display: grid;
		grid-template-columns: 0.72rem 1fr;
		gap: 0.5rem;
		align-items: start;
		border-radius: 8px;
		padding: 0.42rem 0.35rem;
		color: var(--muted);
		font-size: 0.82rem;
		font-weight: 800;
		line-height: 1.45;
		text-decoration: none;
		transition:
			background 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.toc-list :global(.toc-link.depth-h3) {
		padding-left: 0.82rem;
		font-size: 0.76rem;
		font-weight: 700;
	}

	.toc-list :global(.toc-dot) {
		position: relative;
		z-index: 1;
		width: 0.46rem;
		height: 0.46rem;
		margin-top: 0.42em;
		border: 1px solid color-mix(in srgb, var(--article-accent) 48%, white);
		border-radius: 2px;
		background: #f5fffd;
		transform: rotate(45deg);
		transition:
			background 0.2s ease,
			box-shadow 0.2s ease,
			border-color 0.2s ease;
	}

	.toc-list :global(.toc-link:hover),
	.toc-list :global(.toc-link.is-active) {
		background: color-mix(in srgb, var(--article-accent-soft) 70%, white);
		color: #042f2d;
		transform: translateX(2px);
	}

	.toc-list :global(.toc-link:hover .toc-dot),
	.toc-list :global(.toc-link.is-active .toc-dot) {
		border-color: var(--article-accent);
		background: var(--article-accent);
		box-shadow: 0 0 0 5px color-mix(in srgb, var(--article-accent) 12%, transparent);
	}

	.prose {
		width: min(780px, 100%);
		margin: 0 auto;
		padding: 2rem;
		font-size: 1.04rem;
	}

	.prose :global(section) {
		width: 100%;
		max-width: none;
	}

	.tldr-block {
		display: grid;
		gap: 0.55rem;
		margin-bottom: 1.7rem;
		border-left: 4px solid var(--article-accent);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(227, 251, 247, 82%), rgba(248, 250, 252, 92%)),
			#f8fafc;
		padding: 1rem 1.1rem;
		box-shadow: inset 0 0 0 1px rgba(15, 118, 110, 10%);
	}

	.tldr-block strong {
		color: var(--article-accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.75rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.tldr-block p {
		margin: 0;
		color: #334155;
		font-size: 0.98rem;
		line-height: 1.7;
	}

	.prose :global(.reveal-item) {
		opacity: 0;
		transform: translateY(14px);
		transition:
			opacity 0.55s ease,
			transform 0.55s ease;
	}

	.prose :global(.reveal-item.is-visible) {
		opacity: 1;
		transform: translateY(0);
	}

	.prose :global(strong) {
		color: #073d3a;
