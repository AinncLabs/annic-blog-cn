---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const featuredIndex = featuredPost ? posts.findIndex((post) => post.id === featuredPost.id) : 0;
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);
const frameworks = [
	['ops', '运营方法论', '规模化账号运营、团队协作和交付稳定性'],
	['platform', '平台专题', 'TikTok、Instagram、Reddit、X 的执行差异'],
	['product', '产品能力解读', '账号、代理、文件、任务和用量管理'],
	['insights', '出海观察', '本地化、多市场规模化和品牌出海方法'],
];
const topics = ['运营方法论', '平台专题', '产品能力解读', '出海观察', '任务复盘', '操作教程'];
const clusterDevices = [
	{ id: 'TT-01', platform: 'TikTok', active: true },
	{ id: 'IG-02', platform: 'Instagram', active: false },
	{ id: 'RD-03', platform: 'Reddit', active: true },
	{ id: 'X-04', platform: 'X', active: false },
	{ id: 'TT-05', platform: 'TikTok', active: true },
	{ id: 'IG-06', platform: 'Instagram', active: false },
	{ id: 'RD-07', platform: 'Reddit', active: true },
	{ id: 'X-08', platform: 'X', active: false },
];
const clusterLogs = [
	['09:41', 'TikTok', '批量登录', '完成'],
	['09:46', 'Instagram', '素材同步', '运行中'],
	['09:53', 'Reddit', '帖子排队', '完成'],
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero" id="home-hero">
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<span class="hero-cursor-glow" aria-hidden="true"></span>
				<div class="hero-copy">
					<span class="section-kicker">麦芽营销团队出品</span>
					<h1>规模化运营社媒账号的实战方法</h1>
					<p>
						写给需要在 TikTok、Instagram、Reddit 和 X
						上管理成百上千个账号的代运营机构、MCN 和出海品牌团队。
					</p>
					<div class="hero-stats" aria-label="博客内容概览">
						<span><strong>{posts.length}</strong>篇文章</span>
						<span><strong>4</strong>个核心栏目</span>
						<span><strong>1</strong>套运营底座</span>
					</div>
				</div>
				<div class="cluster-wrap" aria-label="Ainnc 云端账号集群示意">
					<div class="cluster-panel">
						<div class="cluster-head">
							<span class="cluster-title">云端账号集群 · 实时任务</span>
							<span class="live-pill"><span class="live-dot"></span>RUNNING</span>
						</div>
						<div class="device-grid">
							{
								clusterDevices.map((device, index) => (
									<div
										class:list={['device-card', { active: device.active }]}
										style={`--delay: ${index * 0.16}s`}
									>
										<div class="device-top">
											<span class="device-id">{device.id}</span>
											<span class="device-dot"></span>
										</div>
										<p class="device-status">{device.platform} 环境同步</p>
										<div class="device-bar"><span></span></div>
									</div>
								))
							}
						</div>
						<div class="log-panel">
							{
								clusterLogs.map(([time, platform, action, status], index) => (
									<div class="log-line" style={`--delay: ${index * 0.18}s`}>
										<span class="lt">{time}</span>
										<span class="ld">{platform}</span>
										<span class="la">{action}</span>
										<span class="lc">{status}</span>
									</div>
								))
							}
						</div>
						<div class="cluster-stats">
							<span><strong>2,855</strong>本周发布内容</span>
							<span><strong>4</strong>覆盖平台</span>
							<span><strong>99.6%</strong>环境在线率</span>
						</div>
					</div>
				</div>
				<div class="hero-ticker" aria-hidden="true">
					<div>
						<span>TIKTOK</span>
						<span>INSTAGRAM</span>
						<span>REDDIT</span>
						<span>X</span>
						<span>云手机环境</span>
						<span>代理 IP 管理</span>
						<span>素材文件</span>
						<span>任务队列</span>
						<span>TIKTOK</span>
						<span>INSTAGRAM</span>
						<span>REDDIT</span>
						<span>X</span>
						<span>云手机环境</span>
						<span>代理 IP 管理</span>
						<span>素材文件</span>
						<span>任务队列</span>
					</div>
				</div>
			</section>

			<section class="framework-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">内容框架</span>
						<h2>从运营问题进入产品能力</h2>
					</div>
					<p>给新读者快速建立对 Ainnc 产品能力和博客内容方向的理解。</p>
				</div>
				<div class="framework-grid">
					{
						frameworks.map(([tone, title, description]) => (
							<article class="framework-card" data-tone={tone}>
								<h3>{title}</h3>
								<p>{description}</p>
							</article>
						))
					}
				</div>
			</section>

			{
				featuredPost && (
					<section class="featured-section">
						<div class="section-header">
							<div>
								<span class="eyebrow">推荐阅读</span>
								<h2>先从这篇开始</h2>
							</div>
							<p>建立对规模化社媒运营、账号矩阵和 Ainnc 工作流的第一层理解。</p>
						</div>
						<PostCard post={featuredPost} featured index={featuredIndex} />
					</section>
				)
			}

			<section class="latest-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">最新文章</span>
						<h2>持续更新的运营指南</h2>
					</div>
					<a href="/blog/">全部文章</a>
				</div>
				<div class="post-grid">
					{latestPosts.map((post) => <PostCard post={post} index={posts.findIndex((item) => item.id === post.id)} />)}
				</div>
			</section>

			<section class="topics panel">
				<div>
					<span class="eyebrow">栏目规划</span>
					<h2>围绕这些主题持续更新</h2>
				</div>
				<ul>
					{topics.map((topic) => <li>{topic}</li>)}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			const hero = document.getElementById('home-hero');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (hero && supportsHover) {
				hero.addEventListener('pointermove', (event) => {
					const rect = hero.getBoundingClientRect();
					const shiftX = ((event.clientX - rect.left) / rect.width - 0.5) * 22;
					const shiftY = ((event.clientY - rect.top) / rect.height - 0.5) * 18;
					hero.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
					hero.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
					hero.style.setProperty('--shift-x', `${shiftX}px`);
					hero.style.setProperty('--shift-y', `${shiftY}px`);
					hero.classList.add('is-glowing');
				});
				hero.addEventListener('pointerleave', () => {
					hero.classList.remove('is-glowing');
					hero.style.setProperty('--shift-x', '0px');
					hero.style.setProperty('--shift-y', '0px');
				});
			}
		</script>
	</body>
</html>

<style>
	.home-hero {
		--glow-x: 50%;
		--glow-y: 50%;
		--shift-x: 0px;
		--shift-y: 0px;
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 760px;
		align-content: center;
		justify-items: center;
		overflow: hidden;
		margin-bottom: 4rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 76%) 0, rgba(255, 255, 255, 38%) 45%, rgba(255, 255, 255, 76%) 100%),
			linear-gradient(135deg, rgba(0, 201, 170, 16%), rgba(60, 110, 159, 8%) 48%, rgba(0, 69, 76, 5%)),
			white;
		box-shadow: 0 24px 70px rgba(0, 69, 76, 12%);
		text-align: center;
	}

	.home-hero::before {
		content: '';
		position: absolute;
		inset: 1rem;
		z-index: 0;
		border: 1px solid rgba(0, 201, 170, 16%);
		border-radius: 8px;
		pointer-events: none;
	}

	.hero-watermark {
		position: absolute;
		top: -7rem;
		right: -5rem;
		z-index: 0;
		width: min(50rem, 58vw);
		opacity: 0.07;
		filter: grayscale(1) brightness(0.45);
		transform: translate3d(var(--shift-x), var(--shift-y), 0) rotate(-7deg);
		transition: transform 0.18s ease-out;
	}

	.hero-cursor-glow {
		position: absolute;
		z-index: 1;
		inset: -14%;
		background: radial-gradient(circle 280px at var(--glow-x) var(--glow-y), rgba(46, 233, 208, 30%), rgba(0, 201, 170, 12%) 34%, transparent 72%);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.home-hero.is-glowing .hero-cursor-glow {
		opacity: 1;
	}

	.hero-copy {
		position: relative;
		z-index: 3;
		display: grid;
		max-width: 720px;
		gap: 1rem;
		padding: clamp(2rem, 5vw, 4rem) 1rem 1.25rem;
		justify-items: center;
	}

	.hero-ticker span {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.hero-copy p {
		max-width: 620px;
		font-size: 1.08rem;
	}

	.hero-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.hero-stats {
		margin-top: 0.25rem;
		color: var(--muted);
		font-weight: 800;
	}

	.hero-stats span {
		border: 1px solid rgba(0, 201, 170, 28%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 72%);
		padding: 0.45rem 0.8rem;
	}

	.hero-stats strong {
		margin-right: 0.2rem;
		color: var(--text);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.cluster-wrap {
		position: relative;
		z-index: 4;
		width: min(860px, calc(100% - 2rem));
		margin-bottom: 3.25rem;
		transform: translate3d(calc(var(--shift-x) * 0.25), calc(var(--shift-y) * 0.25), 0);
		transition: transform 0.18s ease-out;
	}

	.cluster-panel {
		overflow: hidden;
		border: 1px solid rgba(46, 233, 208, 20%);
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(4, 36, 38, 92%), rgba(5, 54, 52, 88%)),
			#06272a;
		padding: 1.1rem;
		box-shadow: 0 24px 60px rgba(0, 69, 76, 22%);
		text-align: left;
		backdrop-filter: blur(18px);
	}

	.cluster-head,
	.device-top,
	.cluster-stats,
	.log-line {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.cluster-head {
		margin-bottom: 0.85rem;
		color: #dcfffa;
	}

	.cluster-title,
	.live-pill,
	.device-id,
	.lt,
	.lc {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.cluster-title {
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.02em;
	}

	.live-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 999px;
		background: rgba(46, 233, 208, 10%);
		padding: 0.25rem 0.55rem;
		color: #8dfff0;
		font-size: 0.66rem;
		font-weight: 900;
	}

	.live-dot,
	.device-dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: var(--accent);
		box-shadow: 0 0 0 5px rgba(0, 201, 170, 12%);
	}

	.live-dot {
		animation: live-pulse 1.35s ease-in-out infinite;
	}

	.device-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.device-card {
		border: 1px solid rgba(255, 255, 255, 8%);
		border-radius: 8px;
		background: rgba(255, 255, 255, 6%);
		padding: 0.75rem;
		animation: card-breathe 4.8s ease-in-out var(--delay) infinite;
	}

	.device-card.active {
		border-color: rgba(46, 233, 208, 42%);
		background: rgba(46, 233, 208, 12%);
	}

	.device-card.active .device-dot {
		background: #c8fff7;
		box-shadow:
			0 0 0 4px rgba(141, 255, 240, 18%),
			0 0 18px rgba(141, 255, 240, 82%);
	}

	.device-id {
		color: #e8fffb;
		font-size: 0.72rem;
		font-weight: 900;
	}

	.device-status {
		margin-top: 0.5rem;
		color: rgba(232, 255, 251, 70%);
		font-size: 0.74rem;
		font-weight: 800;
	}

	.device-bar {
		overflow: hidden;
		height: 0.28rem;
		margin-top: 0.65rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 10%);
	}

	.device-bar span {
		display: block;
		width: 55%;
		height: 100%;
		border-radius: inherit;
		background: linear-gradient(90deg, var(--accent), #8dfff0);
		animation: bar-fill 3.8s ease-in-out var(--delay) infinite;
	}

	.device-card.active .device-bar span {
		width: 100%;
		background: linear-gradient(90deg, var(--accent), #c8fff7);
		animation: none;
	}

	.log-panel {
		display: grid;
		gap: 0.4rem;
		margin-top: 0.8rem;
	}

	.log-line {
		border: 1px solid rgba(255, 255, 255, 7%);
		border-radius: 6px;
		background: rgba(255, 255, 255, 5%);
		padding: 0.45rem 0.55rem;
		color: rgba(232, 255, 251, 78%);
		font-size: 0.72rem;
		animation: log-glow 4s ease-in-out var(--delay) infinite;
	}

	.ld,
	.la {
		font-weight: 800;
	}

	.lt,
	.lc {
		color: #8dfff0;
		font-weight: 900;
	}

	.cluster-stats {
		margin-top: 0.85rem;
		border-top: 1px solid rgba(255, 255, 255, 8%);
		padding-top: 0.8rem;
		color: rgba(232, 255, 251, 70%);
		font-size: 0.74rem;
		font-weight: 800;
	}

	.cluster-stats strong {
		margin-right: 0.25rem;
		color: white;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 1rem;
	}

	.hero-ticker {
		position: absolute;
		right: 1rem;
		bottom: 1rem;
		left: 1rem;
		z-index: 4;
		overflow: hidden;
		border-top: 1px solid rgba(0, 125, 118, 12%);
		padding-top: 0.75rem;
		color: rgba(6, 39, 42, 58%);
		font-size: 0.74rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		white-space: nowrap;
	}

	.hero-ticker div {
		display: flex;
		width: max-content;
		gap: 2rem;
		animation: ticker-flow 24s linear infinite;
	}

	.framework-section,
	.featured-section,
	main > section {
		margin-bottom: 3rem;
	}

	.framework-section .section-header,
	.featured-section .section-header {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.85fr);
		gap: 1.75rem;
		align-items: end;
		margin-bottom: 1.65rem;
	}

	.framework-section .section-header > div,
	.featured-section .section-header > div {
		min-width: 0;
	}

	.framework-section .section-header h2,
	.featured-section .section-header h2 {
		margin-top: 0.55rem;
		max-width: 760px;
		line-height: 1.15;
	}

	.framework-section .section-header p,
	.featured-section .section-header p {
		justify-self: end;
		max-width: 560px;
		font-size: 0.98rem;
		line-height: 1.8;
	}

	.framework-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.framework-card {
		border: 1px solid var(--line);
		border-top: 3px solid var(--framework-accent);
		border-radius: 8px;
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--framework-accent) 9%, white), white 52%),
			white;
		padding: 1.3rem;
		box-shadow: 0 6px 18px rgba(15, 23, 42, 5%);
		transition:
			border-color 0.22s ease,
			box-shadow 0.22s ease,
			transform 0.22s ease;
	}

	.framework-card[data-tone='ops'] {
		--framework-accent: var(--tone-ops);
	}

	.framework-card[data-tone='platform'] {
		--framework-accent: var(--tone-platform);
	}

	.framework-card[data-tone='product'] {
		--framework-accent: var(--tone-product);
	}

	.framework-card[data-tone='insights'] {
		--framework-accent: var(--tone-insights);
	}

	.framework-card:hover {
		border-color: color-mix(in srgb, var(--framework-accent) 45%, white);
		box-shadow: 0 16px 30px -14px color-mix(in srgb, var(--framework-accent) 28%, transparent);
		transform: translateY(-3px);
	}

	.framework-card h3 {
		font-size: 1rem;
	}

	.framework-card p {
		margin-top: 0.45rem;
		font-size: 0.92rem;
	}

	.latest-section {
		position: relative;
		margin-block: clamp(4.5rem, 7vw, 7rem);
		overflow: hidden;
		border: 1px solid rgba(0, 201, 170, 16%);
		border-radius: 8px;
		background:
			radial-gradient(circle at 12% 10%, rgba(0, 201, 170, 14%), transparent 28rem),
			radial-gradient(circle at 92% 18%, rgba(60, 110, 159, 10%), transparent 24rem),
			linear-gradient(180deg, rgba(255, 255, 255, 72%), rgba(244, 255, 252, 88%));
		padding: clamp(1.5rem, 3vw, 3rem);
		box-shadow: 0 22px 60px rgba(0, 69, 76, 8%);
	}

	.latest-section::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 0;
		background:
			linear-gradient(90deg, rgba(0, 125, 118, 5%) 1px, transparent 1px),
			linear-gradient(180deg, rgba(0, 125, 118, 4%) 1px, transparent 1px);
		background-size: 52px 52px;
		pointer-events: none;
	}

	.latest-section > * {
		position: relative;
		z-index: 1;
	}

	.latest-section .section-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: center;
		margin-bottom: clamp(2rem, 3.6vw, 3.5rem);
		border-bottom: 1px solid rgba(0, 125, 118, 10%);
		padding-bottom: clamp(1rem, 2vw, 1.5rem);
	}

	.latest-section .section-header h2 {
		margin-top: 0.65rem;
		max-width: 540px;
		font-size: clamp(1.7rem, 2.4vw, 2.65rem);
		line-height: 1.12;
	}

	.latest-section .section-header a {
		display: inline-flex;
		align-items: center;
		border: 1px solid rgba(0, 201, 170, 28%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 68%);
		padding: 0.55rem 0.9rem;
		color: var(--accent-dark);
		font-weight: 900;
		text-decoration: none;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.latest-section .section-header a:hover {
		border-color: rgba(0, 201, 170, 60%);
		background: white;
		transform: translateY(-2px);
	}

	.latest-section .post-grid {
		gap: clamp(1.25rem, 2vw, 2rem);
	}

	.latest-section :global(.post-card) {
		min-height: 0;
