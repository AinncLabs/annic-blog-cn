---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const featuredIndex = featuredPost ? posts.findIndex((post) => post.id === featuredPost.id) : 0;
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);
const frameworks = [
	['ops', '运营方法论', '规模化账号运营、团队协作和交付稳定性'],
	['platform', '平台专题', 'TikTok、Instagram、Reddit、X 的执行差异'],
	['product', '产品能力解读', '账号、代理、文件、任务和用量管理'],
	['insights', '出海观察', '本地化、多市场规模化和品牌出海方法'],
];
const topics = ['运营方法论', '平台专题', '产品能力解读', '出海观察', '任务复盘', '操作教程'];
const clusterDevices = [
	{ id: 'DE-001', platform: 'TikTok', task: '队列分发 → TikTok', active: true },
	{ id: 'FR-002', platform: 'Instagram', task: '待机', active: false },
	{ id: 'UK-003', platform: 'Reddit', task: '待机', active: false },
	{ id: 'US-004', platform: 'X', task: '待机', active: false },
	{ id: 'JP-005', platform: 'TikTok', task: '渲染视频 → TikTok', active: true },
	{ id: 'BR-006', platform: 'Instagram', task: '账号互检 → Instagram', active: true },
	{ id: 'ES-007', platform: 'Reddit', task: '待机', active: false },
	{ id: 'IT-008', platform: 'X', task: '待机', active: false },
];
const clusterLogs = [
	['11:02:25', 'IT-008', '同步数据', 'Instagram', '完成'],
	['11:02:27', 'BR-006', '同步数据', 'Instagram', '完成'],
	['11:25:41', 'US-004', '发布图文', 'X', '完成'],
	['11:25:44', 'JP-005', '渲染视频', 'TikTok', '运行中'],
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero" id="home-hero">
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<span class="hero-cursor-glow" aria-hidden="true"></span>
				<div class="hero-copy">
					<span class="section-kicker">麦芽营销团队出品</span>
					<h1>规模化运营社媒账号的实战方法</h1>
					<p>
						写给需要在 TikTok、Instagram、Reddit 和 X
						上管理成百上千个账号的代运营机构、MCN 和出海品牌团队。
					</p>
					<div class="hero-stats" aria-label="博客内容概览">
						<span><strong>{posts.length}</strong>篇文章</span>
						<span><strong>4</strong>个核心栏目</span>
						<span><strong>1</strong>套运营底座</span>
					</div>
				</div>
				<div class="cluster-wrap" aria-label="Ainnc 云端账号集群示意">
					<div class="cluster-panel">
						<div class="cluster-head">
							<span class="cluster-title">云端账号集群 · 实时任务</span>
							<span class="live-pill"><span class="live-dot"></span>RUNNING</span>
						</div>
						<div class="cluster-body">
							<div class="device-grid">
								{
									clusterDevices.map((device, index) => (
										<div
											class:list={['device-card', { active: device.active }]}
											style={`--delay: ${index * 0.16}s`}
											data-device-card
											data-device-id={device.id}
											data-index={index}
										>
											<div class="device-top">
												<span class="device-id">{device.id}</span>
												<span class="device-dot"></span>
											</div>
											<p class="device-status">{device.task}</p>
											<span class="device-trace"></span>
										</div>
									))
								}
							</div>
							<div class="log-panel">
								<div class="log-track" data-log-track>
									{
										clusterLogs.map(([time, device, action, platform, status], index) => (
											<div class="log-line" style={`--delay: ${index * 0.18}s`}>
												<span class="lt">{time}</span>
												<span class="ld">{device}</span>
												<span class="la">{action}</span>
												<span class="lp">{platform}</span>
												<span class="lc">✓ {status}</span>
											</div>
										))
									}
								</div>
							</div>
						</div>
						<div class="cluster-stats">
							<span><strong data-live-count>2,866</strong>本周发布内容</span>
							<span><strong>12</strong>覆盖时区</span>
							<span><strong>99.6%</strong>环境在线率</span>
						</div>
					</div>
				</div>
				<div class="hero-ticker" aria-hidden="true">
					<div class="ticker-track">
						<span class="ticker-icon" data-platform="tiktok">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M14.5 4v10.1a4.3 4.3 0 1 1-3.2-4.2v3.1a1.5 1.5 0 1 0 1 1.4V4h2.2c.3 2.1 1.7 3.8 3.8 4.3v3.1a7 7 0 0 1-3.8-1.3z" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="instagram">
							<svg viewBox="0 0 24 24" focusable="false">
								<rect x="5" y="5" width="14" height="14" rx="4" />
								<circle cx="12" cy="12" r="3.2" />
								<circle cx="16.6" cy="7.4" r="1" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="reddit">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M8 12.2a5.9 5.9 0 0 1 8 0 3.1 3.1 0 0 1 2.3-.8 2.2 2.2 0 0 1 .6 4.2c-.3 3-3.2 5.3-6.9 5.3s-6.6-2.3-6.9-5.3a2.2 2.2 0 0 1 .6-4.2 3.1 3.1 0 0 1 2.3.8z" />
								<path d="M12.7 7.3h3.1l.5-2.2 2.6.6" />
								<circle cx="9.6" cy="15.3" r=".8" />
								<circle cx="14.4" cy="15.3" r=".8" />
								<path d="M10.1 17.4a4.6 4.6 0 0 0 3.8 0" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="x">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M5 5l14 14M19 5 5 19" />
							</svg>
						</span>
						<span>云手机环境</span>
						<span>代理 IP 管理</span>
						<span>素材文件</span>
						<span>任务队列</span>
						<span class="ticker-icon" data-platform="tiktok">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M14.5 4v10.1a4.3 4.3 0 1 1-3.2-4.2v3.1a1.5 1.5 0 1 0 1 1.4V4h2.2c.3 2.1 1.7 3.8 3.8 4.3v3.1a7 7 0 0 1-3.8-1.3z" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="instagram">
							<svg viewBox="0 0 24 24" focusable="false">
								<rect x="5" y="5" width="14" height="14" rx="4" />
								<circle cx="12" cy="12" r="3.2" />
								<circle cx="16.6" cy="7.4" r="1" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="reddit">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M8 12.2a5.9 5.9 0 0 1 8 0 3.1 3.1 0 0 1 2.3-.8 2.2 2.2 0 0 1 .6 4.2c-.3 3-3.2 5.3-6.9 5.3s-6.6-2.3-6.9-5.3a2.2 2.2 0 0 1 .6-4.2 3.1 3.1 0 0 1 2.3.8z" />
								<path d="M12.7 7.3h3.1l.5-2.2 2.6.6" />
								<circle cx="9.6" cy="15.3" r=".8" />
								<circle cx="14.4" cy="15.3" r=".8" />
								<path d="M10.1 17.4a4.6 4.6 0 0 0 3.8 0" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="x">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M5 5l14 14M19 5 5 19" />
							</svg>
						</span>
						<span>云手机环境</span>
						<span>代理 IP 管理</span>
						<span>素材文件</span>
						<span>任务队列</span>
					</div>
				</div>
			</section>

			<section class="framework-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">内容框架</span>
						<h2>从运营问题进入产品能力</h2>
					</div>
					<p>给新读者快速建立对 Ainnc 产品能力和博客内容方向的理解。</p>
				</div>
				<div class="framework-grid">
					{
						frameworks.map(([tone, title, description]) => (
							<article class="framework-card" data-tone={tone}>
								<h3>{title}</h3>
								<p>{description}</p>
							</article>
						))
					}
				</div>
			</section>

			{
				featuredPost && (
					<section class="featured-section">
						<div class="section-header">
							<div>
								<span class="eyebrow">推荐阅读</span>
								<h2>先从这篇开始</h2>
							</div>
							<p>建立对规模化社媒运营、账号矩阵和 Ainnc 工作流的第一层理解。</p>
						</div>
						<PostCard post={featuredPost} featured index={featuredIndex} />
					</section>
				)
			}

			<section class="latest-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">最新文章</span>
						<h2>持续更新的运营指南</h2>
					</div>
					<a href="/blog/">全部文章</a>
				</div>
				<div class="post-grid">
					{latestPosts.map((post) => <PostCard post={post} index={posts.findIndex((item) => item.id === post.id)} />)}
				</div>
			</section>

			<section class="topics panel">
				<div>
					<span class="eyebrow">栏目规划</span>
					<h2>围绕这些主题持续更新</h2>
				</div>
				<ul>
					{topics.map((topic) => <li>{topic}</li>)}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			const hero = document.getElementById('home-hero');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (hero && supportsHover) {
				hero.addEventListener('pointermove', (event) => {
					const rect = hero.getBoundingClientRect();
					const shiftX = ((event.clientX - rect.left) / rect.width - 0.5) * 22;
					const shiftY = ((event.clientY - rect.top) / rect.height - 0.5) * 18;
					hero.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
					hero.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
					hero.style.setProperty('--shift-x', `${shiftX}px`);
					hero.style.setProperty('--shift-y', `${shiftY}px`);
					hero.classList.add('is-glowing');
				});
				hero.addEventListener('pointerleave', () => {
					hero.classList.remove('is-glowing');
					hero.style.setProperty('--shift-x', '0px');
					hero.style.setProperty('--shift-y', '0px');
				});
			}

			const liveTasks = [
				['UK-003', '素材同步', 'Reddit', '运行中'],
				['US-004', '同步数据', 'X', '完成'],
				['JP-005', '渲染视频', 'TikTok', '运行中'],
				['BR-006', '账号互检', 'Instagram', '完成'],
				['DE-001', '队列分发', 'TikTok', '完成'],
				['ES-007', '评论巡检', 'Reddit', '运行中'],
				['FR-002', '素材入库', 'Instagram', '完成'],
				['IT-008', '同步数据', 'X', '完成'],
			];
			const taskCards = Array.from(document.querySelectorAll<HTMLElement>('[data-device-card]'));
			const logTrack = document.querySelector<HTMLElement>('[data-log-track]');
			const liveCount = document.querySelector<HTMLElement>('[data-live-count]');
			let liveTaskIndex = 0;
			let publishedCount = 2866;
			const activeDevices = new Set(['DE-001', 'JP-005', 'BR-006']);
			const taskLabels = new Map(liveTasks.map(([device, action, platform]) => [device, `${action} → ${platform}`]));
			const progressTimers = new Map<HTMLElement, number>();

			const startCardProgress = (card: HTMLElement) => {
				const currentTimer = progressTimers.get(card);
				if (currentTimer) {
					window.clearTimeout(currentTimer);
				}
				card.classList.remove('is-complete');
				card.classList.add('is-running');
				const timer = window.setTimeout(() => {
					card.classList.remove('is-running');
					if (card.classList.contains('active')) {
						card.classList.add('is-complete');
					}
					progressTimers.delete(card);
				}, 1700);
				progressTimers.set(card, timer);
			};

			const formatTime = () => new Date().toLocaleTimeString('zh-CN', { hour12: false });
			const updateLiveTasks = () => {
				const [device, action, platform, status] = liveTasks[liveTaskIndex % liveTasks.length];
				liveTaskIndex += 1;
				taskCards.forEach((card) => {
					const id = card.dataset.deviceId ?? '';
					const statusNode = card.querySelector<HTMLElement>('.device-status');
					const isActive = activeDevices.has(id);
					const wasActive = card.classList.contains('active');
					card.classList.toggle('active', isActive);
					if (isActive && !wasActive) {
						startCardProgress(card);
					}
					if (!isActive) {
						const currentTimer = progressTimers.get(card);
						if (currentTimer) {
							window.clearTimeout(currentTimer);
							progressTimers.delete(card);
						}
						card.classList.remove('is-running', 'is-complete');
					}
					if (statusNode) {
						statusNode.textContent = isActive ? taskLabels.get(id) ?? '任务处理中' : '待机';
					}
				});

				if (logTrack) {
					const template = logTrack.querySelector<HTMLElement>('.log-line');
					const row = template ? (template.cloneNode(true) as HTMLElement) : document.createElement('div');
					row.className = 'log-line';
					if (template) {
						const cells = row.querySelectorAll('span');
						const values = [formatTime(), device, action, platform, `✓ ${status}`];
						cells.forEach((cell, index) => {
							cell.textContent = values[index] ?? '';
						});
					} else {
						row.innerHTML = `<span class="lt">${formatTime()}</span><span class="ld">${device}</span><span class="la">${action}</span><span class="lp">${platform}</span><span class="lc">✓ ${status}</span>`;
					}
					logTrack.appendChild(row);
					if (logTrack.children.length > 4) {
						const first = logTrack.firstElementChild as HTMLElement | null;
						if (first) {
							const gap = parseFloat(window.getComputedStyle(logTrack).rowGap || '0');
							const shift = first.getBoundingClientRect().height + gap;
							logTrack.style.setProperty('--log-shift', `${shift}px`);
							logTrack.classList.add('is-shifting');
							window.setTimeout(() => {
								first.remove();
								logTrack.classList.remove('is-shifting');
								logTrack.style.removeProperty('--log-shift');
							}, 680);
						}
					}
				}

				if (liveCount) {
					publishedCount += 1;
					liveCount.textContent = publishedCount.toLocaleString('en-US');
				}
			};

			taskCards.forEach((card) => {
				if (card.classList.contains('active')) {
					startCardProgress(card);
				}
			});
			window.setInterval(updateLiveTasks, 1850);

			document.querySelectorAll<HTMLElement>('.ticker-track').forEach((track) => {
				requestAnimationFrame(() => {
					const loopDistance = track.scrollWidth / 2;
					track.style.setProperty('--ticker-distance', `${loopDistance}px`);
					const items = Array.from(track.children);
					items.forEach((item) => track.appendChild(item.cloneNode(true)));
				});
			});
		</script>
	</body>
</html>

<style>
	.home-hero {
		--glow-x: 50%;
		--glow-y: 50%;
		--shift-x: 0px;
		--shift-y: 0px;
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 760px;
		align-content: center;
		justify-items: center;
		overflow: hidden;
		margin-bottom: 4rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 76%) 0, rgba(255, 255, 255, 38%) 45%, rgba(255, 255, 255, 76%) 100%),
			linear-gradient(135deg, rgba(0, 201, 170, 16%), rgba(60, 110, 159, 8%) 48%, rgba(0, 69, 76, 5%)),
			white;
		box-shadow: 0 24px 70px rgba(0, 69, 76, 12%);
		text-align: center;
	}

	.home-hero::before {
		content: '';
		position: absolute;
		inset: 1rem;
		z-index: 0;
		border: 1px solid rgba(0, 201, 170, 16%);
		border-radius: 8px;
		pointer-events: none;
	}

	.hero-watermark {
		position: absolute;
		top: -7rem;
		right: -5rem;
		z-index: 0;
		width: min(50rem, 58vw);
		opacity: 0.07;
		filter: grayscale(1) brightness(0.45);
		transform: translate3d(var(--shift-x), var(--shift-y), 0) rotate(-7deg);
		transition: transform 0.18s ease-out;
	}

	.hero-cursor-glow {
		position: absolute;
		z-index: 1;
		inset: -14%;
		background: radial-gradient(circle 280px at var(--glow-x) var(--glow-y), rgba(46, 233, 208, 30%), rgba(0, 201, 170, 12%) 34%, transparent 72%);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.home-hero.is-glowing .hero-cursor-glow {
		opacity: 1;
	}

	.hero-copy {
		position: relative;
		z-index: 3;
		display: grid;
		max-width: 720px;
		gap: 1rem;
		padding: clamp(2rem, 5vw, 4rem) 1rem 1.25rem;
		justify-items: center;
	}

	.hero-ticker span {
		display: inline-flex;
		align-items: center;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.hero-ticker .ticker-icon {
		justify-content: center;
		width: 1.72rem;
		height: 1.72rem;
		border: 1px solid rgba(0, 201, 170, 20%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 62%);
		color: rgba(0, 125, 118, 76%);
		box-shadow: 0 8px 18px rgba(0, 125, 118, 8%);
	}

	.ticker-icon svg {
		width: 1rem;
		height: 1rem;
	}

	.ticker-icon svg :where(path, rect, circle) {
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.ticker-icon[data-platform='tiktok'] svg path {
		fill: currentColor;
		stroke: none;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.hero-copy p {
		max-width: 620px;
		font-size: 1.08rem;
	}

	.hero-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.hero-stats {
		margin-top: 0.25rem;
		color: var(--muted);
		font-weight: 800;
	}

	.hero-stats span {
		border: 1px solid rgba(0, 201, 170, 28%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 72%);
		padding: 0.45rem 0.8rem;
	}

	.hero-stats strong {
		margin-right: 0.2rem;
		color: var(--text);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.cluster-wrap {
		position: relative;
		z-index: 4;
		isolation: isolate;
		width: min(960px, calc(100% - 2rem));
		margin-bottom: 3.25rem;
		transform: translate3d(calc(var(--shift-x) * 0.25), calc(var(--shift-y) * 0.25), 0);
		transition: transform 0.18s ease-out;
	}

	.cluster-wrap::before,
	.cluster-wrap::after {
		content: '';
		position: absolute;
		z-index: 0;
		width: 46%;
		aspect-ratio: 1;
		border-radius: 50%;
		filter: blur(58px);
		opacity: 0.72;
		pointer-events: none;
		will-change: transform;
	}

	.cluster-wrap::before {
		top: -8%;
		left: 3%;
		background: radial-gradient(circle, rgba(37, 230, 214, 78%) 0%, rgba(22, 188, 198, 38%) 38%, transparent 72%);
		animation: glass-orb-cyan 16s ease-in-out infinite alternate;
	}

	.cluster-wrap::after {
		right: 2%;
		bottom: -12%;
