	.device-card {
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(205, 220, 226, 18%);
		border-radius: 8px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 10%), rgba(215, 228, 235, 4%));
		padding: 0.75rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 18%),
			inset 0 -1px 0 rgba(0, 0, 0, 16%),
			0 10px 24px rgba(0, 8, 18, 20%);
		-webkit-backdrop-filter: blur(14px) saturate(112%);
		backdrop-filter: blur(14px) saturate(112%);
		transition:
			border-color 0.35s ease,
			background 0.35s ease,
			box-shadow 0.35s ease,
			transform 0.35s ease;
	}

	.device-card::before {
		content: '';
		position: absolute;
		top: 0;
		right: 8%;
		left: 8%;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 58%), transparent);
		opacity: 0.58;
		pointer-events: none;
	}

	.device-card.active {
		border-color: rgba(39, 219, 194, 0.55);
		background: linear-gradient(165deg, #12383a, #0f2e2c);
		box-shadow:
			inset 0 1px 0 rgba(225, 255, 250, 32%),
			inset 0 0 30px rgba(39, 219, 194, 0.06),
			0 0 24px -6px rgba(39, 219, 194, 0.35),
			0 16px 32px rgba(1, 7, 22, 32%);
		-webkit-backdrop-filter: blur(22px) saturate(150%);
		backdrop-filter: blur(22px) saturate(150%);
		transform: translateY(-1px);
	}

	.device-card.active::before {
		opacity: 1;
		background: linear-gradient(90deg, transparent, rgba(205, 255, 248, 78%), transparent);
	}

	.device-card.active .device-dot {
		background: #27dbc2;
		box-shadow:
			0 0 0 5px rgba(39, 219, 194, 18%),
			0 0 20px rgba(39, 219, 194, 78%);
		transform: scale(1.12);
		animation: node-glow 1.6s ease-in-out infinite;
	}

	.device-id {
		color: #e8fffb;
		font-size: 0.72rem;
		font-weight: 900;
	}

	.device-status {
		margin-top: 0.5rem;
		color: rgba(232, 255, 251, 70%);
		font-size: 0.74rem;
		font-weight: 800;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.device-card.active .device-id {
		color: #f4fffd;
		text-shadow: 0 0 14px rgba(39, 219, 194, 18%);
	}

	.device-card.active .device-status {
		color: #cfede7;
	}

	.device-card.active .device-platform {
		color: #27dbc2;
		font-weight: 900;
	}

	.device-trace {
		display: block;
		overflow: hidden;
		width: 100%;
		height: 0.18rem;
		margin-top: 0.65rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 8%);
	}

	.device-trace::before {
		content: '';
		display: block;
		width: 100%;
		height: 100%;
		border-radius: inherit;
		background: linear-gradient(90deg, #00a6a4, #27dbc2);
		opacity: 0;
		transform-origin: left center;
		transform: scaleX(0);
		box-shadow: 0 0 0 rgba(39, 219, 194, 0%);
		transition: opacity 0.28s ease;
	}

	.device-card.active .device-trace::before {
		opacity: 1;
	}

	.device-card.is-running .device-trace::before {
		animation: trace-fill 1.7s cubic-bezier(0.2, 0.72, 0.16, 1) forwards;
	}

	.device-card.is-complete .device-trace::before {
		transform: scaleX(1);
		opacity: 1;
		box-shadow: 0 0 18px rgba(39, 219, 194, 60%);
	}

	.log-panel {
		overflow: hidden;
