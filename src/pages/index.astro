---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getPostCode } from '../blogVisuals';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);
const topicCounts = posts.reduce<Record<string, number>>((counts, post) => {
	counts[post.data.category] = (counts[post.data.category] ?? 0) + 1;
	return counts;
}, {});
const categoryCount = Object.keys(topicCounts).length;
const allTrackDefinitions = [
	['运营方法论', '规模化账号运营、团队协作与交付稳定性'],
	['产品能力解读', '账号、代理、素材、任务和用量管理'],
	['平台专题', 'TikTok、Instagram、Reddit、X 的执行差异'],
	['出海观察', '本地化、多市场扩张与全球品牌运营'],
	['数据与增长', '从内容信号到实验、停止条件和业务结果'],
	['内容策略', '选题、表达、传播与可持续内容组合'],
	['团队协作', '交接、复盘、协同与团队判断'],
	['商业与交付', '定价、合同、客户边界与续约'],
	['操作教程', '账号、设备和代理等实际配置步骤'],
	['运营实践', '素材、任务与日常执行方法'],
	['产品更新', 'Ainnc 功能与内容中心进展'],
] as const;
const trackDefinitions = allTrackDefinitions.slice(0, 6);
const tracks = trackDefinitions.map(([label, description], index) => ({
	code: `TRK-${String(index + 1).padStart(2, '0')}`,
	label,
	description,
	count: topicCounts[label] ?? 0,
}));
const featuredTrackLabels = new Set(trackDefinitions.map(([label]) => label));
const trackOrder = new Map(allTrackDefinitions.map(([label], index) => [label, index]));
const remainingTrackLabels = Object.keys(topicCounts)
	.filter((label) => !featuredTrackLabels.has(label))
	.sort((first, second) => (trackOrder.get(first) ?? 99) - (trackOrder.get(second) ?? 99));
const categorySequence: Record<string, number> = {};
const postCodes = new Map(
	posts.map((post) => {
		const index = categorySequence[post.data.category] ?? 0;
		categorySequence[post.data.category] = index + 1;
		return [post.id, getPostCode(post.data.category, index)];
	}),
);
const formatConsoleDate = (date: Date) => date.toISOString().slice(0, 10).replaceAll('-', '.');
const featuredTitle = featuredPost?.data.title ?? '';
const featuredAccent = featuredTitle.endsWith('而不失控') ? '而不失控' : '';
const featuredTitleLead = featuredAccent ? featuredTitle.slice(0, -featuredAccent.length) : featuredTitle;
const tickerItems = ['账号矩阵', '素材管理', '任务中心', '出海社媒运营', 'CLOUD PHONE', 'PROXY IP', 'ASSET FILES', 'TASK QUEUE'];
const clusterDevices = [
	{ id: 'DE-001', platform: 'TikTok', task: '队列分发', active: true },
	{ id: 'FR-002', platform: 'Instagram', task: '待机', active: false },
	{ id: 'UK-003', platform: 'Reddit', task: '待机', active: false },
	{ id: 'US-004', platform: 'X', task: '待机', active: false },
	{ id: 'JP-005', platform: 'TikTok', task: '渲染视频', active: true },
	{ id: 'BR-006', platform: 'Instagram', task: '账号互检', active: true },
	{ id: 'ES-007', platform: 'Reddit', task: '待机', active: false },
	{ id: 'IT-008', platform: 'X', task: '待机', active: false },
];
const clusterLogs = [
	['11:02:25', 'IT-008', '同步数据', 'Instagram', '完成'],
	['11:02:27', 'BR-006', '同步数据', 'Instagram', '完成'],
	['11:25:41', 'US-004', '发布图文', 'X', '完成'],
	['11:25:44', 'JP-005', '渲染视频', 'TikTok', '运行中'],
];
---

<!doctype html>
<html lang="zh-CN" class="home-page-root">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="home-page">
		<Header />
		<main>
			<section class="home-hero" id="home-hero">
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<span class="hero-cursor-glow" aria-hidden="true"></span>
				<div class="hero-copy">
					<span class="section-kicker">麦芽营销团队出品</span>
					<svg class="hero-connect-art" viewBox="0 0 140 140" aria-hidden="true">
						<path d="M70 70C48 58 41 37 28 25" fill="none" stroke="#00B1B3" stroke-width="1.6" />
						<path d="M70 70C91 77 105 96 116 116" fill="none" stroke="#0891B2" stroke-width="1.35" />
						<circle cx="70" cy="70" r="6" fill="#00B1B3" />
						<circle cx="28" cy="25" r="4.5" fill="#9FE1CB" />
						<circle cx="116" cy="116" r="5" fill="#5DCAA5" />
					</svg>
					<h1>规模化运营<span class="hero-title-accent">社媒账号</span>的实战方法</h1>
					<p>
						写给需要在 TikTok、Instagram、Reddit 和 X
						上管理成百上千个账号的代运营机构、MCN 和出海品牌团队。
					</p>
					<div class="hero-stats" aria-label="博客内容概览">
						<span><strong>{posts.length}</strong>篇文章</span>
						<span><strong>{categoryCount}</strong>个主题栏目</span>
						<span><strong>1</strong>套运营底座</span>
					</div>
				</div>
				<div class="cluster-wrap" aria-label="Ainnc 云端账号集群示意">
					<div class="cluster-panel">
						<div class="cluster-head">
							<span class="cluster-title">云端账号集群 · 实时任务</span>
							<span class="live-pill"><span class="live-dot"></span>RUNNING</span>
						</div>
						<div class="cluster-body">
							<div class="device-grid">
								{
									clusterDevices.map((device, index) => (
										<div
											class:list={['device-card', { active: device.active }]}
											style={`--delay: ${index * 0.16}s`}
											data-device-card
											data-device-id={device.id}
											data-index={index}
										>
											<div class="device-top">
												<span class="device-id">{device.id}</span>
												<span class="device-dot"></span>
											</div>
											<p class="device-status">
												<span class="device-action">{device.task}</span>
												<span class="device-route" hidden={!device.active}>
													 → <strong class="device-platform">{device.platform}</strong>
												</span>
											</p>
											<span class="device-trace"></span>
										</div>
									))
								}
							</div>
							<div class="log-panel">
								<div class="log-track" data-log-track>
									{
										clusterLogs.map(([time, device, action, platform, status], index) => (
											<div class="log-line" style={`--delay: ${index * 0.18}s`}>
												<span class="lt">{time}</span>
												<span class="ld">{device}</span>
												<span class="la">{action}</span>
												<span class="lp">{platform}</span>
												<span class="lc">✓ {status}</span>
											</div>
										))
									}
								</div>
							</div>
						</div>
						<div class="cluster-stats">
							<span><strong data-live-count>2,866</strong>本周发布内容</span>
							<span><strong>12</strong>覆盖时区</span>
							<span><strong>99.6%</strong>环境在线率</span>
						</div>
					</div>
				</div>
			</section>

			<div class="content-console">
				<div class="console-wrap">
					<section class="content-statusbar" aria-label="Ainnc 内容中心状态">
						<div class="content-brandmark">
							<img src="/ainnc-logo-icon.webp" width="26" height="26" alt="" aria-hidden="true" />
							<strong>Ainnc · 内容中心</strong>
						</div>
						<div class="content-status-data">
							<span class="content-live"><i aria-hidden="true"></i>持续更新中</span>
							<span>栏目 {String(categoryCount).padStart(2, '0')}</span>
							<span>文章 {String(posts.length).padStart(2, '0')}</span>
							<time data-utc-clock datetime="">UTC --:--:--</time>
						</div>
					</section>

					{
						featuredPost && (
							<section class="content-headline" aria-labelledby="content-headline-title">
								<div class="content-headline-kicker">
									<span class="content-post-id">{postCodes.get(featuredPost.id)}</span>
									<span>{featuredPost.data.category}</span>
									<time datetime={featuredPost.data.pubDate.toISOString()}>{formatConsoleDate(featuredPost.data.pubDate)}</time>
									<span class="content-recommended">● 推荐首读</span>
								</div>
								<h2 id="content-headline-title">
									{featuredTitleLead}{featuredAccent && <>，<span class="content-headline-glow">{featuredAccent}</span></>}
								</h2>
								<div class="content-headline-sub">
									<p>{featuredPost.data.description}</p>
									<a class="content-primary-cta" href={`/blog/${featuredPost.id}/`}>
										<span>阅读全文</span>
										<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
									</a>
								</div>
							</section>
						)
					}

					<section class="content-latest" aria-labelledby="content-latest-title">
						<div class="content-section-head">
							<h2 id="content-latest-title">LATEST — 最新文章</h2>
							<a href="/blog/">全部文章 →</a>
						</div>
						<div class="content-latest-grid">
							{
								latestPosts.map((post) => (
									<a class="content-latest-pane" href={`/blog/${post.id}/`}>
										<span class="content-latest-meta">
											<strong>{postCodes.get(post.id)}</strong>
											<span>{post.data.category}</span>
											<time datetime={post.data.pubDate.toISOString()}>{formatConsoleDate(post.data.pubDate)}</time>
										</span>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
										<span class="content-read-link">
											READ
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
										</span>
									</a>
								))
							}
						</div>
					</section>

					<section class="content-tracks" aria-labelledby="content-tracks-title">
						<div class="content-tracks-head">
							<h2 id="content-tracks-title">TRACKS — 栏目入口</h2>
							<span>精选 {String(tracks.length).padStart(2, '0')} / 全部 {String(categoryCount).padStart(2, '0')}</span>
						</div>
						<div class="content-track-list">
							{
								tracks.map((track) => (
									<a class="content-track-row" href={`/blog/?category=${encodeURIComponent(track.label)}`}>
										<span class="content-track-code">{track.code}</span>
										<span class="content-track-name">
											<strong>{track.label}</strong>
											<small>{track.description}</small>
										</span>
										<span class="content-track-count">{String(track.count).padStart(2, '0')} 篇</span>
										<span class="content-track-arrow">
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
										</span>
									</a>
								))
							}
							<a class="content-track-row content-track-more" href="/blog/#blog-categories">
								<span class="content-track-code">TRK-07+</span>
								<span class="content-track-name">
									<strong>查看全部栏目</strong>
									<small>另有 {remainingTrackLabels.length} 个：{remainingTrackLabels.join(' · ')}</small>
								</span>
								<span class="content-track-count">共 {String(categoryCount).padStart(2, '0')} 栏</span>
								<span class="content-track-arrow">
									<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
								</span>
							</a>
						</div>
					</section>
				</div>

				<div class="content-ticker" aria-hidden="true">
					<div class="content-ticker-track">
						{[...tickerItems, ...tickerItems].map((item) => <span><i>✦</i>{item}</span>)}
					</div>
				</div>
				<div class="content-console-pad" aria-hidden="true"></div>
			</div>
		</main>
		<Footer />
		<script>
			const hero = document.getElementById('home-hero');
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches && !prefersReducedMotion;

			if (hero && supportsHover) {
				hero.addEventListener('pointermove', (event) => {
					const rect = hero.getBoundingClientRect();
					const shiftX = ((event.clientX - rect.left) / rect.width - 0.5) * 22;
					const shiftY = ((event.clientY - rect.top) / rect.height - 0.5) * 18;
					hero.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
					hero.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
					hero.style.setProperty('--shift-x', `${shiftX}px`);
					hero.style.setProperty('--shift-y', `${shiftY}px`);
					hero.classList.add('is-glowing');
				});
				hero.addEventListener('pointerleave', () => {
					hero.classList.remove('is-glowing');
					hero.style.setProperty('--shift-x', '0px');
					hero.style.setProperty('--shift-y', '0px');
				});
			}

			const liveTasks = [
				['UK-003', '素材同步', 'Reddit', '运行中'],
				['US-004', '同步数据', 'X', '完成'],
				['JP-005', '渲染视频', 'TikTok', '运行中'],
				['BR-006', '账号互检', 'Instagram', '完成'],
				['DE-001', '队列分发', 'TikTok', '完成'],
				['ES-007', '评论巡检', 'Reddit', '运行中'],
				['FR-002', '素材入库', 'Instagram', '完成'],
				['IT-008', '同步数据', 'X', '完成'],
			];
			const taskCards = Array.from(document.querySelectorAll<HTMLElement>('[data-device-card]'));
			const logTrack = document.querySelector<HTMLElement>('[data-log-track]');
			const liveCount = document.querySelector<HTMLElement>('[data-live-count]');
			let publishedCount = 2866;
			const activeDevices = new Set(['DE-001', 'JP-005', 'BR-006']);
			const taskDetails = new Map(liveTasks.map(([device, action, platform, status]) => [device, [action, platform, status]]));
			const deviceIds = taskCards.map((card) => card.dataset.deviceId ?? '').filter(Boolean);
			const progressTimers = new Map<HTMLElement, number>();

			const startCardProgress = (card: HTMLElement) => {
				const currentTimer = progressTimers.get(card);
				if (currentTimer) {
					window.clearTimeout(currentTimer);
				}
				card.classList.remove('is-complete');
				card.classList.add('is-running');
				const timer = window.setTimeout(() => {
					card.classList.remove('is-running');
					if (card.classList.contains('active')) {
						card.classList.add('is-complete');
					}
					progressTimers.delete(card);
				}, 1700);
				progressTimers.set(card, timer);
			};

			const formatTime = () => new Date().toLocaleTimeString('zh-CN', { hour12: false });
			const updateLiveTasks = () => {
				const inactiveDevices = deviceIds.filter((id) => !activeDevices.has(id));
				const runningDevices = Array.from(activeDevices);
				const device = inactiveDevices[Math.floor(Math.random() * inactiveDevices.length)] ?? deviceIds[0];
				const deviceToPause = runningDevices[Math.floor(Math.random() * runningDevices.length)];
				if (deviceToPause) activeDevices.delete(deviceToPause);
				activeDevices.add(device);
				const [action = '任务处理', platform = 'TikTok', status = '运行中'] = taskDetails.get(device) ?? [];
				taskCards.forEach((card) => {
					const id = card.dataset.deviceId ?? '';
					const statusNode = card.querySelector<HTMLElement>('.device-status');
					const actionNode = statusNode?.querySelector<HTMLElement>('.device-action');
					const routeNode = statusNode?.querySelector<HTMLElement>('.device-route');
					const platformNode = statusNode?.querySelector<HTMLElement>('.device-platform');
					const isActive = activeDevices.has(id);
					const wasActive = card.classList.contains('active');
					card.classList.toggle('active', isActive);
					if (isActive && !wasActive) {
						startCardProgress(card);
					}
					if (!isActive) {
						const currentTimer = progressTimers.get(card);
						if (currentTimer) {
							window.clearTimeout(currentTimer);
							progressTimers.delete(card);
						}
						card.classList.remove('is-running', 'is-complete');
					}
					if (actionNode) {
						const [cardAction = '任务处理中', cardPlatform = 'TikTok'] = taskDetails.get(id) ?? [];
						actionNode.textContent = isActive ? cardAction : '待机';
						if (platformNode) platformNode.textContent = cardPlatform;
						if (routeNode) routeNode.hidden = !isActive;
					}
				});

				if (logTrack) {
					const template = logTrack.querySelector<HTMLElement>('.log-line');
					const row = template ? (template.cloneNode(true) as HTMLElement) : document.createElement('div');
					row.className = 'log-line';
					if (template) {
						const cells = row.querySelectorAll('span');
						const values = [formatTime(), device, action, platform, `✓ ${status}`];
						cells.forEach((cell, index) => {
							cell.textContent = values[index] ?? '';
						});
					} else {
						row.innerHTML = `<span class="lt">${formatTime()}</span><span class="ld">${device}</span><span class="la">${action}</span><span class="lp">${platform}</span><span class="lc">✓ ${status}</span>`;
					}
					logTrack.appendChild(row);
					if (logTrack.children.length > 4) {
						const first = logTrack.firstElementChild as HTMLElement | null;
						if (first) {
							const gap = parseFloat(window.getComputedStyle(logTrack).rowGap || '0');
							const shift = first.getBoundingClientRect().height + gap;
							logTrack.style.setProperty('--log-shift', `${shift}px`);
							logTrack.classList.add('is-shifting');
							window.setTimeout(() => {
								first.remove();
								logTrack.classList.remove('is-shifting');
								logTrack.style.removeProperty('--log-shift');
							}, 680);
						}
					}
				}

				if (liveCount) {
					publishedCount += 1;
					liveCount.textContent = publishedCount.toLocaleString('en-US');
				}
			};

			let liveUpdateTimer: number | undefined;
			const scheduleLiveUpdate = () => {
				liveUpdateTimer = window.setTimeout(() => {
					updateLiveTasks();
					scheduleLiveUpdate();
				}, 1800 + Math.random() * 1400);
			};
			if (!prefersReducedMotion) {
				taskCards.forEach((card) => {
					if (card.classList.contains('active')) {
						startCardProgress(card);
					}
				});
				scheduleLiveUpdate();
			}

			const utcClock = document.querySelector<HTMLTimeElement>('[data-utc-clock]');
			const updateUtcClock = () => {
				if (!utcClock) return;
				const now = new Date();
				const pad = (value: number) => String(value).padStart(2, '0');
				utcClock.textContent = `UTC ${pad(now.getUTCHours())}:${pad(now.getUTCMinutes())}:${pad(now.getUTCSeconds())}`;
				utcClock.dateTime = now.toISOString();
			};
			updateUtcClock();
			const utcClockTimer = window.setInterval(updateUtcClock, 1000);
			const cleanupHomeTimers = () => {
				window.clearInterval(utcClockTimer);
				if (liveUpdateTimer) window.clearTimeout(liveUpdateTimer);
				progressTimers.forEach((timer) => window.clearTimeout(timer));
				progressTimers.clear();
			};
			window.addEventListener('pagehide', cleanupHomeTimers, { once: true });
			document.addEventListener('astro:before-swap', cleanupHomeTimers, { once: true });

		</script>
	</body>
</html>

<style>
	:global(html.home-page-root),
	:global(body.home-page) {
		overflow-x: clip;
	}

	:global(body.home-page) {
		background:
			radial-gradient(1000px 520px at 88% -12%, color-mix(in srgb, var(--brand) 18%, transparent), transparent 65%),
			radial-gradient(760px 460px at -12% 55%, color-mix(in srgb, var(--brand-mid) 10%, transparent), transparent 62%),
			linear-gradient(color-mix(in srgb, var(--brand-deep) 3.5%, transparent) 1px, transparent 1px),
			linear-gradient(90deg, color-mix(in srgb, var(--brand-deep) 3.5%, transparent) 1px, transparent 1px),
			var(--bg);
		background-attachment: fixed;
		background-position: center top;
		background-size: auto, auto, 44px 44px, 44px 44px, auto;
	}

	:global(body.home-page main) {
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0;
	}

	.home-hero {
		--glow-x: 50%;
		--glow-y: 50%;
		--shift-x: 0px;
		--shift-y: 0px;
		position: relative;
		isolation: isolate;
		display: grid;
		box-sizing: border-box;
		width: 100vw;
		min-height: 760px;
		align-content: center;
		justify-items: center;
		overflow: hidden;
		margin-inline: calc(50% - 50vw);
		margin-bottom: 0;
		padding-inline: clamp(1rem, 3vw, 2rem);
		text-align: center;
	}

	.hero-watermark {
		position: absolute;
		top: -7rem;
		right: -5rem;
		z-index: 0;
		width: min(50rem, 58vw);
		opacity: 0.07;
		filter: grayscale(1) brightness(0.45);
		transform: translate3d(var(--shift-x), var(--shift-y), 0) rotate(-7deg);
		transition: transform 0.18s ease-out;
	}

	.hero-cursor-glow {
		position: absolute;
		z-index: 1;
		inset: -14%;
		background: radial-gradient(circle 280px at var(--glow-x) var(--glow-y), rgba(46, 233, 208, 30%), rgba(0, 201, 170, 12%) 34%, transparent 72%);
