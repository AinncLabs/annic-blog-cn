		-webkit-backdrop-filter: blur(26px) saturate(145%);
		backdrop-filter: blur(26px) saturate(145%);
	}

	.cluster-body {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.78rem;
		align-items: stretch;
	}

	.cluster-head,
