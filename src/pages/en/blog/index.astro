---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPostCode } from '../../../blogVisuals';
import { getPostMeta, SITE_COPY } from '../../../i18n';

const postOrder = [
	'scaling-social-account-operations',
	'spreadsheets-break-50',
	'real-social-ops-platform',
	'task-center',
	'mcn-prove-value-with-data',
	'cloud-phone-vs-browser',
	'proxy-ip-types',
	'one-workflow-five-tools',
	'tiktok-risk-guide',
	'global-brand-scale',
	'localization-how-deep',
];
const posts = (await getCollection('blog', (entry) => !entry.data.draft && postOrder.includes(entry.id))).sort((a, b) => {
	const aOrder = postOrder.indexOf(a.id);
	const bOrder = postOrder.indexOf(b.id);
	return (aOrder === -1 ? 999 : aOrder) - (bOrder === -1 ? 999 : bOrder);
});
const featuredPost = posts[0];
const featuredMeta = featuredPost ? getPostMeta(featuredPost, 'en') : undefined;
const gridPosts = posts.slice(1);
const spanMap: Record<string, 'wide' | 'tall' | 'none'> = {
	'spreadsheets-break-50': 'tall',
	'real-social-ops-platform': 'wide',
	'tiktok-risk-guide': 'wide',
};
const englishCategoryCounters: Record<string, number> = featuredMeta ? { [featuredMeta.category]: 1 } : {};
const nextEnglishCategoryIndex = (category: string) => {
	const value = englishCategoryCounters[category] ?? 0;
	englishCategoryCounters[category] = value + 1;
	return value;
};
const categoryOrder = [
	'Operations Playbook',
	'Platform Guides',
	'Product Capabilities',
	'Global Growth',
	'Tutorials',
	'Operations',
	'Product Updates',
];
const allCategoryLabels = new Set([
	...posts.map((post) => getPostMeta(post, 'en').category),
]);
const categories = [
	'All Articles',
	...categoryOrder.filter((category) => allCategoryLabels.has(category)),
	...Array.from(allCategoryLabels).filter((category) => !categoryOrder.includes(category)),
];
const featuredCode = featuredPost && featuredMeta ? getPostCode(featuredMeta.category, 0) : 'OPS-01';
const heroLogRows = [
	['12:02:35', 'TT-05', 'sync data', 'TikTok', 'done'],
	['12:02:35', 'IG-06', 'render asset', 'Instagram', 'done'],
	['12:02:35', 'TT-05', 'warmup action', 'TikTok', 'done'],
	['12:02:37', 'RD-03', 'sync data', 'Reddit', 'done'],
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_COPY.en.title}`} description={SITE_COPY.en.description} />
	</head>
	<body>
		<Header />
		<div class="keyword-ticker" aria-hidden="true">
			<div class="ticker-track">
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>CLOUD PHONE ENVIRONMENTS</span>
				<span>PROXY IP MANAGEMENT</span>
				<span>BULK TASKS</span>
				<span>ASSET LIBRARY</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>ACCOUNT MATRIX</span>
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>CLOUD PHONE ENVIRONMENTS</span>
				<span>PROXY IP MANAGEMENT</span>
				<span>BULK TASKS</span>
				<span>ASSET LIBRARY</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>ACCOUNT MATRIX</span>
			</div>
		</div>
		<main>
			<section class="page-head">
				<span class="cursor-glow" aria-hidden="true"></span>
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<div class="page-head-copy">
					<span class="section-kicker">From the Ainnc Team</span>
					<h1>When Account Count Goes From 1 to <em id="counter-num">1000+</em></h1>
					<p>For agencies, MCNs, and global brand teams managing hundreds or thousands of accounts across TikTok, Instagram, Reddit, and X.</p>
				</div>
				<div class="ops-dashboard" aria-label="Blog operations live log">
					<div class="ops-head">
						<span>Operations Tasks · Live Log</span>
						<em><span></span>LIVE</em>
					</div>
					<div class="ops-log">
						<div class="ops-log-track">
							{
								[...heroLogRows, ...heroLogRows].map(([time, device, action, platform, status], index) => (
									<div class="ops-row" style={`--delay: ${index * 0.16}s`}>
										<span>{time}</span>
										<strong>{device}</strong>
										<span>{action}</span>
										<b>{platform}</b>
										<em>{status}</em>
									</div>
								))
							}
						</div>
					</div>
					<div class="ops-stats" aria-label="Blog content stats">
						<span><strong>2,855</strong>weekly published items</span>
						<span><strong>{posts.length}</strong>practical articles</span>
						<span><strong>4</strong>covered platforms</span>
					</div>
				</div>
			</section>

			{
				featuredPost && featuredMeta && (
					<section class="spotlight-card">
						<div class="spotlight-copy">
							<div class="article-code">
								<span>FEATURED</span>
								<span aria-hidden="true">/</span>
								<span>{featuredCode}</span>
							</div>
							<h2>
								<a href={`/en/blog/${featuredPost.id}/`}>{featuredMeta.title}</a>
							</h2>
							<p>{featuredMeta.description}</p>
						</div>
						<div class="spotlight-meta">
							<span><FormattedDate date={featuredPost.data.pubDate} locale="en" /></span>
							<span>7 MIN</span>
							<a href={`/en/blog/${featuredPost.id}/`}>Read article -&gt;</a>
						</div>
					</section>
				)
			}

			<section class="filter-bar" aria-label="Post category filters">
				{
					categories.map((category, index) => (
						<button class:list={['filter-pill', { selected: index === 0 }]} type="button" data-filter={category}>
							<span class="dot" aria-hidden="true"></span>
							{category}
						</button>
					))
				}
			</section>

			<section class="post-grid bento-grid" id="post-grid">
				{gridPosts.map((post) => {
					const meta = getPostMeta(post, 'en');
					return <PostCard post={post} index={nextEnglishCategoryIndex(meta.category)} variant="bento" span={spanMap[post.id] ?? 'none'} locale="en" />;
				})}
			</section>
		</main>
		<Footer />
		<script>
			const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
			const cards = document.querySelectorAll<HTMLElement>('#post-grid > [data-category]');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					filterButtons.forEach((item) => item.classList.remove('selected'));
					button.classList.add('selected');
					const filter = button.dataset.filter;

					cards.forEach((card) => {
						const visible = filter === 'All Articles' || card.dataset.category === filter;
						card.toggleAttribute('hidden', !visible);
					});
				});
			});

			const heroPanels = document.querySelectorAll<HTMLElement>('.page-head');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (supportsHover) {
				heroPanels.forEach((panel) => {
					panel.addEventListener('pointermove', (event) => {
						const rect = panel.getBoundingClientRect();
						panel.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
						panel.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerenter', () => {
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerleave', () => {
						panel.classList.remove('is-glowing');
					});
				});

				document.querySelectorAll<HTMLElement>('.post-card').forEach((card) => {
					card.addEventListener('pointermove', (event) => {
						const rect = card.getBoundingClientRect();
						const x = event.clientX - rect.left;
						const y = event.clientY - rect.top;
						const rotateX = ((y / rect.height) - 0.5) * -4;
						const rotateY = ((x / rect.width) - 0.5) * 4;
						card.style.setProperty('--glare-x', `${event.clientX - rect.left}px`);
						card.style.setProperty('--glare-y', `${event.clientY - rect.top}px`);
						if (card.classList.contains('bento')) {
							card.style.transform = `translateY(-4px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
						}
					});

					card.addEventListener('pointerleave', () => {
						card.style.transform = '';
					});
				});
			}

			const counter = document.getElementById('counter-num');
			if (counter && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				let value = 1;
				const step = () => {
					value = Math.min(1000, value + Math.ceil((1000 - value) / 9));
					counter.textContent = `${value}+`;
					if (value < 1000) {
						window.requestAnimationFrame(step);
					}
				};
				window.requestAnimationFrame(step);
			}
		</script>
	</body>
</html>

<style>
	.keyword-ticker {
		overflow: hidden;
		border-bottom: 1px solid rgba(6, 39, 42, 14%);
		background: #06272a;
		color: #d8fffa;
	}

	.ticker-track {
		display: flex;
		width: max-content;
		gap: 2rem;
		padding: 0.45rem 0;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.76rem;
		font-weight: 800;
		letter-spacing: 0.11em;
		animation: ticker-slide 34s linear infinite;
	}

	.ticker-track span {
		position: relative;
		white-space: nowrap;
		opacity: 0.86;
	}

	.ticker-track span::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1.15rem;
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 999px;
		background: var(--accent);
		transform: translateY(-50%);
	}

	@keyframes ticker-slide {
		to {
			transform: translateX(-50%);
		}
	}

	.page-head {
		--glow-x: 50%;
		--glow-y: 50%;
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 620px;
		gap: clamp(1.75rem, 4vw, 3rem);
		justify-items: center;
		margin-bottom: 2rem;
		overflow: hidden;
		padding: clamp(2.5rem, 6vw, 5.5rem) clamp(1.25rem, 5vw, 4rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			radial-gradient(circle at 72% 22%, rgba(0, 201, 170, 22%), transparent 19rem),
			linear-gradient(135deg, rgba(224, 255, 249, 92%), rgba(244, 255, 252, 88%) 54%, rgba(255, 255, 255, 86%)),
			white;
		box-shadow: 0 24px 70px rgba(0, 69, 76, 12%);
		text-align: center;
	}

	.cursor-glow {
		position: absolute;
		z-index: 0;
		inset: -12%;
		background: radial-gradient(
			circle 260px at var(--glow-x) var(--glow-y),
			rgba(46, 233, 208, 38%),
			rgba(0, 201, 170, 16%) 34%,
			rgba(0, 125, 118, 8%) 48%,
			transparent 72%
		);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.page-head.is-glowing .cursor-glow {
		opacity: 1;
	}

	.hero-watermark {
		position: absolute;
		right: clamp(-8rem, -8vw, -3rem);
		top: 4rem;
		z-index: 0;
		width: min(42rem, 54vw);
		opacity: 0.06;
		filter: grayscale(1) brightness(0.45);
		transform: rotate(-7deg);
	}

	.page-head-copy {
		position: relative;
		z-index: 2;
		display: grid;
		gap: 1rem;
		max-width: 760px;
		justify-items: center;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.page-head p {
		max-width: 700px;
		font-size: clamp(1rem, 1.6vw, 1.15rem);
	}

	.page-head h1 em {
		color: var(--accent-dark);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-style: normal;
	}

	.ops-dashboard {
		position: relative;
		z-index: 2;
		width: min(720px, 100%);
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 8px;
		background:
			linear-gradient(155deg, rgba(3, 39, 40, 94%), rgba(4, 85, 75, 92%)),
			#06272a;
		padding: clamp(1rem, 2vw, 1.35rem);
		box-shadow: 0 28px 64px rgba(0, 69, 76, 28%);
		text-align: left;
	}

	.ops-head,
	.ops-stats {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.ops-head {
		margin-bottom: 1rem;
		color: #d8fffa;
		font-weight: 900;
	}

	.ops-head span,
	.ops-head em,
	.ops-row,
	.ops-stats strong {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.ops-head > span {
		font-size: 0.78rem;
	}

	.ops-head em {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 999px;
		background: rgba(46, 233, 208, 10%);
		padding: 0.25rem 0.55rem;
		color: #8dfff0;
		font-size: 0.66rem;
		font-style: normal;
	}

	.ops-head em span {
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 999px;
		background: var(--accent);
		box-shadow: 0 0 0 5px rgba(0, 201, 170, 12%);
		animation: live-pulse 1.35s ease-in-out infinite;
	}

	.ops-log {
		overflow: hidden;
		height: 9.7rem;
		border-radius: 8px;
		background:
			radial-gradient(circle at 28% 16%, rgba(0, 201, 170, 12%), transparent 16rem),
			rgba(0, 24, 26, 42%);
		padding: 1rem;
	}

	.ops-log-track {
		display: grid;
		animation: live-log-scroll 11s linear infinite;
	}

	.ops-log:hover .ops-log-track {
		animation-play-state: paused;
	}

	.ops-row {
		display: grid;
		grid-template-columns: 4.8rem 4rem minmax(0, 1fr) 5.4rem 3.2rem;
		align-items: center;
		gap: 0.75rem;
		border-bottom: 1px solid rgba(255, 255, 255, 5%);
		padding: 0.38rem 0;
		color: rgba(216, 255, 250, 72%);
		font-size: 0.72rem;
		animation: row-glow 3.6s ease-in-out var(--delay) infinite;
	}

	.ops-row:last-child {
		border-bottom: 0;
	}

	.ops-row strong,
	.ops-row b,
	.ops-row em {
		min-width: 0;
		overflow: hidden;
		color: #8dfff0;
		font-style: normal;
		font-weight: 900;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.ops-row span {
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.ops-stats {
		margin-top: 1rem;
		border-top: 1px solid rgba(255, 255, 255, 8%);
		padding-top: 1rem;
		color: rgba(216, 255, 250, 70%);
		font-size: 0.76rem;
		font-weight: 800;
	}

	.ops-stats span,
	.ops-stats strong {
		display: block;
	}

	.ops-stats strong {
		margin-bottom: 0.25rem;
		color: white;
		font-size: clamp(1.1rem, 2vw, 1.45rem);
	}

	@keyframes live-pulse {
		50% {
			box-shadow: 0 0 0 8px rgba(0, 201, 170, 4%);
			transform: scale(0.9);
		}
	}

	@keyframes row-glow {
		50% {
			color: rgba(216, 255, 250, 95%);
		}
	}

	@keyframes live-log-scroll {
		to {
			transform: translateY(-50%);
		}
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-items: center;
		margin-bottom: 1rem;
	}

	.spotlight-card {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1rem;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(6, 39, 42, 92%), rgba(4, 63, 60, 88%)),
			white;
		padding: clamp(1.3rem, 3vw, 2rem);
		box-shadow: var(--shadow);
	}

	.spotlight-card::before {
		content: '';
		position: absolute;
		inset: auto 8% -35% auto;
		width: 16rem;
		height: 16rem;
		border-radius: 999px;
		background: rgba(46, 233, 208, 18%);
		filter: blur(30px);
	}

	.spotlight-copy,
	.spotlight-meta {
		position: relative;
		z-index: 1;
	}

	.spotlight-copy {
		display: grid;
		gap: 0.85rem;
	}

	.spotlight-copy .article-code {
		display: inline-flex;
		gap: 0.5rem;
		align-items: center;
		width: fit-content;
		border: 1px solid rgba(46, 233, 208, 36%);
		border-radius: 999px;
		background: rgba(227, 251, 247, 10%);
		padding: 0.3rem 0.7rem;
		color: #72f7e8;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.spotlight-card h2 {
		max-width: 780px;
		font-size: clamp(1.5rem, 3vw, 2.45rem);
	}

	.spotlight-card h2 a {
		color: white;
		text-decoration: none;
	}

	.spotlight-card p {
		max-width: 780px;
		color: #b8eee7;
	}

	.spotlight-meta {
		display: grid;
		gap: 0.55rem;
		justify-items: end;
		color: #d8fffa;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.78rem;
		font-weight: 900;
		white-space: nowrap;
	}

	.spotlight-meta a {
		color: var(--accent);
		text-decoration: none;
	}

	.filter-pill {
		display: inline-flex;
		gap: 0.45rem;
		align-items: center;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: white;
		padding: 0.55rem 0.9rem;
		color: var(--muted);
		font: inherit;
		font-weight: 800;
		cursor: pointer;
	}

	.filter-pill .dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.45;
	}

	.filter-pill:hover,
	.filter-pill.selected {
		border-color: var(--accent-dark);
		background: #063f3c;
		color: white;
	}

	.filter-pill.selected .dot {
		opacity: 1;
	}

	@media (max-width: 900px) {
		.page-head {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.spotlight-card {
			grid-template-columns: 1fr;
		}

		.spotlight-meta {
			justify-items: start;
		}

		.hero-watermark {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.page-head {
			padding: 2rem 1rem;
		}

		.ops-dashboard {
			padding: 0.9rem;
		}

		.ops-log {
			padding: 0.7rem;
		}

		.ops-row {
			grid-template-columns: 3.6rem 2.8rem minmax(3.6rem, 1fr) 3.7rem 2.4rem;
			gap: 0.3rem;
			font-size: 0.58rem;
		}

		.ops-head {
			gap: 0.5rem;
		}

		.ops-stats {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0.7rem;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.cursor-glow {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.ops-log-track {
			animation: none;
		}
	}
</style>
