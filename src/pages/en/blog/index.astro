---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPostMeta, SITE_COPY } from '../../../i18n';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const upcomingPosts = [
	{
		category: 'Operations Playbook',
		title: 'Why Spreadsheets Break After 50 Social Accounts',
		description: 'The hidden cost of tracking accounts, logins, and content in sheets, plus what a living account record should contain.',
		readTime: '6 min read',
		date: 'Jul 7, 2026',
	},
	{
		category: 'Operations Playbook',
		title: 'What a Real Social Media Operations Platform Should Look Like',
		description: 'How teams move from scattered tools to one shared operating layer for accounts, assets, tasks, and data.',
		readTime: '6 min read',
		date: 'Jul 10, 2026',
	},
	{
		category: 'Operations Playbook',
		title: 'How MCN Agencies Prove Value to Clients With Data',
		description: 'Turning execution records into review-ready reports is one of the most underrated renewal tools for agency teams.',
		readTime: '6 min read',
		date: 'Jul 14, 2026',
	},
	{
		category: 'Product Capabilities',
		title: 'Cloud Phones vs. Browsers: Which Is Safer for Accounts?',
		description: 'Browser fingerprinting and cloud-phone isolation solve different problems. The right choice depends on account scale.',
		readTime: '5 min read',
		date: 'Jul 17, 2026',
	},
	{
		category: 'Product Capabilities',
		title: 'Static, Dynamic, and Mobile IPs: How to Choose a Proxy',
		description: 'There is no single best proxy type. The right setup depends on account volume, market coverage, and risk tolerance.',
		readTime: '5 min read',
		date: 'Jul 21, 2026',
	},
	{
		category: 'Product Capabilities',
		title: 'From Content Creation to Publishing: One Workflow Instead of Five Tools',
		description: 'A practical look at how one content asset moves from idea to publication across four platforms with less handoff friction.',
		readTime: '6 min read',
		date: 'Jul 24, 2026',
	},
	{
		category: 'Platform Guides',
		title: 'How to Avoid Common Risk-Control Issues in Bulk TikTok Operations',
		description: 'Account safety comes down to believable independence, natural operating rhythm, and a baseline of content originality.',
		readTime: '6 min read',
		date: 'Jul 28, 2026',
	},
	{
		category: 'Global Growth',
		title: 'Building Scalable Social Operations for Global Brands',
		description: 'The common localization traps brands face when entering new markets, and the four layers scalable operations require.',
		readTime: '6 min read',
		date: 'Jul 31, 2026',
	},
	{
		category: 'Global Growth',
		title: 'How Deep Should Localization Go for Global Social Media?',
		description: 'Translation helps audiences understand you. Localization makes them want to keep watching. Those are different jobs.',
		readTime: '6 min read',
		date: 'Aug 4, 2026',
	},
];
const categoryOrder = [
	'Operations Playbook',
	'Platform Guides',
	'Product Capabilities',
	'Global Growth',
	'Tutorials',
	'Operations',
	'Product Updates',
];
const allCategoryLabels = new Set([
	...posts.map((post) => getPostMeta(post, 'en').category),
	...upcomingPosts.map((post) => post.category),
]);
const categories = [
	'All Articles',
	...categoryOrder.filter((category) => allCategoryLabels.has(category)),
	...Array.from(allCategoryLabels).filter((category) => !categoryOrder.includes(category)),
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_COPY.en.title}`} description={SITE_COPY.en.description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<span class="eyebrow">From the Ainnc Team</span>
				<h1>Practical Methods for Scaling Social Account Operations</h1>
				<p>For agencies, MCNs, and global brand teams managing hundreds or thousands of accounts across TikTok, Instagram, Reddit, and X.</p>
			</section>

			<section class="filter-bar" aria-label="Post category filters">
				{
					categories.map((category, index) => (
						<button class:list={['filter-pill', { selected: index === 0 }]} type="button" data-filter={category}>
							{category}
						</button>
					))
				}
			</section>

			<section class="post-grid" id="post-grid">
				{posts.map((post) => <PostCard post={post} locale="en" />)}
				{
					upcomingPosts.map((post) => (
						<article class="post-card draft-card" data-category={post.category}>
							<div class="post-body">
								<div class="post-meta">
									<span>{post.category}</span>
									<span>{post.readTime}</span>
									<span>{post.date}</span>
								</div>
								<h2>{post.title}</h2>
								<p>{post.description}</p>
								<span class="draft-label">Scheduled</span>
							</div>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
		<script>
			const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
			const cards = document.querySelectorAll<HTMLElement>('#post-grid > [data-category]');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					filterButtons.forEach((item) => item.classList.remove('selected'));
					button.classList.add('selected');
					const filter = button.dataset.filter;

					cards.forEach((card) => {
						const visible = filter === 'All Articles' || card.dataset.category === filter;
						card.toggleAttribute('hidden', !visible);
					});
				});
			});
		</script>
	</body>
</html>

<style>
	.page-head {
		display: grid;
		gap: 0.8rem;
		margin-bottom: 1.5rem;
		padding: 2rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(0, 201, 170, 12%), rgba(0, 69, 76, 6%)),
			white;
		box-shadow: var(--shadow);
	}

	.page-head p {
		max-width: 720px;
		font-size: 1.05rem;
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-items: center;
		margin-bottom: 1rem;
	}

	.filter-pill {
		border: 1px solid var(--line);
		border-radius: 999px;
		background: white;
		padding: 0.55rem 0.9rem;
		color: var(--muted);
		font: inherit;
		font-weight: 800;
		cursor: pointer;
	}

	.filter-pill:hover,
	.filter-pill.selected {
		border-color: var(--accent-dark);
		background: #063f3c;
		color: white;
	}

	.draft-card {
		border-style: dashed;
		background: rgba(255, 255, 255, 0.72);
	}

	.draft-card .post-meta span:first-child {
		color: var(--accent-dark);
	}

	.draft-card h2 {
		font-size: 1.15rem;
	}

	.draft-label {
		width: fit-content;
		border-radius: 999px;
		background: rgba(0, 201, 170, 12%);
		padding: 0.25rem 0.65rem;
		color: var(--accent-dark);
		font-size: 0.82rem;
		font-weight: 800;
	}
</style>
