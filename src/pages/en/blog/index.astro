---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPostMeta, SITE_COPY } from '../../../i18n';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const categoryOrder = [
	'Operations Playbook',
	'Platform Guides',
	'Product Capabilities',
	'Global Growth',
	'Tutorials',
	'Operations',
	'Product Updates',
];
const allCategoryLabels = new Set([
	...posts.map((post) => getPostMeta(post, 'en').category),
]);
const categories = [
	'All Articles',
	...categoryOrder.filter((category) => allCategoryLabels.has(category)),
	...Array.from(allCategoryLabels).filter((category) => !categoryOrder.includes(category)),
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_COPY.en.title}`} description={SITE_COPY.en.description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<span class="cursor-glow" aria-hidden="true"></span>
				<div class="page-head-copy">
					<span class="section-kicker">From the Ainnc Team</span>
					<h1>Practical Methods for Scaling Social Account Operations</h1>
					<p>For agencies, MCNs, and global brand teams managing hundreds or thousands of accounts across TikTok, Instagram, Reddit, and X.</p>
					<div class="hero-stats" aria-label="Blog content overview">
						<span><strong>{posts.length}</strong>articles</span>
						<span><strong>4</strong>themes</span>
						<span><strong>Ainnc</strong>playbooks</span>
					</div>
				</div>
				<div class="tile-grid" aria-hidden="true">
					{Array.from({ length: 42 }).map((_, index) => <span class:list={['tile', { bright: index % 8 === 0 || index % 13 === 0 }]} />)}
				</div>
			</section>

			<section class="filter-bar" aria-label="Post category filters">
				{
					categories.map((category, index) => (
						<button class:list={['filter-pill', { selected: index === 0 }]} type="button" data-filter={category}>
							<span class="dot" aria-hidden="true"></span>
							{category}
						</button>
					))
				}
			</section>

			<section class="post-grid" id="post-grid">
				{posts.map((post, index) => <PostCard post={post} featured={index === 0} locale="en" />)}
			</section>
		</main>
		<Footer />
		<script>
			const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
			const cards = document.querySelectorAll<HTMLElement>('#post-grid > [data-category]');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					filterButtons.forEach((item) => item.classList.remove('selected'));
					button.classList.add('selected');
					const filter = button.dataset.filter;

					cards.forEach((card) => {
						const visible = filter === 'All Articles' || card.dataset.category === filter;
						card.toggleAttribute('hidden', !visible);
					});
				});
			});

			const heroPanels = document.querySelectorAll<HTMLElement>('.page-head');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (supportsHover) {
				heroPanels.forEach((panel) => {
					panel.addEventListener('pointermove', (event) => {
						const rect = panel.getBoundingClientRect();
						panel.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
						panel.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerenter', () => {
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerleave', () => {
						panel.classList.remove('is-glowing');
					});
				});
			}
		</script>
	</body>
</html>

<style>
	.page-head {
		--glow-x: 50%;
		--glow-y: 50%;
		position: relative;
		isolation: isolate;
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(260px, 0.92fr);
		gap: 2rem;
		align-items: center;
		margin-bottom: 1.35rem;
		overflow: hidden;
		padding: clamp(2rem, 5vw, 4rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(0, 201, 170, 12%), rgba(0, 69, 76, 6%)),
			white;
		box-shadow: var(--shadow);
	}

	.cursor-glow {
		position: absolute;
		z-index: 0;
		inset: -12%;
		background: radial-gradient(
			circle 260px at var(--glow-x) var(--glow-y),
			rgba(46, 233, 208, 38%),
			rgba(0, 201, 170, 16%) 34%,
			rgba(0, 125, 118, 8%) 48%,
			transparent 72%
		);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.page-head.is-glowing .cursor-glow {
		opacity: 1;
	}

	.page-head-copy {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1rem;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.page-head p {
		max-width: 720px;
		font-size: 1.05rem;
	}

	.hero-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 0.25rem;
		color: var(--muted);
		font-weight: 800;
	}

	.hero-stats span {
		border: 1px solid rgba(0, 201, 170, 28%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 70%);
		padding: 0.45rem 0.75rem;
	}

	.hero-stats strong {
		margin-right: 0.2rem;
		color: var(--text);
	}

	.tile-grid {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.tile {
		aspect-ratio: 1;
		border-radius: 7px;
		background: rgba(0, 177, 179, 10%);
	}

	.tile.bright {
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		box-shadow: 0 10px 28px rgba(0, 201, 170, 24%);
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-items: center;
		margin-bottom: 1rem;
	}

	.filter-pill {
		display: inline-flex;
		gap: 0.45rem;
		align-items: center;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: white;
		padding: 0.55rem 0.9rem;
		color: var(--muted);
		font: inherit;
		font-weight: 800;
		cursor: pointer;
	}

	.filter-pill .dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.45;
	}

	.filter-pill:hover,
	.filter-pill.selected {
		border-color: var(--accent-dark);
		background: #063f3c;
		color: white;
	}

	.filter-pill.selected .dot {
		opacity: 1;
	}

	@media (max-width: 900px) {
		.page-head {
			grid-template-columns: 1fr;
		}

		.tile-grid {
			display: none;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.cursor-glow {
			display: none;
		}
	}
</style>
