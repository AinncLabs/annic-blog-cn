---
import { type CollectionEntry, getCollection } from 'astro:content';
import EnglishPostBody from '../../../components/EnglishPostBody.astro';
import BlogPost from '../../../layouts/BlogPost.astro';
import { getPostMeta } from '../../../i18n';

export async function getStaticPaths() {
	const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	return posts.map((post, postIndex) => ({
		params: { slug: post.id },
		props: { post, postIndex },
	}));
}
type Props = {
	post: CollectionEntry<'blog'>;
	postIndex: number;
};

const { post, postIndex } = Astro.props;
const meta = getPostMeta(post, 'en');
---

<BlogPost
	{...post.data}
	title={meta.title}
	description={meta.description}
	category={meta.category}
	tags={meta.tags}
	locale="en"
	postIndex={postIndex}
>
	<EnglishPostBody postId={post.id} />
</BlogPost>
