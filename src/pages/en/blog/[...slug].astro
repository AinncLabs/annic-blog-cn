---
import { type CollectionEntry, getCollection } from 'astro:content';
import EnglishPostBody from '../../../components/EnglishPostBody.astro';
import BlogPost from '../../../layouts/BlogPost.astro';
import { getCategoryTone } from '../../../blogVisuals';
import { getPostMeta } from '../../../i18n';

export async function getStaticPaths() {
	const postOrder = [
		'scaling-social-account-operations',
		'spreadsheets-break-50',
		'real-social-ops-platform',
		'task-center',
		'mcn-prove-value-with-data',
		'cloud-phone-vs-browser',
		'proxy-ip-types',
		'one-workflow-five-tools',
		'tiktok-risk-guide',
		'global-brand-scale',
		'localization-how-deep',
		'account-device-proxy-guide',
		'task-files-publishing',
		'ainnc-start',
	];
	const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => {
		const aOrder = postOrder.indexOf(a.id);
		const bOrder = postOrder.indexOf(b.id);
		return (aOrder === -1 ? 999 : aOrder) - (bOrder === -1 ? 999 : bOrder);
	});
	const toneCounters: Record<string, number> = {};

	return posts.map((post) => {
		const meta = getPostMeta(post, 'en');
		const tone = getCategoryTone(meta.category);
		const postIndex = toneCounters[tone] ?? 0;
		toneCounters[tone] = postIndex + 1;

		return {
			params: { slug: post.id },
			props: { post, postIndex },
		};
	});
}
type Props = {
	post: CollectionEntry<'blog'>;
	postIndex: number;
};

const { post, postIndex } = Astro.props;
const meta = getPostMeta(post, 'en');
---

<BlogPost
	{...post.data}
	title={meta.title}
	description={meta.description}
	category={meta.category}
	tags={meta.tags}
	locale="en"
	postIndex={postIndex}
>
	<EnglishPostBody postId={post.id} />
</BlogPost>
