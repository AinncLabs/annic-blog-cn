---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostMeta, SITE_COPY } from '../../i18n';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);
const topics = [
	'All Articles',
	'Operations Playbooks',
	'Platform Guides',
	'Product Capabilities',
	'Global Growth',
	'Task Reviews',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_COPY.en.title} description={SITE_COPY.en.description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<span class="eyebrow">From the Ainnc Team</span>
					<h1>Practical Methods for Scaling Social Account Operations</h1>
					<p>
						For agencies, MCNs, and global brand teams managing hundreds or thousands of
						accounts across TikTok, Instagram, Reddit, and X.
					</p>
					<div class="hero-actions">
						<a href="/en/blog/" class="primary">Read Articles</a>
						<a
							href="https://www.ainnc.com/#hero"
							class="primary site-primary"
							target="_blank"
							rel="noopener noreferrer"
						>
							Official Site
						</a>
						<a href="/en/about/" class="secondary">About Ainnc</a>
					</div>
				</div>
				<div class="hero-panel panel">
					<h2>Content Framework</h2>
					<ul>
						<li><strong>Operations Playbooks</strong><span>Scaling accounts, team workflows, and delivery stability</span></li>
						<li><strong>Platform Guides</strong><span>Execution differences across TikTok, Instagram, Reddit, and X</span></li>
						<li><strong>Product Capabilities</strong><span>Accounts, proxies, files, tasks, and usage management</span></li>
					</ul>
				</div>
			</section>

			{
				featuredPost && (
					<section class="featured-section">
						<div class="section-header">
							<div>
								<span class="eyebrow">Featured</span>
								<h2>Start Here</h2>
							</div>
							<p>A quick introduction to Ainnc's product capabilities and blog direction.</p>
						</div>
						<PostCard post={featuredPost} featured locale="en" />
					</section>
				)
			}

			<section>
				<div class="section-header">
					<div>
						<span class="eyebrow">Latest</span>
						<h2>Operations Guides</h2>
					</div>
					<a href="/en/blog/">All Articles</a>
				</div>
				<div class="post-grid">
					{latestPosts.map((post) => <PostCard post={post} locale="en" />)}
				</div>
			</section>

			<section class="topics panel">
				<div>
					<span class="eyebrow">Editorial Plan</span>
					<h2>Topics We Will Keep Expanding</h2>
				</div>
				<ul>
					{topics.map((topic) => <li>{topic}</li>)}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
		gap: 1rem;
		align-items: stretch;
		margin-bottom: 2rem;
	}

	.hero-copy,
	.hero-panel {
		padding: 2rem;
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(0, 201, 170, 14%), rgba(0, 69, 76, 8%)),
			white;
		box-shadow: var(--shadow);
	}

	.hero-copy p {
		max-width: 720px;
		font-size: 1.05rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.hero-actions a {
		border-radius: 8px;
		padding: 0.7rem 1rem;
		font-weight: 800;
		text-decoration: none;
	}

	.primary {
		background: var(--accent);
		color: white;
	}

	.primary:hover {
		background: var(--accent-dark);
		color: white;
	}

	.site-primary {
		background: #063f3c;
	}

	.site-primary:hover {
		background: #021f1e;
	}

	.secondary {
		border: 1px solid var(--line);
		background: white;
		color: var(--text);
	}

	.hero-panel ul {
		display: grid;
		gap: 0.75rem;
		margin-top: 1rem;
		list-style: none;
	}

	.hero-panel li {
		border-radius: 8px;
		background: var(--surface-soft);
		padding: 0.9rem;
	}

	.hero-panel strong,
	.hero-panel span {
		display: block;
	}

	.hero-panel span {
		margin-top: 0.2rem;
		color: var(--muted);
		font-size: 0.92rem;
	}

	.featured-section,
	main > section {
		margin-bottom: 2rem;
	}

	.topics {
		display: grid;
		grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
		gap: 1rem;
		padding: 1.5rem;
	}

	.topics ul {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		list-style: none;
	}

	.topics li {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface-soft);
		padding: 0.75rem;
		color: var(--text);
		font-weight: 700;
	}

	@media (max-width: 900px) {
		.hero,
		.topics,
		.topics ul {
			grid-template-columns: 1fr;
		}
	}
</style>
