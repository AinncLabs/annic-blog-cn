---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostMeta, hasEnglishPost, SITE_COPY } from '../../i18n';

const posts = (await getCollection('blog', (post) => !post.data.draft && hasEnglishPost(post.id))).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const featuredIndex = featuredPost ? posts.findIndex((post) => post.id === featuredPost.id) : 0;
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);
const frameworks = [
	['ops', 'Operations Playbooks', 'Scaling accounts, team workflows, and delivery stability'],
	['platform', 'Platform Guides', 'Execution differences across TikTok, Instagram, Reddit, and X'],
	['product', 'Product Capabilities', 'Accounts, proxies, files, tasks, and usage management'],
	['insights', 'Global Growth', 'Localization, multi-market scale, and brand expansion'],
];
const topicDefinitions = [
	{ label: 'Operations Playbooks', category: 'Operations Playbook' },
	{ label: 'Product Capabilities', category: 'Product Capabilities' },
	{ label: 'Platform Guides', category: 'Platform Guides' },
	{ label: 'Global Growth', category: 'Global Growth' },
	{ label: 'Tutorials', category: 'Tutorials' },
	{ label: 'Task Reviews', category: 'Task Reviews' },
];
const topicCounts = posts.reduce<Record<string, number>>((counts, post) => {
	const category = getPostMeta(post, 'en').category;
	counts[category] = (counts[category] ?? 0) + 1;
	return counts;
}, {});
const topicSizes = ['large', 'medium-primary', 'medium-secondary', 'small-blue', 'small-neutral', 'small-neutral'];
const topics = topicDefinitions
	.map((topic) => ({ ...topic, count: topicCounts[topic.category] ?? 0 }))
	.sort((a, b) => b.count - a.count)
	.map((topic, index) => ({ ...topic, size: topicSizes[index] }));
const clusterDevices = [
	{ id: 'DE-001', platform: 'TikTok', task: 'queue dispatch → TikTok', active: true },
	{ id: 'FR-002', platform: 'Instagram', task: 'standby', active: false },
	{ id: 'UK-003', platform: 'Reddit', task: 'standby', active: false },
	{ id: 'US-004', platform: 'X', task: 'standby', active: false },
	{ id: 'JP-005', platform: 'TikTok', task: 'render video → TikTok', active: true },
	{ id: 'BR-006', platform: 'Instagram', task: 'account check → Instagram', active: true },
	{ id: 'ES-007', platform: 'Reddit', task: 'standby', active: false },
	{ id: 'IT-008', platform: 'X', task: 'standby', active: false },
];
const clusterLogs = [
	['11:02:25', 'IT-008', 'data sync', 'Instagram', 'done'],
	['11:02:27', 'BR-006', 'data sync', 'Instagram', 'done'],
	['11:25:41', 'US-004', 'post draft', 'X', 'done'],
	['11:25:44', 'JP-005', 'render video', 'TikTok', 'running'],
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_COPY.en.title} description={SITE_COPY.en.description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero" id="home-hero">
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<span class="hero-cursor-glow" aria-hidden="true"></span>
				<div class="hero-copy">
					<span class="section-kicker">From the Ainnc Team</span>
					<h1>Practical Methods for Scaling Social Account Operations</h1>
					<p>
						For agencies, MCNs, and global brand teams managing hundreds or thousands of
						accounts across TikTok, Instagram, Reddit, and X.
					</p>
					<div class="hero-stats" aria-label="Blog content overview">
						<span><strong>{posts.length}</strong>articles</span>
						<span><strong>4</strong>themes</span>
						<span><strong>1</strong>operations layer</span>
					</div>
				</div>
				<div class="cluster-wrap" aria-label="Ainnc cloud account cluster preview">
					<div class="cluster-panel">
						<div class="cluster-head">
							<span class="cluster-title">Cloud account cluster · Live tasks</span>
							<span class="live-pill"><span class="live-dot"></span>RUNNING</span>
						</div>
						<div class="cluster-body">
							<div class="device-grid">
								{
									clusterDevices.map((device, index) => (
										<div
											class:list={['device-card', { active: device.active }]}
											style={`--delay: ${index * 0.16}s`}
											data-device-card
											data-device-id={device.id}
											data-index={index}
										>
											<div class="device-top">
												<span class="device-id">{device.id}</span>
												<span class="device-dot"></span>
											</div>
											<p class="device-status">{device.task}</p>
											<span class="device-trace"></span>
										</div>
									))
								}
							</div>
							<div class="log-panel">
								<div class="log-track" data-log-track>
									{
										clusterLogs.map(([time, device, action, platform, status], index) => (
											<div class="log-line" style={`--delay: ${index * 0.18}s`}>
												<span class="lt">{time}</span>
												<span class="ld">{device}</span>
												<span class="la">{action}</span>
												<span class="lp">{platform}</span>
												<span class="lc">✓ {status}</span>
											</div>
										))
									}
								</div>
							</div>
						</div>
						<div class="cluster-stats">
							<span><strong data-live-count>2,866</strong>weekly published items</span>
							<span><strong>12</strong>covered time zones</span>
							<span><strong>99.6%</strong>environment uptime</span>
						</div>
					</div>
				</div>
			</section>

			<section class="framework-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">Content Framework</span>
						<h2>From Operational Problems to Product Capabilities</h2>
					</div>
					<p>A quick map for understanding Ainnc's product capabilities and editorial direction.</p>
				</div>
				<div class="framework-grid">
					{
						frameworks.map(([tone, title, description]) => (
							<article class="framework-card" data-tone={tone}>
								<h3>{title}</h3>
								<p>{description}</p>
							</article>
						))
					}
				</div>
			</section>

			{
				featuredPost && (
					<section class="featured-section">
						<div class="section-header">
							<div>
								<span class="eyebrow">Featured</span>
								<h2>Start Here</h2>
							</div>
							<p>Build a first-layer understanding of scaled social operations, account matrices, and Ainnc workflows.</p>
						</div>
						<PostCard post={featuredPost} featured index={featuredIndex} locale="en" />
					</section>
				)
			}

			<section class="latest-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">Latest</span>
						<h2>Operations Guides</h2>
					</div>
					<a href="/en/blog/">All Articles</a>
				</div>
				<div class="post-grid">
					{latestPosts.map((post) => <PostCard post={post} index={posts.findIndex((item) => item.id === post.id)} locale="en" />)}
				</div>
			</section>

			<section class="category-cloud">
				<div class="category-cloud-copy">
					<span class="eyebrow">Editorial Plan</span>
					<h2>Topics We Will Keep Expanding</h2>
				</div>
				<ul class="category-pill-list" aria-label="Blog categories">
					{
						topics.map((topic) => (
							<li
								class="category-pill"
								data-size={topic.size}
								title={`${topic.label} · ${topic.count} ${topic.count === 1 ? 'article' : 'articles'}`}
							>
								{topic.label}
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			const hero = document.getElementById('home-hero');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (hero && supportsHover) {
				hero.addEventListener('pointermove', (event) => {
					const rect = hero.getBoundingClientRect();
					const shiftX = ((event.clientX - rect.left) / rect.width - 0.5) * 22;
					const shiftY = ((event.clientY - rect.top) / rect.height - 0.5) * 18;
					hero.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
					hero.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
					hero.style.setProperty('--shift-x', `${shiftX}px`);
					hero.style.setProperty('--shift-y', `${shiftY}px`);
					hero.classList.add('is-glowing');
				});
				hero.addEventListener('pointerleave', () => {
					hero.classList.remove('is-glowing');
					hero.style.setProperty('--shift-x', '0px');
					hero.style.setProperty('--shift-y', '0px');
				});
			}

			const liveTasks = [
				['UK-003', 'asset sync', 'Reddit', 'running'],
				['US-004', 'data sync', 'X', 'done'],
				['JP-005', 'render video', 'TikTok', 'running'],
				['BR-006', 'account check', 'Instagram', 'done'],
				['DE-001', 'queue dispatch', 'TikTok', 'done'],
				['ES-007', 'comment review', 'Reddit', 'running'],
				['FR-002', 'asset ingest', 'Instagram', 'done'],
				['IT-008', 'data sync', 'X', 'done'],
			];
			const taskCards = Array.from(document.querySelectorAll<HTMLElement>('[data-device-card]'));
			const logTrack = document.querySelector<HTMLElement>('[data-log-track]');
			const liveCount = document.querySelector<HTMLElement>('[data-live-count]');
			let publishedCount = 2866;
			const activeDevices = new Set(['DE-001', 'JP-005', 'BR-006']);
			const taskLabels = new Map(liveTasks.map(([device, action, platform]) => [device, `${action} → ${platform}`]));
			const taskDetails = new Map(liveTasks.map(([device, action, platform, status]) => [device, [action, platform, status]]));
			const deviceIds = taskCards.map((card) => card.dataset.deviceId ?? '').filter(Boolean);
			const progressTimers = new Map<HTMLElement, number>();

			const startCardProgress = (card: HTMLElement) => {
				const currentTimer = progressTimers.get(card);
				if (currentTimer) {
					window.clearTimeout(currentTimer);
				}
				card.classList.remove('is-complete');
				card.classList.add('is-running');
				const timer = window.setTimeout(() => {
					card.classList.remove('is-running');
					if (card.classList.contains('active')) {
						card.classList.add('is-complete');
					}
					progressTimers.delete(card);
				}, 1700);
				progressTimers.set(card, timer);
			};

			const formatTime = () => new Date().toLocaleTimeString('en-US', { hour12: false });
			const updateLiveTasks = () => {
				const inactiveDevices = deviceIds.filter((id) => !activeDevices.has(id));
				const runningDevices = Array.from(activeDevices);
				const device = inactiveDevices[Math.floor(Math.random() * inactiveDevices.length)] ?? deviceIds[0];
				const deviceToPause = runningDevices[Math.floor(Math.random() * runningDevices.length)];
				if (deviceToPause) activeDevices.delete(deviceToPause);
				activeDevices.add(device);
				const [action = 'processing task', platform = 'TikTok', status = 'running'] = taskDetails.get(device) ?? [];
				taskCards.forEach((card) => {
					const id = card.dataset.deviceId ?? '';
					const statusNode = card.querySelector<HTMLElement>('.device-status');
					const isActive = activeDevices.has(id);
					const wasActive = card.classList.contains('active');
					card.classList.toggle('active', isActive);
					if (isActive && !wasActive) {
						startCardProgress(card);
					}
					if (!isActive) {
						const currentTimer = progressTimers.get(card);
						if (currentTimer) {
							window.clearTimeout(currentTimer);
							progressTimers.delete(card);
						}
						card.classList.remove('is-running', 'is-complete');
					}
					if (statusNode) {
						statusNode.textContent = isActive ? taskLabels.get(id) ?? 'processing task' : 'standby';
					}
				});

				if (logTrack) {
					const template = logTrack.querySelector<HTMLElement>('.log-line');
					const row = template ? (template.cloneNode(true) as HTMLElement) : document.createElement('div');
					row.className = 'log-line';
					if (template) {
						const cells = row.querySelectorAll('span');
						const values = [formatTime(), device, action, platform, `✓ ${status}`];
						cells.forEach((cell, index) => {
							cell.textContent = values[index] ?? '';
						});
					} else {
						row.innerHTML = `<span class="lt">${formatTime()}</span><span class="ld">${device}</span><span class="la">${action}</span><span class="lp">${platform}</span><span class="lc">✓ ${status}</span>`;
					}
					logTrack.appendChild(row);
					if (logTrack.children.length > 4) {
						const first = logTrack.firstElementChild as HTMLElement | null;
						if (first) {
							const gap = parseFloat(window.getComputedStyle(logTrack).rowGap || '0');
							const shift = first.getBoundingClientRect().height + gap;
							logTrack.style.setProperty('--log-shift', `${shift}px`);
							logTrack.classList.add('is-shifting');
							window.setTimeout(() => {
								first.remove();
								logTrack.classList.remove('is-shifting');
								logTrack.style.removeProperty('--log-shift');
							}, 680);
						}
					}
				}

				if (liveCount) {
					publishedCount += 1;
					liveCount.textContent = publishedCount.toLocaleString('en-US');
				}
			};

			taskCards.forEach((card) => {
				if (card.classList.contains('active')) {
					startCardProgress(card);
				}
			});
			const scheduleLiveUpdate = () => {
				window.setTimeout(() => {
					updateLiveTasks();
					scheduleLiveUpdate();
				}, 1800 + Math.random() * 1400);
			};
			scheduleLiveUpdate();

		</script>
	</body>
</html>

<style>
	.home-hero {
		--glow-x: 50%;
		--glow-y: 50%;
		--shift-x: 0px;
		--shift-y: 0px;
		position: relative;
		isolation: isolate;
		display: grid;
		box-sizing: border-box;
		width: 100vw;
		min-height: 760px;
		align-content: center;
		justify-items: center;
		overflow: hidden;
		margin-inline: calc(50% - 50vw);
		margin-bottom: 4rem;
		padding-inline: clamp(1rem, 3vw, 2rem);
		background:
			radial-gradient(circle at 20% 10%, rgba(46, 233, 208, 8%), transparent 50%),
			radial-gradient(circle at 80% 40%, rgba(8, 145, 178, 6%), transparent 50%),
			#fafdfc;
		text-align: center;
	}

	.hero-watermark {
		position: absolute;
		top: -7rem;
		right: -5rem;
		z-index: 0;
		width: min(50rem, 58vw);
		opacity: 0.07;
		filter: grayscale(1) brightness(0.45);
		transform: translate3d(var(--shift-x), var(--shift-y), 0) rotate(-7deg);
		transition: transform 0.18s ease-out;
	}

	.hero-cursor-glow {
		position: absolute;
		z-index: 1;
		inset: -14%;
		background: radial-gradient(circle 280px at var(--glow-x) var(--glow-y), rgba(46, 233, 208, 30%), rgba(0, 201, 170, 12%) 34%, transparent 72%);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.home-hero.is-glowing .hero-cursor-glow {
		opacity: 1;
	}

	.hero-copy {
		position: relative;
		z-index: 3;
		display: grid;
		max-width: 760px;
		gap: 1rem;
		padding: clamp(2rem, 5vw, 4rem) 1rem 1.25rem;
		justify-items: center;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.hero-copy p {
		max-width: 640px;
		font-size: 1.08rem;
	}

	.hero-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		justify-content: center;
		margin-top: 0.25rem;
		color: #06272a;
		font-size: 13px;
		font-weight: 800;
	}

	.hero-stats span {
		border: 1px solid #d7eeea;
		border-radius: 24px;
		background: #fff;
		padding: 10px 22px;
	}

	.hero-stats strong {
		margin-right: 0.2rem;
		color: var(--text);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.cluster-wrap {
		position: relative;
		z-index: 4;
		isolation: isolate;
		width: min(960px, calc(100% - 2rem));
		margin-bottom: 3.25rem;
		transform: translate3d(calc(var(--shift-x) * 0.25), calc(var(--shift-y) * 0.25), 0);
		transition: transform 0.18s ease-out;
	}

	.cluster-wrap::before,
	.cluster-wrap::after {
		content: '';
		position: absolute;
		z-index: 0;
		width: 46%;
		aspect-ratio: 1;
		border-radius: 50%;
		filter: blur(58px);
		opacity: 0.72;
		pointer-events: none;
		will-change: transform;
	}

	.cluster-wrap::before {
		top: -8%;
		left: 3%;
		background: radial-gradient(circle, rgba(37, 230, 214, 78%) 0%, rgba(22, 188, 198, 38%) 38%, transparent 72%);
		animation: glass-orb-cyan 16s ease-in-out infinite alternate;
	}

	.cluster-wrap::after {
		right: 2%;
		bottom: -12%;
		background: radial-gradient(circle, rgba(67, 117, 255, 72%) 0%, rgba(75, 89, 218, 38%) 42%, transparent 72%);
		animation: glass-orb-blue 19s ease-in-out infinite alternate;
	}

	.cluster-panel {
		position: relative;
		z-index: 1;
		overflow: hidden;
		border: 1px solid rgba(220, 240, 246, 18%);
		border-radius: 8px;
		background:
			radial-gradient(circle at 18% 12%, rgba(63, 220, 210, 14%), transparent 34%),
			radial-gradient(circle at 88% 86%, rgba(80, 105, 232, 16%), transparent 38%),
			linear-gradient(145deg, rgba(8, 31, 39, 62%), rgba(7, 17, 35, 46%));
		padding: 1.1rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 16%),
			inset 0 -1px 0 rgba(0, 0, 0, 18%),
			0 28px 70px rgba(2, 15, 32, 38%);
		text-align: left;
		-webkit-backdrop-filter: blur(26px) saturate(145%);
		backdrop-filter: blur(26px) saturate(145%);
	}

	.cluster-body {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.78rem;
		align-items: stretch;
	}

	.cluster-head,
	.device-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.log-line {
		display: grid;
		grid-template-columns: 4.9rem 4.4rem minmax(0, 1fr) 6.1rem 4.5rem;
		align-items: center;
		gap: 0.75rem;
	}

	.cluster-head {
		margin-bottom: 0.85rem;
		color: #dcfffa;
	}

	.cluster-title,
	.live-pill,
	.device-id,
	.lt,
	.lc {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.cluster-title {
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.02em;
	}

	.live-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 999px;
		background: rgba(46, 233, 208, 10%);
		padding: 0.25rem 0.55rem;
		color: #8dfff0;
		font-size: 0.66rem;
		font-weight: 900;
	}

	.live-dot,
	.device-dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: rgba(141, 255, 240, 42%);
		box-shadow: none;
		transition:
			background 0.35s ease,
			box-shadow 0.35s ease,
			transform 0.35s ease;
	}

	.live-dot {
		background: var(--accent);
		box-shadow: 0 0 0 5px rgba(0, 201, 170, 12%);
		animation: live-pulse 1.35s ease-in-out infinite;
	}

	.device-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.device-card {
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(205, 220, 226, 18%);
		border-radius: 8px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 10%), rgba(215, 228, 235, 4%));
		padding: 0.75rem;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 18%),
			inset 0 -1px 0 rgba(0, 0, 0, 16%),
			0 10px 24px rgba(0, 8, 18, 20%);
		-webkit-backdrop-filter: blur(14px) saturate(112%);
		backdrop-filter: blur(14px) saturate(112%);
		transition:
			border-color 0.35s ease,
			background 0.35s ease,
			box-shadow 0.35s ease,
			transform 0.35s ease;
	}

	.device-card::before {
		content: '';
		position: absolute;
		top: 0;
		right: 8%;
		left: 8%;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 58%), transparent);
		opacity: 0.58;
		pointer-events: none;
	}

	.device-card.active {
		border-color: #7f77dd;
		background:
			radial-gradient(circle at 88% 0, rgba(188, 182, 255, 28%), transparent 44%),
			linear-gradient(155deg, rgba(127, 119, 221, 24%), rgba(20, 28, 52, 16%));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 42%),
			inset 0 0 24px rgba(127, 119, 221, 18%),
			0 0 0 1px rgba(127, 119, 221, 24%),
			0 0 28px rgba(127, 119, 221, 48%),
			0 16px 32px rgba(1, 7, 22, 32%);
		-webkit-backdrop-filter: blur(22px) saturate(150%);
		backdrop-filter: blur(22px) saturate(150%);
		transform: translateY(-1px);
	}

	.device-card.active::before {
		opacity: 1;
		background: linear-gradient(90deg, transparent, rgba(235, 232, 255, 88%), transparent);
	}

	.device-card.active .device-dot {
		background: #c4bfff;
		box-shadow:
