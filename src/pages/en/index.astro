---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_COPY } from '../../i18n';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const featuredIndex = featuredPost ? posts.findIndex((post) => post.id === featuredPost.id) : 0;
const latestPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);
const frameworks = [
	['ops', 'Operations Playbooks', 'Scaling accounts, team workflows, and delivery stability'],
	['platform', 'Platform Guides', 'Execution differences across TikTok, Instagram, Reddit, and X'],
	['product', 'Product Capabilities', 'Accounts, proxies, files, tasks, and usage management'],
	['insights', 'Global Growth', 'Localization, multi-market scale, and brand expansion'],
];
const topics = ['Operations Playbooks', 'Platform Guides', 'Product Capabilities', 'Global Growth', 'Task Reviews', 'Tutorials'];
const clusterDevices = [
	{ id: 'DE-001', platform: 'TikTok', task: 'standby', active: false },
	{ id: 'FR-002', platform: 'Instagram', task: 'standby', active: false },
	{ id: 'UK-003', platform: 'Reddit', task: 'asset sync → Reddit', active: true },
	{ id: 'US-004', platform: 'X', task: 'data sync → X', active: true },
	{ id: 'JP-005', platform: 'TikTok', task: 'render video → TikTok', active: true },
	{ id: 'BR-006', platform: 'Instagram', task: 'standby', active: false },
	{ id: 'ES-007', platform: 'Reddit', task: 'standby', active: false },
	{ id: 'IT-008', platform: 'X', task: 'standby', active: false },
];
const clusterLogs = [
	['11:02:25', 'IT-008', 'data sync', 'Instagram', 'done'],
	['11:02:27', 'BR-006', 'data sync', 'Instagram', 'done'],
	['11:25:41', 'US-004', 'post draft', 'X', 'done'],
	['11:25:44', 'JP-005', 'render video', 'TikTok', 'running'],
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_COPY.en.title} description={SITE_COPY.en.description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero" id="home-hero">
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<span class="hero-cursor-glow" aria-hidden="true"></span>
				<div class="hero-copy">
					<span class="section-kicker">From the Ainnc Team</span>
					<h1>Practical Methods for Scaling Social Account Operations</h1>
					<p>
						For agencies, MCNs, and global brand teams managing hundreds or thousands of
						accounts across TikTok, Instagram, Reddit, and X.
					</p>
					<div class="hero-stats" aria-label="Blog content overview">
						<span><strong>{posts.length}</strong>articles</span>
						<span><strong>4</strong>themes</span>
						<span><strong>1</strong>operations layer</span>
					</div>
				</div>
				<div class="cluster-wrap" aria-label="Ainnc cloud account cluster preview">
					<div class="cluster-panel">
						<div class="cluster-head">
							<span class="cluster-title">Cloud account cluster · Live tasks</span>
							<span class="live-pill"><span class="live-dot"></span>RUNNING</span>
						</div>
						<div class="cluster-body">
							<div class="device-grid">
								{
									clusterDevices.map((device, index) => (
										<div
											class:list={['device-card', { active: device.active }]}
											style={`--delay: ${index * 0.16}s`}
											data-device-card
											data-device-id={device.id}
											data-index={index}
										>
											<div class="device-top">
												<span class="device-id">{device.id}</span>
												<span class="device-dot"></span>
											</div>
											<p class="device-status">{device.task}</p>
											<span class="device-trace"></span>
										</div>
									))
								}
							</div>
							<div class="log-panel">
								<div class="log-track" data-log-track>
									{
										clusterLogs.map(([time, device, action, platform, status], index) => (
											<div class="log-line" style={`--delay: ${index * 0.18}s`}>
												<span class="lt">{time}</span>
												<span class="ld">{device}</span>
												<span class="la">{action}</span>
												<span class="lp">{platform}</span>
												<span class="lc">✓ {status}</span>
											</div>
										))
									}
								</div>
							</div>
						</div>
						<div class="cluster-stats">
							<span><strong data-live-count>2,866</strong>weekly published items</span>
							<span><strong>12</strong>covered time zones</span>
							<span><strong>99.6%</strong>environment uptime</span>
						</div>
					</div>
				</div>
				<div class="hero-ticker" aria-hidden="true">
					<div class="ticker-track">
						<span class="ticker-icon" data-platform="tiktok">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M14.5 4v10.1a4.3 4.3 0 1 1-3.2-4.2v3.1a1.5 1.5 0 1 0 1 1.4V4h2.2c.3 2.1 1.7 3.8 3.8 4.3v3.1a7 7 0 0 1-3.8-1.3z" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="instagram">
							<svg viewBox="0 0 24 24" focusable="false">
								<rect x="5" y="5" width="14" height="14" rx="4" />
								<circle cx="12" cy="12" r="3.2" />
								<circle cx="16.6" cy="7.4" r="1" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="reddit">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M8 12.2a5.9 5.9 0 0 1 8 0 3.1 3.1 0 0 1 2.3-.8 2.2 2.2 0 0 1 .6 4.2c-.3 3-3.2 5.3-6.9 5.3s-6.6-2.3-6.9-5.3a2.2 2.2 0 0 1 .6-4.2 3.1 3.1 0 0 1 2.3.8z" />
								<path d="M12.7 7.3h3.1l.5-2.2 2.6.6" />
								<circle cx="9.6" cy="15.3" r=".8" />
								<circle cx="14.4" cy="15.3" r=".8" />
								<path d="M10.1 17.4a4.6 4.6 0 0 0 3.8 0" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="x">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M5 5l14 14M19 5 5 19" />
							</svg>
						</span>
						<span>CLOUD PHONE</span>
						<span>PROXY IP</span>
						<span>ASSET FILES</span>
						<span>TASK QUEUE</span>
						<span class="ticker-icon" data-platform="tiktok">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M14.5 4v10.1a4.3 4.3 0 1 1-3.2-4.2v3.1a1.5 1.5 0 1 0 1 1.4V4h2.2c.3 2.1 1.7 3.8 3.8 4.3v3.1a7 7 0 0 1-3.8-1.3z" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="instagram">
							<svg viewBox="0 0 24 24" focusable="false">
								<rect x="5" y="5" width="14" height="14" rx="4" />
								<circle cx="12" cy="12" r="3.2" />
								<circle cx="16.6" cy="7.4" r="1" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="reddit">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M8 12.2a5.9 5.9 0 0 1 8 0 3.1 3.1 0 0 1 2.3-.8 2.2 2.2 0 0 1 .6 4.2c-.3 3-3.2 5.3-6.9 5.3s-6.6-2.3-6.9-5.3a2.2 2.2 0 0 1 .6-4.2 3.1 3.1 0 0 1 2.3.8z" />
								<path d="M12.7 7.3h3.1l.5-2.2 2.6.6" />
								<circle cx="9.6" cy="15.3" r=".8" />
								<circle cx="14.4" cy="15.3" r=".8" />
								<path d="M10.1 17.4a4.6 4.6 0 0 0 3.8 0" />
							</svg>
						</span>
						<span class="ticker-icon" data-platform="x">
							<svg viewBox="0 0 24 24" focusable="false">
								<path d="M5 5l14 14M19 5 5 19" />
							</svg>
						</span>
						<span>CLOUD PHONE</span>
						<span>PROXY IP</span>
						<span>ASSET FILES</span>
						<span>TASK QUEUE</span>
					</div>
				</div>
			</section>

			<section class="framework-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">Content Framework</span>
						<h2>From Operational Problems to Product Capabilities</h2>
					</div>
					<p>A quick map for understanding Ainnc's product capabilities and editorial direction.</p>
				</div>
				<div class="framework-grid">
					{
						frameworks.map(([tone, title, description]) => (
							<article class="framework-card" data-tone={tone}>
								<h3>{title}</h3>
								<p>{description}</p>
							</article>
						))
					}
				</div>
			</section>

			{
				featuredPost && (
					<section class="featured-section">
						<div class="section-header">
							<div>
								<span class="eyebrow">Featured</span>
								<h2>Start Here</h2>
							</div>
							<p>Build a first-layer understanding of scaled social operations, account matrices, and Ainnc workflows.</p>
						</div>
						<PostCard post={featuredPost} featured index={featuredIndex} locale="en" />
					</section>
				)
			}

			<section class="latest-section">
				<div class="section-header">
					<div>
						<span class="eyebrow">Latest</span>
						<h2>Operations Guides</h2>
					</div>
					<a href="/en/blog/">All Articles</a>
				</div>
				<div class="post-grid">
					{latestPosts.map((post) => <PostCard post={post} index={posts.findIndex((item) => item.id === post.id)} locale="en" />)}
				</div>
			</section>

			<section class="topics panel">
				<div>
					<span class="eyebrow">Editorial Plan</span>
					<h2>Topics We Will Keep Expanding</h2>
				</div>
				<ul>
					{topics.map((topic) => <li>{topic}</li>)}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			const hero = document.getElementById('home-hero');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (hero && supportsHover) {
				hero.addEventListener('pointermove', (event) => {
					const rect = hero.getBoundingClientRect();
					const shiftX = ((event.clientX - rect.left) / rect.width - 0.5) * 22;
					const shiftY = ((event.clientY - rect.top) / rect.height - 0.5) * 18;
					hero.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
					hero.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
					hero.style.setProperty('--shift-x', `${shiftX}px`);
					hero.style.setProperty('--shift-y', `${shiftY}px`);
					hero.classList.add('is-glowing');
				});
				hero.addEventListener('pointerleave', () => {
					hero.classList.remove('is-glowing');
					hero.style.setProperty('--shift-x', '0px');
					hero.style.setProperty('--shift-y', '0px');
				});
			}

			const liveTasks = [
				['UK-003', 'asset sync', 'Reddit', 'running'],
				['US-004', 'data sync', 'X', 'done'],
				['JP-005', 'render video', 'TikTok', 'running'],
				['BR-006', 'account check', 'Instagram', 'done'],
				['DE-001', 'queue dispatch', 'TikTok', 'done'],
				['ES-007', 'comment review', 'Reddit', 'running'],
				['FR-002', 'asset ingest', 'Instagram', 'done'],
				['IT-008', 'data sync', 'X', 'done'],
			];
			const taskCards = Array.from(document.querySelectorAll<HTMLElement>('[data-device-card]'));
			const logTrack = document.querySelector<HTMLElement>('[data-log-track]');
			const liveCount = document.querySelector<HTMLElement>('[data-live-count]');
			let liveTaskIndex = 0;
			let publishedCount = 2866;
			const activeDevices = new Set(['UK-003', 'US-004', 'JP-005']);
			const taskLabels = new Map(liveTasks.map(([device, action, platform]) => [device, `${action} → ${platform}`]));

			const formatTime = () => new Date().toLocaleTimeString('en-US', { hour12: false });
			const updateLiveTasks = () => {
				const [device, action, platform, status] = liveTasks[liveTaskIndex % liveTasks.length];
				liveTaskIndex += 1;
				activeDevices.add(device);
				while (activeDevices.size > 3) {
					const oldestDevice = activeDevices.values().next().value;
					if (oldestDevice) {
						activeDevices.delete(oldestDevice);
					}
				}

				taskCards.forEach((card) => {
					const id = card.dataset.deviceId ?? '';
					const statusNode = card.querySelector<HTMLElement>('.device-status');
					const isActive = activeDevices.has(id);
					card.classList.toggle('active', isActive);
					card.style.setProperty('--trace-width', `${18 + ((liveTaskIndex + Number(card.dataset.index ?? 0)) % 3) * 12}%`);
					if (statusNode) {
						statusNode.textContent = isActive ? taskLabels.get(id) ?? 'processing task' : 'standby';
					}
				});

				if (logTrack) {
					const template = logTrack.querySelector<HTMLElement>('.log-line');
					const row = template ? (template.cloneNode(true) as HTMLElement) : document.createElement('div');
					row.className = 'log-line is-new';
					if (template) {
						const cells = row.querySelectorAll('span');
						const values = [formatTime(), device, action, platform, `✓ ${status}`];
						cells.forEach((cell, index) => {
							cell.textContent = values[index] ?? '';
						});
					} else {
						row.innerHTML = `<span class="lt">${formatTime()}</span><span class="ld">${device}</span><span class="la">${action}</span><span class="lp">${platform}</span><span class="lc">✓ ${status}</span>`;
					}
					logTrack.appendChild(row);
					if (logTrack.children.length > 4) {
						const first = logTrack.firstElementChild as HTMLElement | null;
						first?.classList.add('is-removing');
						window.setTimeout(() => first?.remove(), 420);
					}
					window.setTimeout(() => row.classList.remove('is-new'), 700);
				}

				if (liveCount) {
					publishedCount += 1;
					liveCount.textContent = publishedCount.toLocaleString('en-US');
				}
			};

			window.setInterval(updateLiveTasks, 1850);

			document.querySelectorAll<HTMLElement>('.ticker-track').forEach((track) => {
				requestAnimationFrame(() => {
					const loopDistance = track.scrollWidth / 2;
					track.style.setProperty('--ticker-distance', `${loopDistance}px`);
					const items = Array.from(track.children);
					items.forEach((item) => track.appendChild(item.cloneNode(true)));
				});
			});
		</script>
	</body>
</html>

<style>
	.home-hero {
		--glow-x: 50%;
		--glow-y: 50%;
		--shift-x: 0px;
		--shift-y: 0px;
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 760px;
		align-content: center;
		justify-items: center;
		overflow: hidden;
		margin-bottom: 4rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 76%) 0, rgba(255, 255, 255, 38%) 45%, rgba(255, 255, 255, 76%) 100%),
			linear-gradient(135deg, rgba(0, 201, 170, 16%), rgba(60, 110, 159, 8%) 48%, rgba(0, 69, 76, 5%)),
			white;
		box-shadow: 0 24px 70px rgba(0, 69, 76, 12%);
		text-align: center;
	}

	.home-hero::before {
		content: '';
		position: absolute;
		inset: 1rem;
		z-index: 0;
		border: 1px solid rgba(0, 201, 170, 16%);
		border-radius: 8px;
		pointer-events: none;
	}

	.hero-watermark {
		position: absolute;
		top: -7rem;
		right: -5rem;
		z-index: 0;
		width: min(50rem, 58vw);
		opacity: 0.07;
		filter: grayscale(1) brightness(0.45);
		transform: translate3d(var(--shift-x), var(--shift-y), 0) rotate(-7deg);
		transition: transform 0.18s ease-out;
	}

	.hero-cursor-glow {
		position: absolute;
		z-index: 1;
		inset: -14%;
		background: radial-gradient(circle 280px at var(--glow-x) var(--glow-y), rgba(46, 233, 208, 30%), rgba(0, 201, 170, 12%) 34%, transparent 72%);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.home-hero.is-glowing .hero-cursor-glow {
		opacity: 1;
	}

	.hero-copy {
		position: relative;
		z-index: 3;
		display: grid;
		max-width: 760px;
		gap: 1rem;
		padding: clamp(2rem, 5vw, 4rem) 1rem 1.25rem;
		justify-items: center;
	}

	.hero-ticker span {
		display: inline-flex;
		align-items: center;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.hero-ticker .ticker-icon {
		justify-content: center;
		width: 1.72rem;
		height: 1.72rem;
		border: 1px solid rgba(0, 201, 170, 20%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 62%);
		color: rgba(0, 125, 118, 76%);
		box-shadow: 0 8px 18px rgba(0, 125, 118, 8%);
	}

	.ticker-icon svg {
		width: 1rem;
		height: 1rem;
	}

	.ticker-icon svg :where(path, rect, circle) {
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.ticker-icon[data-platform='tiktok'] svg path {
		fill: currentColor;
		stroke: none;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.hero-copy p {
		max-width: 640px;
		font-size: 1.08rem;
	}

	.hero-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.hero-stats {
		margin-top: 0.25rem;
		color: var(--muted);
		font-weight: 800;
	}

	.hero-stats span {
		border: 1px solid rgba(0, 201, 170, 28%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 72%);
		padding: 0.45rem 0.8rem;
	}

	.hero-stats strong {
		margin-right: 0.2rem;
		color: var(--text);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.cluster-wrap {
		position: relative;
		z-index: 4;
		width: min(960px, calc(100% - 2rem));
		margin-bottom: 3.25rem;
		transform: translate3d(calc(var(--shift-x) * 0.25), calc(var(--shift-y) * 0.25), 0);
		transition: transform 0.18s ease-out;
	}

	.cluster-panel {
		overflow: hidden;
		border: 1px solid rgba(46, 233, 208, 20%);
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(4, 36, 38, 92%), rgba(5, 54, 52, 88%)),
			#06272a;
		padding: 1.1rem;
		box-shadow: 0 24px 60px rgba(0, 69, 76, 22%);
		text-align: left;
		backdrop-filter: blur(18px);
	}

	.cluster-body {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.78rem;
		align-items: stretch;
	}

	.cluster-head,
	.device-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.log-line {
		display: grid;
		grid-template-columns: 4.9rem 4.4rem minmax(0, 1fr) 6.1rem 4.5rem;
		align-items: center;
		gap: 0.75rem;
	}

	.cluster-head {
		margin-bottom: 0.85rem;
		color: #dcfffa;
	}

	.cluster-title,
	.live-pill,
	.device-id,
	.lt,
	.lc {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.cluster-title {
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.02em;
	}

	.live-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 999px;
		background: rgba(46, 233, 208, 10%);
		padding: 0.25rem 0.55rem;
		color: #8dfff0;
		font-size: 0.66rem;
		font-weight: 900;
	}

	.live-dot,
	.device-dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: rgba(141, 255, 240, 42%);
		box-shadow: none;
		transition:
			background 0.35s ease,
			box-shadow 0.35s ease,
			transform 0.35s ease;
	}

	.live-dot {
		background: var(--accent);
		box-shadow: 0 0 0 5px rgba(0, 201, 170, 12%);
		animation: live-pulse 1.35s ease-in-out infinite;
	}

	.device-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.device-card {
		position: relative;
		border: 1px solid rgba(255, 255, 255, 8%);
		border-radius: 8px;
		background: rgba(255, 255, 255, 6%);
		padding: 0.75rem;
		transition:
			border-color 0.35s ease,
			background 0.35s ease,
			box-shadow 0.35s ease,
			transform 0.35s ease;
	}

	.device-card.active {
