---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const capabilities = [
	['ops', '云手机环境管理', '每个账号独立云端环境，设备与网络配置统一管理。'],
	['platform', '批量账号与代理', '静态、动态、移动代理统一分配，账号分组管理。'],
	['product', 'AI 内容创作中心', '生成多风格文案与标签，素材库统一管理。'],
	['insights', '任务中心自动化', '登录、养号、发布批量执行，全流程可追溯。'],
];
const audiences = [
	['ops', '跨境电商卖家', '每个市场都要开账号、切设备、倒时差、排内容。Ainnc 用独立云端环境统一承载所有账号，按目标市场时区组织发布。'],
	['platform', 'MCN / 代运营机构', '签约账号越多，维护和排期越吃人力。用批量素材、队列发布和统一看板，把重复劳动交给系统。'],
	['insights', '品牌出海团队', '没有海外团队、没有本地内容、没有设备时，可以围绕账号搭建、内容生成、发布排期和数据复盘建立标准流程。'],
	['product', '为什么是基础设施', '账号、代理、素材、任务共用同一套记录，而不是分散在表格、网盘和聊天工具里。规模变大时，系统不会跟着变乱。'],
];
const proofStats = [
	['3', '+', '海外社媒运营经验'],
	['10000', '+', '托管中的账号环境'],
	['4', '', '主流社媒平台支持'],
	['7', 'x24', '云端自动化运行'],
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="关于 Ainnc" description="Ainnc 是面向跨境社媒运营团队的账号、代理、素材和任务管理基础设施。" />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero" id="about-hero">
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<span class="hero-cursor-glow" aria-hidden="true"></span>
				<div class="hero-copy">
					<span class="section-kicker">ABOUT AINNC</span>
					<h1>一套面向跨境团队的社媒运营基础设施</h1>
					<p>
						Ainnc 不是单一发帖工具，而是让账号、代理、素材、任务共用同一套系统的运营底座，
						服务于需要规模化管理社媒账号的团队。
					</p>
				</div>
				<div class="proof-panel" aria-label="Ainnc 服务规模">
					<div class="proof-head">
						<span>麦芽营销 · 服务规模</span>
						<em>TRACK RECORD</em>
					</div>
					<div class="proof-grid">
						{
							proofStats.map(([value, suffix, label]) => (
								<div class="proof-cell">
									<strong class="count-up" data-count={value} data-suffix={suffix}>0{suffix}</strong>
									<span>{label}</span>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="about-detail-section" aria-label="Ainnc 受众与产品能力">
				<div class="audience-grid" data-audience-reveal>
					{
						audiences.map(([tone, title, description]) => (
							<article class="audience-item" data-tone={tone}>
								<h2>{title}</h2>
								<p>{description}</p>
							</article>
						))
					}
				</div>

				<div class="capability-shell" data-capability-reveal>
					<div class="capability-header">
						<div class="capability-title">
							<span class="eyebrow">产品能力</span>
							<h2>一个控制台覆盖账号管理到内容发布</h2>
						</div>
						<p>面向 TikTok、Instagram、Reddit、X 等平台的规模化运营场景。</p>
					</div>
					<div class="capability-grid">
						{
							capabilities.map(([tone, title, description]) => (
								<article class="capability-item" data-tone={tone}>
									<h3>{title}</h3>
									<p>{description}</p>
								</article>
							))
						}
					</div>
					<div class="detail-stats" aria-label="Ainnc 概览">
						<div class="detail-stat">
							<strong class="detail-stat-number" data-detail-count="4" data-duration="700">0</strong>
							<span>覆盖平台</span>
						</div>
						<div class="detail-stat">
							<strong class="detail-stat-number" data-detail-count="3" data-duration="600">0</strong>
							<span>核心使用场景</span>
						</div>
						<div class="detail-stat">
							<strong class="detail-stat-number accent" data-detail-count="1" data-duration="500" data-pad="2">00</strong>
							<span>统一控制台</span>
						</div>
					</div>
				</div>
			</section>

			<a class="blog-cta" href="/blog/">
				<span>READ MORE / BLOG</span>
				<strong>去博客看代运营机构的实战方法</strong>
				<em>查看全部文章 -&gt;</em>
			</a>
		</main>
		<Footer />
		<script>
			const hero = document.getElementById('about-hero');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (hero && supportsHover) {
				hero.addEventListener('pointermove', (event) => {
					const rect = hero.getBoundingClientRect();
					hero.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
					hero.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
					hero.classList.add('is-glowing');
				});
				hero.addEventListener('pointerleave', () => hero.classList.remove('is-glowing'));
			}

			const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const counters = document.querySelectorAll<HTMLElement>('.count-up');

			const finishCounter = (counter: HTMLElement) => {
				counter.textContent = `${counter.dataset.count ?? '0'}${counter.dataset.suffix ?? ''}`;
			};

			const animateCounter = (counter: HTMLElement) => {
				const target = Number(counter.dataset.count ?? 0);
				const suffix = counter.dataset.suffix ?? '';
				const duration = 1400;
				const start = performance.now();

				const tick = (now: number) => {
					const progress = Math.min(1, (now - start) / duration);
					const eased = 1 - Math.pow(1 - progress, 3);
					counter.textContent = `${Math.round(target * eased)}${suffix}`;

					if (progress < 1) {
						window.requestAnimationFrame(tick);
					} else {
						finishCounter(counter);
					}
				};

				window.requestAnimationFrame(tick);
			};

			if (reducedMotion || !('IntersectionObserver' in window)) {
				counters.forEach(finishCounter);
			} else {
				const counterObserver = new IntersectionObserver(
					(entries, observer) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							const counter = entry.target as HTMLElement;
							animateCounter(counter);
							observer.unobserve(counter);
						});
					},
					{ threshold: 0.45 },
				);

				counters.forEach((counter) => counterObserver.observe(counter));
			}

			const detailSection = document.querySelector<HTMLElement>('.about-detail-section');
			const audienceGroup = document.querySelector<HTMLElement>('[data-audience-reveal]');
			const capabilityGroup = document.querySelector<HTMLElement>('[data-capability-reveal]');
			const audienceItems = Array.from(document.querySelectorAll<HTMLElement>('.audience-item'));
			const capabilityItems = Array.from(document.querySelectorAll<HTMLElement>('.capability-item'));
			const detailCounters = Array.from(document.querySelectorAll<HTMLElement>('.detail-stat-number'));

			const formatDetailValue = (value: number, pad: number) => String(value).padStart(pad, '0');
			const finishDetailCounter = (counter: HTMLElement) => {
				const target = Number(counter.dataset.detailCount ?? 0);
				const pad = Number(counter.dataset.pad ?? 1);
				counter.textContent = formatDetailValue(target, pad);
			};
			const animateDetailCounter = (counter: HTMLElement) => {
				if (counter.dataset.counted === 'true') return;
				counter.dataset.counted = 'true';
				const target = Number(counter.dataset.detailCount ?? 0);
				const duration = Number(counter.dataset.duration ?? 600);
				const pad = Number(counter.dataset.pad ?? 1);
				const start = performance.now();

				const tick = (now: number) => {
					const progress = Math.min(1, (now - start) / duration);
					const eased = 1 - Math.pow(1 - progress, 3);
					counter.textContent = formatDetailValue(Math.round(target * eased), pad);
					if (progress < 1) window.requestAnimationFrame(tick);
				};

				window.requestAnimationFrame(tick);
			};
			const revealSequence = (items: HTMLElement[], delays: number[]) => {
				items.forEach((item, index) => {
					const delay = delays[index] ?? 0;
					window.setTimeout(() => {
						item.classList.add('is-visible');
						window.setTimeout(() => item.classList.add('reveal-complete'), 560);
					}, delay);
				});
			};

			if (reducedMotion || !('IntersectionObserver' in window)) {
				detailCounters.forEach(finishDetailCounter);
			} else if (detailSection) {
				detailSection.classList.add('motion-ready');
				if (audienceGroup) {
					const audienceObserver = new IntersectionObserver(
						(entries, observer) => {
							if (!entries.some((entry) => entry.isIntersecting)) return;
							revealSequence(audienceItems, [50, 150, 250, 350]);
							observer.disconnect();
						},
						{ threshold: 0.18 },
					);
					audienceObserver.observe(audienceGroup);
				}
				if (capabilityGroup) {
					const capabilityObserver = new IntersectionObserver(
						(entries, observer) => {
							if (!entries.some((entry) => entry.isIntersecting)) return;
							revealSequence(capabilityItems, [100, 220, 340, 460]);
							detailCounters.forEach(animateDetailCounter);
							observer.disconnect();
						},
						{ threshold: 0.2 },
					);
					capabilityObserver.observe(capabilityGroup);
				}
			}
		</script>
	</body>
</html>

<style>
	.about-hero {
		--glow-x: 50%;
		--glow-y: 50%;
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 640px;
		align-content: center;
		justify-items: center;
		overflow: hidden;
		margin-bottom: 2rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(0, 201, 170, 10%), rgba(0, 69, 76, 5%)),
			white;
		box-shadow: var(--shadow);
		text-align: center;
	}

	.hero-watermark {
		position: absolute;
		top: -5rem;
		right: -6rem;
		z-index: 0;
		width: min(42rem, 68vw);
		opacity: 0.05;
		filter: grayscale(1) brightness(0.45);
		transform: rotate(-7deg);
	}

	.hero-cursor-glow {
		position: absolute;
		z-index: 1;
		inset: -14%;
		background: radial-gradient(circle 280px at var(--glow-x) var(--glow-y), rgba(46, 233, 208, 30%), rgba(0, 201, 170, 12%) 34%, transparent 72%);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.about-hero.is-glowing .hero-cursor-glow {
		opacity: 1;
	}

	.hero-copy {
		position: relative;
		z-index: 2;
		display: grid;
		max-width: 760px;
		gap: 1rem;
		padding: clamp(2rem, 5vw, 4rem) 1rem 1.1rem;
		justify-items: center;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.hero-copy p {
		max-width: 640px;
		font-size: 1.08rem;
	}

	.proof-panel {
		position: relative;
		z-index: 3;
		width: min(760px, calc(100% - 2rem));
		overflow: hidden;
		border: 1px solid rgba(46, 233, 208, 20%);
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(4, 36, 38, 92%), rgba(5, 54, 52, 88%)),
			#06272a;
		padding: 1rem;
		box-shadow: 0 24px 60px rgba(0, 69, 76, 22%);
		text-align: left;
		backdrop-filter: blur(18px);
	}

	.proof-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.85rem;
		color: #dcfffa;
	}

	.proof-head span,
	.proof-head em,
	.proof-cell strong {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.proof-head span {
		font-size: 0.78rem;
		font-weight: 900;
	}

	.proof-head em {
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 999px;
		background: rgba(46, 233, 208, 10%);
		padding: 0.25rem 0.55rem;
		color: #8dfff0;
		font-size: 0.66rem;
		font-style: normal;
		font-weight: 900;
	}

	.proof-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.proof-cell {
		border: 1px solid rgba(255, 255, 255, 8%);
		border-radius: 8px;
		background: rgba(255, 255, 255, 6%);
		padding: 0.9rem;
	}

	.proof-cell strong,
	.proof-cell span {
		display: block;
	}

	.proof-cell strong {
		color: #e8fffb;
		font-size: clamp(1.35rem, 2.2vw, 2rem);
		line-height: 1;
	}

	.proof-cell span {
		margin-top: 0.55rem;
		color: rgba(232, 255, 251, 70%);
		font-size: 0.78rem;
		font-weight: 800;
	}

	.about-detail-section {
		margin-bottom: 2rem;
	}

	.audience-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 36px 48px;
		margin-bottom: 64px;
	}

	.audience-item,
	.capability-item {
		--item-accent: var(--tone-ops);
	}

	.audience-item[data-tone='platform'],
	.capability-item[data-tone='platform'] {
		--item-accent: var(--tone-platform);
	}

	.audience-item[data-tone='product'],
	.capability-item[data-tone='product'] {
		--item-accent: var(--tone-product);
	}

	.audience-item[data-tone='insights'],
	.capability-item[data-tone='insights'] {
		--item-accent: var(--tone-insights);
	}

	.audience-item {
		position: relative;
		margin-left: -16px;
		border-radius: 10px;
		padding: 4px 16px;
		cursor: pointer;
		transition:
			background 0.25s ease,
			transform 0.25s ease;
	}

	.audience-item::before {
		content: '';
		position: absolute;
		top: 4px;
		bottom: 4px;
		left: 0;
		width: 2px;
		border-radius: 2px;
		background: var(--item-accent);
		transition: width 0.25s ease;
	}

	.audience-item:hover {
		background: rgba(255, 255, 255, 86%);
		transform: translateX(4px);
	}

	.audience-item:hover::before {
		width: 3px;
	}

	.audience-item h2 {
		font-size: 15px;
		font-weight: 700;
	}

	.audience-item p {
		margin-top: 6px;
		color: #5b6e6c;
		font-size: 13px;
		line-height: 1.7;
	}

	.capability-shell {
		border-radius: 24px;
		background: white;
		padding: 48px 44px;
		box-shadow: 0 4px 24px rgba(6, 39, 42, 6%);
	}

	.capability-header {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 36px;
	}

	.capability-title {
		display: grid;
		gap: 14px;
	}

	.capability-title h2 {
		max-width: 680px;
		font-size: 26px;
		font-weight: 900;
		line-height: 1.2;
	}

	.capability-header p {
		max-width: 280px;
		color: #5b6e6c;
		font-size: 13px;
		line-height: 1.7;
	}

	.capability-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 20px;
		margin-bottom: 36px;
	}

	.capability-item {
		position: relative;
		margin: 0 -14px;
		border-radius: 12px;
		padding: 18px 14px 14px;
		cursor: pointer;
		transition:
			background 0.25s ease,
			box-shadow 0.25s ease,
			transform 0.25s ease;
	}

	.capability-item::before {
		content: '';
		position: absolute;
		top: 0;
		right: 14px;
		left: 14px;
		height: 2px;
		background: var(--item-accent);
		transform: scaleX(1);
		transform-origin: left;
		transition: transform 0.25s ease;
	}

	.capability-item:hover {
		background: #f5fcfb;
		box-shadow: 0 12px 24px rgba(6, 39, 42, 8%);
		transform: translateY(-4px);
	}

	.capability-item:hover::before {
		transform: scaleX(1.15);
	}

	.capability-item h3 {
		font-size: 15px;
		font-weight: 700;
	}

	.capability-item p {
		margin-top: 8px;
		color: #5b6e6c;
		font-size: 12px;
		line-height: 1.6;
	}

	.detail-stats {
		display: flex;
		align-items: center;
		border-top: 1px solid #eef6f4;
		padding-top: 24px;
	}

	.detail-stat {
		display: flex;
		align-items: baseline;
		gap: 6px;
		border-right: 1px solid #eef6f4;
		padding: 0 32px;
	}

	.detail-stat:first-child {
		padding-left: 0;
	}

	.detail-stat:last-child {
		border-right: 0;
		padding-right: 0;
	}

	.detail-stat-number {
		display: inline-block;
		color: #06272a;
		font-family: 'Space Grotesk', sans-serif;
		font-size: 22px;
		font-weight: 700;
		line-height: 1;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.detail-stat-number.accent {
		color: #00b1b3;
	}

	.detail-stat span {
		color: #7a8e8b;
		font-size: 12px;
	}

	.detail-stat:hover .detail-stat-number {
		color: #00b1b3;
		transform: translateY(-2px);
	}

	.motion-ready .audience-item,
	.motion-ready .capability-item {
		opacity: 0;
		transform: translateY(12px);
	}

	.motion-ready .audience-item.is-visible,
	.motion-ready .capability-item.is-visible {
		animation: detail-fade-up 0.55s ease forwards;
	}

	.motion-ready .audience-item.reveal-complete,
	.motion-ready .capability-item.reveal-complete {
		opacity: 1;
		transform: none;
		animation: none;
	}

	.motion-ready .capability-item::before {
		transform: scaleX(0);
		transition-duration: 0.9s;
		transition-timing-function: ease-out;
	}

	.motion-ready .capability-item.is-visible::before {
		transform: scaleX(1);
	}

	.motion-ready .audience-item.reveal-complete:hover {
		transform: translateX(4px);
	}

	.motion-ready .capability-item.reveal-complete:hover {
		transform: translateY(-4px);
	}

	.motion-ready .capability-item.reveal-complete:hover::before {
		transform: scaleX(1.15);
	}

	@keyframes detail-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.blog-cta {
		position: relative;
		display: grid;
		gap: 0.75rem;
		overflow: hidden;
		margin-bottom: 2rem;
		border-radius: 8px;
		background: linear-gradient(135deg, #04302e, #06403c 55%, #0a5049);
		padding: 2rem;
		color: white;
		text-decoration: none;
	}

	.blog-cta::before {
		content: '';
		position: absolute;
		top: -8rem;
		right: -4rem;
		width: 22rem;
		height: 22rem;
		border-radius: 999px;
		background: radial-gradient(circle, rgba(46, 233, 208, 28%), transparent 70%);
	}

	.blog-cta span,
	.blog-cta strong,
	.blog-cta em {
		position: relative;
		z-index: 1;
	}

	.blog-cta span {
		color: var(--accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.blog-cta strong {
		max-width: 660px;
		font-size: clamp(1.55rem, 3vw, 2rem);
	}

	.blog-cta em {
		color: #b8eee7;
		font-style: normal;
		font-weight: 900;
	}

	@media (max-width: 900px) {
		.capability-header {
			align-items: flex-start;
			gap: 12px;
		}

		.capability-header p {
			max-width: 100%;
		}

		.audience-grid,
		.proof-grid {
			grid-template-columns: 1fr;
		}

		.audience-grid {
			gap: 24px;
			margin-bottom: 48px;
		}

		.capability-shell {
