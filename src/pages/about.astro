---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const capabilities = [
	['ops', '云手机环境管理', '每个账号独立云端环境，设备与网络配置统一管理。'],
	['platform', '批量账号与代理', '静态、动态、移动代理统一分配，账号分组管理。'],
	['product', 'AI 内容创作中心', '生成多风格文案与标签，素材库统一管理。'],
	['insights', '任务中心自动化', '登录、养号、发布批量执行，全流程可追溯。'],
];
const audiences = [
	['跨境电商卖家', '每个市场都要开账号、切设备、倒时差、排内容。Ainnc 用独立云端环境统一承载所有账号，按目标市场时区组织发布。'],
	['MCN / 代运营机构', '签约账号越多，维护和排期越吃人力。用批量素材、队列发布和统一看板，把重复劳动交给系统。'],
	['品牌出海团队', '没有海外团队、没有本地内容、没有设备时，可以围绕账号搭建、内容生成、发布排期和数据复盘建立标准流程。'],
	['为什么是基础设施', '账号、代理、素材、任务共用同一套记录，而不是分散在表格、网盘和聊天工具里。规模变大时，系统不会跟着变乱。'],
];
const proofStats = [
	['3+', '海外社媒运营经验'],
	['10000+', '托管中的账号环境'],
	['6', '主流社媒平台支持'],
	['7x24', '云端自动化运行'],
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="关于 Ainnc" description="Ainnc 是面向跨境社媒运营团队的账号、代理、素材和任务管理基础设施。" />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero" id="about-hero">
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<span class="hero-cursor-glow" aria-hidden="true"></span>
				<div class="hero-copy">
					<span class="section-kicker">ABOUT AINNC</span>
					<h1>一套面向跨境团队的社媒运营基础设施</h1>
					<p>
						Ainnc 不是单一发帖工具，而是让账号、代理、素材、任务共用同一套系统的运营底座，
						服务于需要规模化管理社媒账号的团队。
					</p>
				</div>
				<div class="proof-panel" aria-label="Ainnc 服务规模">
					<div class="proof-head">
						<span>麦芽营销 · 服务规模</span>
						<em>TRACK RECORD</em>
					</div>
					<div class="proof-grid">
						{
							proofStats.map(([value, label]) => (
								<div class="proof-cell">
									<strong>{value}</strong>
									<span>{label}</span>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="audience-grid">
				{
					audiences.map(([title, description]) => (
						<article class="value-card">
							<h2>{title}</h2>
							<p>{description}</p>
						</article>
					))
				}
			</section>

			<section class="capabilities">
				<div class="section-header">
					<div>
						<span class="eyebrow">产品能力</span>
						<h2>一个控制台覆盖账号管理到内容发布</h2>
					</div>
					<p>面向 TikTok、Instagram、Reddit、X 等平台的规模化运营场景。</p>
				</div>
				<div class="capability-grid">
					{
						capabilities.map(([tone, title, description]) => (
							<article class="capability-card" data-tone={tone}>
								<h3>{title}</h3>
								<p>{description}</p>
							</article>
						))
					}
				</div>
			</section>

			<section class="stats-row" aria-label="Ainnc 概览">
				<div><strong>4</strong><span>覆盖平台</span></div>
				<div><strong>3</strong><span>核心使用场景</span></div>
				<div><strong>01</strong><span>统一控制台</span></div>
			</section>

			<a class="blog-cta" href="/blog/">
				<span>READ MORE / BLOG</span>
				<strong>去博客看代运营机构的实战方法</strong>
				<em>查看全部文章 -&gt;</em>
			</a>
		</main>
		<Footer />
		<script>
			const hero = document.getElementById('about-hero');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (hero && supportsHover) {
				hero.addEventListener('pointermove', (event) => {
					const rect = hero.getBoundingClientRect();
					hero.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
					hero.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
					hero.classList.add('is-glowing');
				});
				hero.addEventListener('pointerleave', () => hero.classList.remove('is-glowing'));
			}
		</script>
	</body>
</html>

<style>
	.about-hero {
		--glow-x: 50%;
		--glow-y: 50%;
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 640px;
		align-content: center;
		justify-items: center;
		overflow: hidden;
		margin-bottom: 2rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(0, 201, 170, 10%), rgba(0, 69, 76, 5%)),
			white;
		box-shadow: var(--shadow);
		text-align: center;
	}

	.hero-watermark {
		position: absolute;
		top: -5rem;
		right: -6rem;
		z-index: 0;
		width: min(42rem, 68vw);
		opacity: 0.05;
		filter: grayscale(1) brightness(0.45);
		transform: rotate(-7deg);
	}

	.hero-cursor-glow {
		position: absolute;
		z-index: 1;
		inset: -14%;
		background: radial-gradient(circle 280px at var(--glow-x) var(--glow-y), rgba(46, 233, 208, 30%), rgba(0, 201, 170, 12%) 34%, transparent 72%);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.about-hero.is-glowing .hero-cursor-glow {
		opacity: 1;
	}

	.hero-copy {
		position: relative;
		z-index: 2;
		display: grid;
		max-width: 760px;
		gap: 1rem;
		padding: clamp(2rem, 5vw, 4rem) 1rem 1.1rem;
		justify-items: center;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.hero-copy p {
		max-width: 640px;
		font-size: 1.08rem;
	}

	.proof-panel {
		position: relative;
		z-index: 3;
		width: min(760px, calc(100% - 2rem));
		overflow: hidden;
		border: 1px solid rgba(46, 233, 208, 20%);
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(4, 36, 38, 92%), rgba(5, 54, 52, 88%)),
			#06272a;
		padding: 1rem;
		box-shadow: 0 24px 60px rgba(0, 69, 76, 22%);
		text-align: left;
		backdrop-filter: blur(18px);
	}

	.proof-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.85rem;
		color: #dcfffa;
	}

	.proof-head span,
	.proof-head em,
	.proof-cell strong {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.proof-head span {
		font-size: 0.78rem;
		font-weight: 900;
	}

	.proof-head em {
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 999px;
		background: rgba(46, 233, 208, 10%);
		padding: 0.25rem 0.55rem;
		color: #8dfff0;
		font-size: 0.66rem;
		font-style: normal;
		font-weight: 900;
	}

	.proof-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.proof-cell {
		border: 1px solid rgba(255, 255, 255, 8%);
		border-radius: 8px;
		background: rgba(255, 255, 255, 6%);
		padding: 0.9rem;
	}

	.proof-cell strong,
	.proof-cell span {
		display: block;
	}

	.proof-cell strong {
		color: #e8fffb;
		font-size: clamp(1.35rem, 2.2vw, 2rem);
		line-height: 1;
	}

	.proof-cell span {
		margin-top: 0.55rem;
		color: rgba(232, 255, 251, 70%);
		font-size: 0.78rem;
		font-weight: 800;
	}

	.audience-grid,
	.capability-grid,
	.stats-row {
		display: grid;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.audience-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.capability-grid,
	.stats-row {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.value-card,
	.capability-card,
	.stats-row div {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: white;
		padding: 1.35rem;
		box-shadow: 0 6px 18px rgba(15, 23, 42, 5%);
	}

	.value-card h2 {
		position: relative;
		padding-left: 1.15rem;
		font-size: 1.1rem;
	}

	.value-card h2::before {
		content: '';
		position: absolute;
		top: 0.45rem;
		left: 0;
		width: 0.48rem;
		height: 0.48rem;
		border-radius: 2px;
		background: var(--accent);
		transform: rotate(45deg);
	}

	.value-card p,
	.capability-card p {
		margin-top: 0.55rem;
		font-size: 0.95rem;
	}

	.capability-card {
		border-top: 3px solid var(--cap-accent);
	}

	.capability-card[data-tone='ops'] {
		--cap-accent: var(--tone-ops);
	}

	.capability-card[data-tone='platform'] {
		--cap-accent: var(--tone-platform);
	}

	.capability-card[data-tone='product'] {
		--cap-accent: var(--tone-product);
	}

	.capability-card[data-tone='insights'] {
		--cap-accent: var(--tone-insights);
	}

	.stats-row {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.stats-row strong,
	.stats-row span {
		display: block;
	}

	.stats-row strong {
		color: var(--text);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 1.8rem;
	}

	.blog-cta {
		position: relative;
		display: grid;
		gap: 0.75rem;
		overflow: hidden;
		margin-bottom: 2rem;
		border-radius: 8px;
		background: linear-gradient(135deg, #04302e, #06403c 55%, #0a5049);
		padding: 2rem;
		color: white;
		text-decoration: none;
	}

	.blog-cta::before {
		content: '';
		position: absolute;
		top: -8rem;
		right: -4rem;
		width: 22rem;
		height: 22rem;
		border-radius: 999px;
		background: radial-gradient(circle, rgba(46, 233, 208, 28%), transparent 70%);
	}

	.blog-cta span,
	.blog-cta strong,
	.blog-cta em {
		position: relative;
		z-index: 1;
	}

	.blog-cta span {
		color: var(--accent);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}

	.blog-cta strong {
		max-width: 660px;
		font-size: clamp(1.55rem, 3vw, 2rem);
	}

	.blog-cta em {
		color: #b8eee7;
		font-style: normal;
		font-weight: 900;
	}

	@keyframes matrix-pulse {
		0%,
		100% {
			opacity: 0.38;
			transform: scale(0.94);
		}

		48% {
			opacity: 1;
			transform: scale(1);
		}
	}

	@media (max-width: 900px) {
		.audience-grid,
		.capability-grid,
		.stats-row,
		.proof-grid {
			grid-template-columns: 1fr;
		}

		.hero-watermark {
			display: none;
		}

		.about-hero {
			min-height: auto;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.hero-cursor-glow {
			display: none;
		}
	}
</style>
