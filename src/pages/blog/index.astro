---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const categoryOrder = ['运营方法论', '平台专题', '产品能力解读', '出海观察', '操作教程', '运营实践', '产品更新'];
const allCategoryLabels = new Set(posts.map((post) => post.data.category));
const categories = [
	'全部文章',
	...categoryOrder.filter((category) => allCategoryLabels.has(category)),
	...Array.from(allCategoryLabels).filter((category) => !categoryOrder.includes(category)),
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`博客文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="keyword-ticker" aria-hidden="true">
			<div class="ticker-track">
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>云手机环境</span>
				<span>代理 IP 管理</span>
				<span>批量任务发布</span>
				<span>素材库</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>账号矩阵</span>
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>云手机环境</span>
				<span>代理 IP 管理</span>
				<span>批量任务发布</span>
				<span>素材库</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>账号矩阵</span>
			</div>
		</div>
		<main>
			<section class="page-head">
				<span class="cursor-glow" aria-hidden="true"></span>
				<div class="page-head-copy">
					<span class="section-kicker">麦芽营销团队出品</span>
					<h1>规模化运营社媒账号的实战方法</h1>
					<p>写给需要在 TikTok、Instagram、Reddit 和 X 上管理成百上千个账号的代运营机构、MCN 和出海品牌团队。</p>
					<div class="hero-stats" aria-label="博客内容概览">
						<span><strong>{posts.length}</strong>篇文章</span>
						<span><strong>4</strong>个主题</span>
						<span><strong>Ainnc</strong>实战方法</span>
					</div>
				</div>
				<div class="tile-grid" aria-hidden="true">
					{Array.from({ length: 42 }).map((_, index) => <span class:list={['tile', { bright: index % 8 === 0 || index % 13 === 0 }]} style={`--delay: ${(index % 11) * 0.18}s`} />)}
				</div>
			</section>

			<section class="filter-bar" aria-label="文章分类筛选">
				{
					categories.map((category, index) => (
						<button class:list={['filter-pill', { selected: index === 0 }]} type="button" data-filter={category}>
							<span class="dot" aria-hidden="true"></span>
							{category}
						</button>
					))
				}
			</section>

			<section class="post-grid" id="post-grid">
				{posts.map((post, index) => <PostCard post={post} index={index} featured={index === 0} />)}
			</section>
		</main>
		<Footer />
		<script>
			const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
			const cards = document.querySelectorAll<HTMLElement>('#post-grid > [data-category]');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					filterButtons.forEach((item) => item.classList.remove('selected'));
					button.classList.add('selected');
					const filter = button.dataset.filter;

					cards.forEach((card) => {
						const visible = filter === '全部文章' || card.dataset.category === filter;
						card.toggleAttribute('hidden', !visible);
					});
				});
			});

			const heroPanels = document.querySelectorAll<HTMLElement>('.page-head');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (supportsHover) {
				heroPanels.forEach((panel) => {
					panel.addEventListener('pointermove', (event) => {
						const rect = panel.getBoundingClientRect();
						panel.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
						panel.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerenter', () => {
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerleave', () => {
						panel.classList.remove('is-glowing');
					});
				});
			}
		</script>
	</body>
</html>

<style>
	.keyword-ticker {
		overflow: hidden;
		border-bottom: 1px solid rgba(6, 39, 42, 14%);
		background: #06272a;
		color: #d8fffa;
	}

	.ticker-track {
		display: flex;
		width: max-content;
		gap: 2rem;
		padding: 0.45rem 0;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.76rem;
		font-weight: 800;
		letter-spacing: 0.11em;
		animation: ticker-slide 34s linear infinite;
	}

	.ticker-track span {
		position: relative;
		white-space: nowrap;
		opacity: 0.86;
	}

	.ticker-track span::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1.15rem;
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 999px;
		background: var(--accent);
		transform: translateY(-50%);
	}

	@keyframes ticker-slide {
		to {
			transform: translateX(-50%);
		}
	}

	.page-head {
		--glow-x: 50%;
		--glow-y: 50%;
		position: relative;
		isolation: isolate;
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(260px, 0.92fr);
		gap: 2rem;
		align-items: center;
		margin-bottom: 1.35rem;
		overflow: hidden;
		padding: clamp(2rem, 5vw, 4rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(0, 201, 170, 12%), rgba(0, 69, 76, 6%)),
			white;
		box-shadow: var(--shadow);
	}

	.cursor-glow {
		position: absolute;
		z-index: 0;
		inset: -12%;
		background: radial-gradient(
			circle 260px at var(--glow-x) var(--glow-y),
			rgba(46, 233, 208, 38%),
			rgba(0, 201, 170, 16%) 34%,
			rgba(0, 125, 118, 8%) 48%,
			transparent 72%
		);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.page-head.is-glowing .cursor-glow {
		opacity: 1;
	}

	.page-head-copy {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1rem;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.page-head p {
		max-width: 720px;
		font-size: 1.05rem;
	}

	.hero-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 0.25rem;
		color: var(--muted);
		font-weight: 800;
	}

	.hero-stats span {
		border: 1px solid rgba(0, 201, 170, 28%);
		border-radius: 999px;
		background: rgba(255, 255, 255, 70%);
		padding: 0.45rem 0.75rem;
	}

	.hero-stats strong {
		margin-right: 0.2rem;
		color: var(--text);
	}

	.tile-grid {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.tile {
		aspect-ratio: 1;
		border-radius: 7px;
		background: rgba(0, 177, 179, 10%);
		animation: tile-breathe 4.8s ease-in-out var(--delay) infinite;
	}

	.tile.bright {
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		box-shadow: 0 10px 28px rgba(0, 201, 170, 24%);
	}

	@keyframes tile-breathe {
		0%,
		100% {
			opacity: 0.42;
			transform: scale(0.94);
		}

		45% {
			opacity: 1;
			transform: scale(1);
		}
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-items: center;
		margin-bottom: 1rem;
	}

	.filter-pill {
		display: inline-flex;
		gap: 0.45rem;
		align-items: center;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: white;
		padding: 0.55rem 0.9rem;
		color: var(--muted);
		font: inherit;
		font-weight: 800;
		cursor: pointer;
	}

	.filter-pill .dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.45;
	}

	.filter-pill:hover,
	.filter-pill.selected {
		border-color: var(--accent-dark);
		background: #063f3c;
		color: white;
	}

	.filter-pill.selected .dot {
		opacity: 1;
	}

	@media (max-width: 900px) {
		.page-head {
			grid-template-columns: 1fr;
		}

		.tile-grid {
			display: none;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.cursor-glow {
			display: none;
		}
	}
</style>
