---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostCode } from '../../blogVisuals';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const postOrder = [
	'scaling-social-account-operations',
	'peak-season-scaling',
	'account-first-three-days',
	'asset-library-reuse',
	'new-client-first-week',
	'team-scale-chaos',
	'spreadsheets-break-50',
	'real-social-ops-platform',
	'task-center',
	'mcn-prove-value-with-data',
	'cloud-phone-vs-browser',
	'proxy-ip-types',
	'one-workflow-five-tools',
	'tiktok-risk-guide',
	'global-brand-scale',
	'localization-how-deep',
];
const posts = (await getCollection('blog', (entry) => !entry.data.draft && postOrder.includes(entry.id))).sort((a, b) => {
	const aOrder = postOrder.indexOf(a.id);
	const bOrder = postOrder.indexOf(b.id);
	return (aOrder === -1 ? 999 : aOrder) - (bOrder === -1 ? 999 : bOrder);
});
const featuredPost = posts[0];
const gridPosts = posts.slice(1);
const spanMap: Record<string, 'wide' | 'tall' | 'none'> = {
	'spreadsheets-break-50': 'tall',
	'real-social-ops-platform': 'wide',
	'tiktok-risk-guide': 'wide',
};
const categoryCounters: Record<string, number> = featuredPost ? { [featuredPost.data.category]: 1 } : {};
const nextCategoryIndex = (category: string) => {
	const value = categoryCounters[category] ?? 0;
	categoryCounters[category] = value + 1;
	return value;
};
const categoryOrder = ['运营方法论', '平台专题', '产品能力解读', '出海观察', '操作教程', '运营实践', '产品更新'];
const allCategoryLabels = new Set(posts.map((post) => post.data.category));
const categories = [
	'全部文章',
	...categoryOrder.filter((category) => allCategoryLabels.has(category)),
	...Array.from(allCategoryLabels).filter((category) => !categoryOrder.includes(category)),
];
const featuredCode = featuredPost ? getPostCode(featuredPost.data.category, 0) : 'OPS-01';
const heroLogRows = [
	['12:02:35', 'TT-05', '同步数据', 'TikTok', '完成'],
	['12:02:35', 'IG-06', '渲染素材', 'Instagram', '完成'],
	['12:02:35', 'TT-05', '养号互动', 'TikTok', '完成'],
	['12:02:37', 'RD-03', '同步数据', 'Reddit', '完成'],
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`博客文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="keyword-ticker" aria-hidden="true">
			<div class="ticker-track">
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>云手机环境</span>
				<span>代理 IP 管理</span>
				<span>批量任务发布</span>
				<span>素材库</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>账号矩阵</span>
				<span>TIKTOK</span>
				<span>INSTAGRAM</span>
				<span>云手机环境</span>
				<span>代理 IP 管理</span>
				<span>批量任务发布</span>
				<span>素材库</span>
				<span>REDDIT</span>
				<span>X</span>
				<span>账号矩阵</span>
			</div>
		</div>
		<main>
			<section class="page-head">
				<span class="cursor-glow" aria-hidden="true"></span>
				<img class="hero-watermark" src="/ainnc-logo-icon.webp" alt="" aria-hidden="true" />
				<div class="page-head-copy">
					<span class="section-kicker">麦芽营销团队出品</span>
					<h1>当账号数量 从 1 变成 <em id="counter-num">1000+</em></h1>
					<p>写给需要在 TikTok、Instagram、Reddit 和 X 上管理成百上千个账号的代运营机构、MCN 和出海品牌团队。</p>
				</div>
				<div class="ops-dashboard" aria-label="博客运营任务实时日志">
					<div class="ops-head">
						<span>运营任务 · 实时日志</span>
						<em><span></span>LIVE</em>
					</div>
					<div class="ops-log">
						<div class="ops-log-track">
							{
								heroLogRows.map(([time, device, action, platform, status], index) => (
									<div class="ops-row" style={`--delay: ${index * 0.16}s`}>
										<span>{time}</span>
										<strong>{device}</strong>
										<span>{action}</span>
										<b>{platform}</b>
										<em>{status}</em>
									</div>
								))
							}
						</div>
					</div>
					<div class="ops-stats" aria-label="博客内容数据">
						<span><strong data-live-stat="content" data-base="2855">2,855</strong>本周发布内容</span>
						<span><strong>{posts.length}</strong>篇实战文章</span>
						<span><strong>4</strong>覆盖平台</span>
					</div>
				</div>
			</section>

			{
				featuredPost && (
					<section class="spotlight-card">
						<div class="spotlight-copy">
							<div class="article-code">
								<span>FEATURED</span>
								<span aria-hidden="true">/</span>
								<span>{featuredCode}</span>
							</div>
							<h2>
								<a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
							</h2>
							<p>{featuredPost.data.description}</p>
						</div>
						<div class="spotlight-meta">
							<span><FormattedDate date={featuredPost.data.pubDate} /></span>
							<span>7 MIN</span>
							<a href={`/blog/${featuredPost.id}/`}>阅读全文 -&gt;</a>
						</div>
					</section>
				)
			}

			<section class="filter-bar" aria-label="文章分类筛选">
				{
					categories.map((category, index) => (
						<button class:list={['filter-pill', { selected: index === 0 }]} type="button" data-filter={category}>
							<span class="dot" aria-hidden="true"></span>
							{category}
						</button>
					))
				}
			</section>

			<section class="post-grid bento-grid" id="post-grid">
				{gridPosts.map((post) => <PostCard post={post} index={nextCategoryIndex(post.data.category)} variant="bento" span={spanMap[post.id] ?? 'none'} />)}
			</section>
		</main>
		<Footer />
		<script>
			const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
			const cards = document.querySelectorAll<HTMLElement>('#post-grid > [data-category]');

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					filterButtons.forEach((item) => item.classList.remove('selected'));
					button.classList.add('selected');
					const filter = button.dataset.filter;

					cards.forEach((card) => {
						const visible = filter === '全部文章' || card.dataset.category === filter;
						card.toggleAttribute('hidden', !visible);
					});
				});
			});

			const heroPanels = document.querySelectorAll<HTMLElement>('.page-head');
			const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

			if (supportsHover) {
				heroPanels.forEach((panel) => {
					panel.addEventListener('pointermove', (event) => {
						const rect = panel.getBoundingClientRect();
						panel.style.setProperty('--glow-x', `${event.clientX - rect.left}px`);
						panel.style.setProperty('--glow-y', `${event.clientY - rect.top}px`);
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerenter', () => {
						panel.classList.add('is-glowing');
					});

					panel.addEventListener('pointerleave', () => {
						panel.classList.remove('is-glowing');
					});
				});

				document.querySelectorAll<HTMLElement>('.post-card').forEach((card) => {
					card.addEventListener('pointermove', (event) => {
						const rect = card.getBoundingClientRect();
						const x = event.clientX - rect.left;
						const y = event.clientY - rect.top;
						const rotateX = ((y / rect.height) - 0.5) * -4;
						const rotateY = ((x / rect.width) - 0.5) * 4;
						card.style.setProperty('--glare-x', `${event.clientX - rect.left}px`);
						card.style.setProperty('--glare-y', `${event.clientY - rect.top}px`);
						if (card.classList.contains('bento')) {
							card.style.transform = `translateY(-4px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
						}
					});

					card.addEventListener('pointerleave', () => {
						card.style.transform = '';
					});
				});
			}

			const counter = document.getElementById('counter-num');
			if (counter && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				let value = 1;
				const step = () => {
					value = Math.min(1000, value + Math.ceil((1000 - value) / 9));
					counter.textContent = `${value}+`;
					if (value < 1000) {
						window.requestAnimationFrame(step);
					}
				};
				window.requestAnimationFrame(step);
			}

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const logTrack = document.querySelector<HTMLElement>('.ops-log-track');
			const liveStat = document.querySelector<HTMLElement>('[data-live-stat="content"]');
			const liveRows = [
				['TT-05', '同步数据', 'TikTok', '完成'],
				['IG-06', '渲染素材', 'Instagram', '完成'],
				['RD-03', '帖子排队', 'Reddit', '运行中'],
				['X-08', '账号巡检', 'X', '完成'],
				['IP-02', '代理切换', 'Proxy', '完成'],
				['TT-01', '批量发布', 'TikTok', '完成'],
				['IG-04', '素材入库', 'Instagram', '运行中'],
			];

			const formatNumber = (value: number) => new Intl.NumberFormat('en-US').format(value);
			const currentTime = () => new Date().toLocaleTimeString('zh-CN', { hour12: false });

			const animateNumber = (from: number, to: number) => {
				if (!liveStat) return;
				if (reduceMotion) {
					liveStat.textContent = formatNumber(to);
					return;
				}

				const start = performance.now();
				const duration = 520;
				liveStat.classList.add('is-ticking');

				const draw = (now: number) => {
					const progress = Math.min(1, (now - start) / duration);
					const eased = 1 - Math.pow(1 - progress, 3);
					liveStat.textContent = formatNumber(Math.round(from + (to - from) * eased));
					if (progress < 1) {
						window.requestAnimationFrame(draw);
					} else {
						window.setTimeout(() => liveStat.classList.remove('is-ticking'), 120);
					}
				};

				window.requestAnimationFrame(draw);
			};

			if (logTrack && liveStat) {
				let rowIndex = 0;
				let statValue = Number(liveStat.dataset.base ?? '2855');

				const createRow = ([device, action, platform, status]: string[]) => {
					const row = document.createElement('div');
					row.className = 'ops-row is-new';
					const cells = [
						['span', currentTime()],
						['strong', device],
						['span', action],
						['b', platform],
						['em', status],
					];

					cells.forEach(([tag, text]) => {
						const cell = document.createElement(tag);
						cell.textContent = text;
						row.appendChild(cell);
					});
					return row;
				};

				const advanceLog = () => {
					const firstRow = logTrack.firstElementChild as HTMLElement | null;
					if (!firstRow || logTrack.classList.contains('is-updating')) return;

					const nextRow = createRow(liveRows[rowIndex % liveRows.length]);
					rowIndex += 1;
					logTrack.appendChild(nextRow);
					logTrack.classList.add('is-updating');
					window.requestAnimationFrame(() => firstRow.classList.add('is-leaving'));

					window.setTimeout(() => {
						firstRow.remove();
						nextRow.classList.remove('is-new');
						logTrack.classList.remove('is-updating');
						statValue += 1 + (rowIndex % 3);
						animateNumber(Number(liveStat.textContent?.replace(/,/g, '') ?? statValue), statValue);
					}, reduceMotion ? 0 : 680);
				};

				if (!reduceMotion) {
					window.setInterval(advanceLog, 1750);
				}
			}
		</script>
	</body>
</html>

<style>
	.keyword-ticker {
		overflow: hidden;
		border-bottom: 1px solid rgba(6, 39, 42, 14%);
		background: #06272a;
		color: #d8fffa;
	}

	.ticker-track {
		display: flex;
		width: max-content;
		gap: 2rem;
		padding: 0.45rem 0;
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.76rem;
		font-weight: 800;
		letter-spacing: 0.11em;
		animation: ticker-slide 34s linear infinite;
	}

	.ticker-track span {
		position: relative;
		white-space: nowrap;
		opacity: 0.86;
	}

	.ticker-track span::after {
		content: '';
		position: absolute;
		top: 50%;
		right: -1.15rem;
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 999px;
		background: var(--accent);
		transform: translateY(-50%);
	}

	@keyframes ticker-slide {
		to {
			transform: translateX(-50%);
		}
	}

	.page-head {
		--glow-x: 50%;
		--glow-y: 50%;
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 620px;
		gap: clamp(1.75rem, 4vw, 3rem);
		justify-items: center;
		margin-bottom: 2rem;
		overflow: hidden;
		padding: clamp(2.5rem, 6vw, 5.5rem) clamp(1.25rem, 5vw, 4rem);
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			radial-gradient(circle at 72% 22%, rgba(0, 201, 170, 22%), transparent 19rem),
			linear-gradient(135deg, rgba(224, 255, 249, 92%), rgba(244, 255, 252, 88%) 54%, rgba(255, 255, 255, 86%)),
			white;
		box-shadow: 0 24px 70px rgba(0, 69, 76, 12%);
		text-align: center;
	}

	.cursor-glow {
		position: absolute;
		z-index: 0;
		inset: -12%;
		background: radial-gradient(
			circle 260px at var(--glow-x) var(--glow-y),
			rgba(46, 233, 208, 38%),
			rgba(0, 201, 170, 16%) 34%,
			rgba(0, 125, 118, 8%) 48%,
			transparent 72%
		);
		filter: blur(14px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.28s ease;
	}

	.page-head.is-glowing .cursor-glow {
		opacity: 1;
	}

	.hero-watermark {
		position: absolute;
		right: clamp(-8rem, -8vw, -3rem);
		top: 4rem;
		z-index: 0;
		width: min(42rem, 54vw);
		opacity: 0.06;
		filter: grayscale(1) brightness(0.45);
		transform: rotate(-7deg);
	}

	.page-head-copy {
		position: relative;
		z-index: 2;
		display: grid;
		gap: 1rem;
		max-width: 760px;
		justify-items: center;
	}

	.section-kicker {
		display: inline-flex;
		gap: 0.65rem;
		align-items: center;
		width: fit-content;
		color: var(--accent-dark);
		font-weight: 900;
	}

	.section-kicker::before {
		content: '';
		width: 1.75rem;
		height: 2px;
		background: var(--accent);
	}

	.page-head p {
		max-width: 700px;
		font-size: clamp(1rem, 1.6vw, 1.15rem);
	}

	.page-head h1 em {
		color: var(--accent-dark);
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-style: normal;
	}

	.ops-dashboard {
		position: relative;
		z-index: 2;
		width: min(720px, 100%);
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 8px;
		background:
			linear-gradient(155deg, rgba(3, 39, 40, 94%), rgba(4, 85, 75, 92%)),
			#06272a;
		padding: clamp(1rem, 2vw, 1.35rem);
		box-shadow: 0 28px 64px rgba(0, 69, 76, 28%);
		text-align: left;
	}

	.ops-head,
	.ops-stats {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.ops-head {
		margin-bottom: 1rem;
		color: #d8fffa;
		font-weight: 900;
	}

	.ops-head span,
	.ops-head em,
	:global(.ops-row),
	.ops-stats strong {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	.ops-head > span {
		font-size: 0.78rem;
	}

	.ops-head em {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		border: 1px solid rgba(46, 233, 208, 22%);
		border-radius: 999px;
		background: rgba(46, 233, 208, 10%);
		padding: 0.25rem 0.55rem;
		color: #8dfff0;
		font-size: 0.66rem;
		font-style: normal;
	}

	.ops-head em span {
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 999px;
		background: var(--accent);
		box-shadow: 0 0 0 5px rgba(0, 201, 170, 12%);
		animation: live-pulse 1.35s ease-in-out infinite;
	}

	.ops-log {
		overflow: hidden;
		height: 9.15rem;
		border-radius: 8px;
		background:
			radial-gradient(circle at 28% 16%, rgba(0, 201, 170, 12%), transparent 16rem),
			rgba(0, 24, 26, 42%);
		padding: 0.82rem 1.05rem;
	}

	.ops-log-track {
		display: grid;
		align-content: start;
	}

	:global(.ops-row) {
		display: grid;
		grid-template-columns: 5rem 4.4rem minmax(7rem, 1fr) minmax(5.6rem, 0.75fr) 3rem;
		align-items: center;
		gap: 1rem;
		max-height: 2.76rem;
		overflow: hidden;
		border-bottom: 1px solid rgba(141, 255, 240, 8%);
		padding: 0.42rem 0;
		color: rgba(216, 255, 250, 82%);
		font-size: clamp(0.68rem, 1.18vw, 0.82rem);
		font-weight: 800;
		line-height: 1;
		transition:
			max-height 680ms cubic-bezier(0.33, 1, 0.68, 1),
			opacity 360ms ease,
			padding 680ms cubic-bezier(0.33, 1, 0.68, 1),
			border-color 360ms ease;
	}

	:global(.ops-row:last-child) {
		border-bottom: 0;
	}

	:global(.ops-row.is-new) {
		border-bottom-color: rgba(141, 255, 240, 24%);
		background: linear-gradient(90deg, rgba(46, 233, 208, 16%), transparent 72%);
		max-height: 0;
		opacity: 0;
		padding-top: 0;
		padding-bottom: 0;
		animation: row-arrive 680ms cubic-bezier(0.33, 1, 0.68, 1) forwards;
	}

	:global(.ops-row.is-leaving) {
		max-height: 0;
		opacity: 0;
		border-bottom-color: transparent;
		padding-top: 0;
		padding-bottom: 0;
	}

	:global(.ops-row strong),
	:global(.ops-row b),
	:global(.ops-row em) {
		min-width: 0;
		overflow: hidden;
		color: #8dfff0;
		font-style: normal;
		font-weight: 900;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	:global(.ops-row span) {
		min-width: 0;
		overflow: hidden;
		color: rgba(216, 255, 250, 76%);
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	:global(.ops-row > *) {
		display: block;
		min-width: 0;
	}

	:global(.ops-row b),
	:global(.ops-row em) {
		text-align: right;
	}

	.ops-stats {
		margin-top: 1rem;
		border-top: 1px solid rgba(255, 255, 255, 8%);
		padding-top: 1rem;
		color: rgba(216, 255, 250, 70%);
		font-size: 0.76rem;
		font-weight: 800;
	}

	.ops-stats span,
	.ops-stats strong {
		display: block;
	}

	.ops-stats strong {
		margin-bottom: 0.25rem;
		color: white;
		font-size: clamp(1.1rem, 2vw, 1.45rem);
		transition:
			color 180ms ease,
			text-shadow 180ms ease,
			transform 180ms ease;
	}

	.ops-stats strong.is-ticking {
		color: #8dfff0;
		text-shadow: 0 0 16px rgba(46, 233, 208, 38%);
		transform: translateY(-1px) scale(1.045);
	}

	@keyframes live-pulse {
		50% {
			box-shadow: 0 0 0 8px rgba(0, 201, 170, 4%);
			transform: scale(0.9);
		}
	}

	@keyframes row-arrive {
		from {
			max-height: 0;
			opacity: 0;
			padding-top: 0;
			padding-bottom: 0;
		}

		45% {
			opacity: 0.72;
		}

		to {
			max-height: 2.76rem;
			opacity: 1;
			background: transparent;
			padding-top: 0.42rem;
			padding-bottom: 0.42rem;
		}
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-items: center;
		margin-bottom: 1rem;
	}

	.spotlight-card {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1rem;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(135deg, rgba(6, 39, 42, 92%), rgba(4, 63, 60, 88%)),
			white;
		padding: clamp(1.3rem, 3vw, 2rem);
		box-shadow: var(--shadow);
	}

	.spotlight-card::before {
		content: '';
