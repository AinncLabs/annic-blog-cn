---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getCategoryTone } from '../../blogVisuals';

export async function getStaticPaths() {
	const postOrder = [
		'scaling-social-account-operations',
		'peak-season-scaling',
		'account-first-three-days',
		'asset-library-reuse',
		'new-client-first-week',
		'team-scale-chaos',
		'account-grouping-strategy',
		'spreadsheets-break-50',
		'real-social-ops-platform',
		'task-center',
		'mcn-prove-value-with-data',
		'cloud-phone-vs-browser',
		'proxy-ip-types',
		'one-workflow-five-tools',
		'tiktok-risk-guide',
		'global-brand-scale',
		'localization-how-deep',
		'tiktok-rate-limit',
		'device-account-limit',
		'cross-border-ecommerce-social-accounts',
		'operations-team-efficiency',
		'tiktok-account-banned',
		'overseas-social-tools-checklist',
		'cloud-phone-vs-emulator',
		'multi-platform-device-management',
		'agency-pricing-models',
		'legacy-account-audit',
		'account-device-proxy-guide',
		'task-files-publishing',
		'ainnc-start',
	];
	const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => {
		const aOrder = postOrder.indexOf(a.id);
		const bOrder = postOrder.indexOf(b.id);
		return (aOrder === -1 ? 999 : aOrder) - (bOrder === -1 ? 999 : bOrder);
	});
	const toneCounters: Record<string, number> = {};

	return posts.map((post) => {
		const tone = getCategoryTone(post.data.category);
		const postIndex = toneCounters[tone] ?? 0;
		toneCounters[tone] = postIndex + 1;

		return {
			params: { slug: post.id },
			props: { post, postIndex },
		};
	});
}
type Props = {
	post: CollectionEntry<'blog'>;
	postIndex: number;
};

function plainMarkdown(text: string) {
	return text
		.replace(/!\[([^\]]*)\]\([^)]+\)/g, '$1')
		.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
		.replace(/<[^>]+>/g, '')
		.replace(/[`*_~]/g, '')
		.replace(/\s+/g, ' ')
		.trim();
}

function extractMarkdownFaq(body: string) {
	const heading = body.match(/^##\s+(?:FAQ|常见问题)\s*$/m);
	if (!heading || heading.index === undefined) return [];
	const afterHeading = body.slice(heading.index + heading[0].length);
	const nextSection = afterHeading.search(/^##\s+/m);
	const section = nextSection === -1 ? afterHeading : afterHeading.slice(0, nextSection);
	const questions = Array.from(section.matchAll(/^###\s+(.+?)\s*$/gm));
	return questions.map((question, index) => {
		const answerStart = (question.index ?? 0) + question[0].length;
		const answerEnd = index + 1 < questions.length ? questions[index + 1].index ?? section.length : section.length;
		return {
			question: plainMarkdown(question[1]),
			answer: plainMarkdown(section.slice(answerStart, answerEnd).split('\n\n', 1)[0]),
		};
	});
}

const { post, postIndex } = Astro.props;
const { Content } = await render(post);
const schemaFaq = extractMarkdownFaq(post.body);
---

<BlogPost {...post.data} postId={post.id} postIndex={postIndex} {schemaFaq}>
	<Content />
</BlogPost>
